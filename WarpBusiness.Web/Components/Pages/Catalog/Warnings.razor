@page "/catalog/warnings"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using WarpBusiness.Web.Services
@inherits WarpBusiness.Web.Components.AuthenticatedComponentBase
@inject CatalogApiClient CatalogApi
@inject NavigationManager Navigation

<PageTitle>Catalog Warnings</PageTitle>

<h1 class="mb-4">Catalog Warnings</h1>

<AuthorizeView>
    <Authorized Context="authContext">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
            </div>
        }

        @if (isLoading)
        {
            <div class="d-flex justify-content-center my-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            @if (showFormModal)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">@(editingId.HasValue ? "Edit Warning" : "Add Warning")</h5>
                                <button type="button" class="btn-close" @onclick="CloseModal"></button>
                            </div>
                            <div class="modal-body">
                                <EditForm Model="formModel" OnValidSubmit="HandleSubmit" FormName="warningForm">
                                    <DataAnnotationsValidator />
                                    <ValidationSummary class="text-danger mb-3" />
                                    <div class="row g-3">
                                        <div class="col-12">
                                            <label class="form-label">Name <span class="text-danger">*</span></label>
                                            <InputText @bind-Value="formModel.Name" class="form-control" />
                                            <ValidationMessage For="() => formModel.Name" class="text-danger" />
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">Icon / Prefix</label>
                                            <InputText @bind-Value="formModel.Icon" class="form-control" placeholder="e.g. ⚠ WARNING: or ⚠ CA WARNING:" />
                                            <div class="form-text">Emoji or short text shown before the warning name (e.g. ⚠ WARNING:, ⚠ CA WARNING:, ⚠ CALIFORNIA WARNING:).</div>
                                            @if (!string.IsNullOrWhiteSpace(formModel.Icon))
                                            {
                                                <div class="mt-2 p-2 rounded" style="background:rgba(255,200,0,0.08); border:1px solid rgba(255,200,0,0.25);">
                                                    <span class="fw-semibold">Preview: </span>
                                                    <span>@formModel.Icon @formModel.Name</span>
                                                </div>
                                            }
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">Description</label>
                                            <InputTextArea @bind-Value="formModel.Description" class="form-control" rows="2" />
                                        </div>
                                        @if (editingId.HasValue)
                                        {
                                            <div class="col-12">
                                                <div class="form-check form-switch">
                                                    <InputCheckbox @bind-Value="formModel.IsActive" class="form-check-input" id="warnActiveSwitch" />
                                                    <label class="form-check-label" for="warnActiveSwitch">
                                                        @(formModel.IsActive ? "Active" : "Inactive")
                                                    </label>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    <div class="mt-3">
                                        <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                                            @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                            @(editingId.HasValue ? "Update Warning" : "Create Warning")
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary ms-2" @onclick="CloseModal">Cancel</button>
                                    </div>
                                </EditForm>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (showDeleteConfirm && deleteCandidate != null)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Confirm Delete</h5>
                                <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                            </div>
                            <div class="modal-body">
                                <p>Delete warning <strong>@deleteCandidate.Name</strong>?</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                                <button type="button" class="btn btn-danger" @onclick="ExecuteDelete" disabled="@isSubmitting">
                                    @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                    Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Warnings (@(warnings?.Count ?? 0))</h5>
                <button class="btn btn-primary" @onclick="ShowAddModal">
                    <span class="bi bi-plus-lg me-1"></span> Add Warning
                </button>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Icon</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th style="width: 250px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (warnings is { Count: > 0 })
                        {
                            @foreach (var w in warnings.OrderBy(w => w.Name))
                            {
                                <tr>
                                    <td class="text-nowrap">@(string.IsNullOrWhiteSpace(w.Icon) ? "—" : w.Icon)</td>
                                    <td>@w.Name</td>
                                    <td class="text-truncate" style="max-width:300px;">@(w.Description ?? "—")</td>
                                    <td>
                                        <span class="badge @(w.IsActive ? "bg-success" : "bg-secondary")">
                                            @(w.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ShowEditModal(w)">Edit</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(w)">Delete</button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">No warnings defined yet.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-warning"><h4>Access Denied</h4><p>You must be logged in. <a href="/login">Login</a></p></div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<CatalogWarningResponse>? warnings;
    private bool isLoading = true;
    private bool isSubmitting;
    private bool showFormModal;
    private bool showDeleteConfirm;
    private Guid? editingId;
    private CatalogWarningResponse? deleteCandidate;
    private string? errorMessage;
    private string? successMessage;
    private WarningFormModel formModel = new();

    protected override async Task OnAuthenticatedInitializedAsync()
    {
        if (string.IsNullOrEmpty(TokenProvider.SelectedTenantId))
        {
            Navigation.NavigateTo("/select-tenant");
            return;
        }
        await LoadWarnings();
        isLoading = false;
    }

    private async Task LoadWarnings()
    {
        try { warnings = await CatalogApi.GetWarningsAsync(); }
        catch (Exception ex) { errorMessage = $"Failed to load warnings: {ex.Message}"; }
    }

    private void ShowAddModal()
    {
        formModel = new WarningFormModel();
        editingId = null;
        showFormModal = true;
    }

    private void ShowEditModal(CatalogWarningResponse w)
    {
        formModel = new WarningFormModel { Name = w.Name, Description = w.Description, Icon = w.Icon, IsActive = w.IsActive };
        editingId = w.Id;
        showFormModal = true;
    }

    private void CloseModal()
    {
        showFormModal = false;
        editingId = null;
        formModel = new WarningFormModel();
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            if (editingId.HasValue)
            {
                await CatalogApi.UpdateWarningAsync(editingId.Value,
                    new UpdateCatalogWarningRequest(formModel.Name!, formModel.Description, formModel.Icon, formModel.IsActive));
                successMessage = "Warning updated.";
            }
            else
            {
                await CatalogApi.CreateWarningAsync(new CreateCatalogWarningRequest(formModel.Name!, formModel.Description, formModel.Icon));
                successMessage = "Warning created.";
            }
            CloseModal();
            await LoadWarnings();
        }
        catch (ApiException ex) { errorMessage = ex.Message; }
        catch (Exception ex) { errorMessage = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private void ConfirmDelete(CatalogWarningResponse w)
    {
        deleteCandidate = w;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        deleteCandidate = null;
    }

    private async Task ExecuteDelete()
    {
        if (deleteCandidate is null) return;
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            var msg = await CatalogApi.DeleteWarningAsync(deleteCandidate.Id);
            successMessage = msg ?? "Warning deleted.";
            CancelDelete();
            await LoadWarnings();
        }
        catch (ApiException ex) { errorMessage = ex.Message; }
        catch (Exception ex) { errorMessage = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private class WarningFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string? Name { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(50)]
        public string? Icon { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(1000)]
        public string? Description { get; set; }

        public bool IsActive { get; set; } = true;
    }
}
