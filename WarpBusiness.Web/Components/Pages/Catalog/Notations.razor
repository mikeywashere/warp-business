@page "/catalog/notations"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using WarpBusiness.Web.Services
@inherits WarpBusiness.Web.Components.AuthenticatedComponentBase
@inject CatalogApiClient CatalogApi
@inject NavigationManager Navigation

<PageTitle>Catalog Notations</PageTitle>

<h1 class="mb-4">Catalog Notations</h1>

<AuthorizeView>
    <Authorized Context="authContext">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
            </div>
        }

        @if (isLoading)
        {
            <div class="d-flex justify-content-center my-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            @if (showFormModal)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">@(editingId.HasValue ? "Edit Notation" : "Add Notation")</h5>
                                <button type="button" class="btn-close" @onclick="CloseModal"></button>
                            </div>
                            <div class="modal-body">
                                <EditForm Model="formModel" OnValidSubmit="HandleSubmit" FormName="notationForm">
                                    <DataAnnotationsValidator />
                                    <ValidationSummary class="text-danger mb-3" />
                                    <div class="row g-3">
                                        <div class="col-12">
                                            <label class="form-label">Name <span class="text-danger">*</span></label>
                                            <InputText @bind-Value="formModel.Name" class="form-control" />
                                            <ValidationMessage For="() => formModel.Name" class="text-danger" />
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">Icon</label>
                                            <div class="d-flex align-items-center gap-2">
                                                <InputSelect @bind-Value="formModel.Icon" class="form-select">
                                                    <option value="">(No Icon)</option>
                                                    <option value="Warning">Warning</option>
                                                    <option value="Info">Info</option>
                                                    <option value="Note">Note</option>
                                                    <option value="Caution">Caution</option>
                                                    <option value="Danger">Danger</option>
                                                    <option value="Prohibited">Prohibited</option>
                                                    <option value="Flammable">Flammable</option>
                                                    <option value="Chemical">Chemical Hazard</option>
                                                    <option value="ElectricalHazard">Electrical Hazard</option>
                                                    <option value="Recyclable">Recyclable</option>
                                                    <option value="EcoFriendly">Eco Friendly</option>
                                                    <option value="FoodAllergen">Food Allergen</option>
                                                    <option value="Prop65">CA Prop 65</option>
                                                    <option value="Compliance">Compliance</option>
                                                    <option value="Temperature">Temperature</option>
                                                </InputSelect>
                                                @if (!string.IsNullOrEmpty(formModel.Icon) && formModel.Icon != "None")
                                                {
                                                    <i class="bi @GetIconClass(formModel.Icon)" style="font-size: 1.5rem; color: var(--clr-text);"></i>
                                                }
                                            </div>
                                            <div class="form-text">Icon displayed with the notation in catalogs</div>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">Description</label>
                                            <InputTextArea @bind-Value="formModel.Description" class="form-control" rows="2" />
                                        </div>
                                        @if (editingId.HasValue)
                                        {
                                            <div class="col-12">
                                                <div class="form-check form-switch">
                                                    <InputCheckbox @bind-Value="formModel.IsActive" class="form-check-input" id="notationActiveSwitch" />
                                                    <label class="form-check-label" for="notationActiveSwitch">
                                                        @(formModel.IsActive ? "Active" : "Inactive")
                                                    </label>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    <div class="mt-3">
                                        <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                                            @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                            @(editingId.HasValue ? "Update Notation" : "Create Notation")
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary ms-2" @onclick="CloseModal">Cancel</button>
                                    </div>
                                </EditForm>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (showDeleteConfirm && deleteCandidate != null)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Confirm Delete</h5>
                                <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                            </div>
                            <div class="modal-body">
                                <p>Delete notation <strong>@deleteCandidate.Name</strong>?</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                                <button type="button" class="btn btn-danger" @onclick="ExecuteDelete" disabled="@isSubmitting">
                                    @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                    Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Notations (@(notations?.Count ?? 0))</h5>
                <button class="btn btn-primary" @onclick="ShowAddModal">
                    <span class="bi bi-plus-lg me-1"></span> Add Notation
                </button>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Icon</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th style="width: 250px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (notations is { Count: > 0 })
                        {
                            @foreach (var n in notations.OrderBy(n => n.Name))
                            {
                                <tr>
                                    <td class="text-nowrap">
                                        @if (!string.IsNullOrWhiteSpace(n.Icon))
                                        {
                                            <i class="bi @GetIconClass(n.Icon)" style="font-size: 1.2rem;"></i>
                                        }
                                        else
                                        {
                                            <span>—</span>
                                        }
                                    </td>
                                    <td>@n.Name</td>
                                    <td class="text-truncate" style="max-width:300px;">@(n.Description ?? "—")</td>
                                    <td>
                                        <span class="badge @(n.IsActive ? "bg-success" : "bg-secondary")">
                                            @(n.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm mt-2 btn-outline-primary me-1" @onclick="() => ShowEditModal(n)">Edit</button>
                                        <button class="btn btn-sm mt-2 btn-outline-danger" @onclick="() => ConfirmDelete(n)">Delete</button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">No notations defined yet.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-warning"><h4>Access Denied</h4><p>You must be logged in. <a href="/login">Login</a></p></div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<CatalogNotationResponse>? notations;
    private bool isLoading = true;
    private bool isSubmitting;
    private bool showFormModal;
    private bool showDeleteConfirm;
    private Guid? editingId;
    private CatalogNotationResponse? deleteCandidate;
    private string? errorMessage;
    private string? successMessage;
    private NotationFormModel formModel = new();

    protected override async Task OnAuthenticatedInitializedAsync()
    {
        if (string.IsNullOrEmpty(TokenProvider.SelectedTenantId))
        {
            Navigation.NavigateTo("/select-tenant");
            return;
        }
        await LoadNotations();
        isLoading = false;
    }

    private async Task LoadNotations()
    {
        try { notations = await CatalogApi.GetNotationsAsync(); }
        catch (Exception ex) { errorMessage = $"Failed to load notations: {ex.Message}"; }
    }

    private void ShowAddModal()
    {
        formModel = new NotationFormModel();
        editingId = null;
        showFormModal = true;
    }

    private void ShowEditModal(CatalogNotationResponse n)
    {
        formModel = new NotationFormModel { Name = n.Name, Description = n.Description, Icon = n.Icon, IsActive = n.IsActive };
        editingId = n.Id;
        showFormModal = true;
    }

    private void CloseModal()
    {
        showFormModal = false;
        editingId = null;
        formModel = new NotationFormModel();
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            if (editingId.HasValue)
            {
                await CatalogApi.UpdateNotationAsync(editingId.Value,
                    new UpdateCatalogNotationRequest(formModel.Name!, formModel.Description, formModel.Icon, formModel.IsActive));
                successMessage = "Notation updated.";
            }
            else
            {
                await CatalogApi.CreateNotationAsync(new CreateCatalogNotationRequest(formModel.Name!, formModel.Description, formModel.Icon));
                successMessage = "Notation created.";
            }
            CloseModal();
            await LoadNotations();
        }
        catch (ApiException ex) { errorMessage = ex.Message; }
        catch (Exception ex) { errorMessage = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private void ConfirmDelete(CatalogNotationResponse n)
    {
        deleteCandidate = n;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        deleteCandidate = null;
    }

    private async Task ExecuteDelete()
    {
        if (deleteCandidate is null) return;
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            var msg = await CatalogApi.DeleteNotationAsync(deleteCandidate.Id);
            successMessage = msg ?? "Notation deleted.";
            CancelDelete();
            await LoadNotations();
        }
        catch (ApiException ex) { errorMessage = ex.Message; }
        catch (Exception ex) { errorMessage = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private static string GetIconClass(string? icon) => icon switch
    {
        "Warning" => "bi-exclamation-triangle-fill",
        "Info" => "bi-info-circle-fill",
        "Note" => "bi-journal-text",
        "Caution" => "bi-exclamation-circle-fill",
        "Danger" => "bi-x-octagon-fill",
        "Prohibited" => "bi-slash-circle",
        "Flammable" => "bi-fire",
        "Chemical" => "bi-droplet-fill",
        "ElectricalHazard" => "bi-lightning-fill",
        "Recyclable" => "bi-recycle",
        "EcoFriendly" => "bi-leaf-fill",
        "FoodAllergen" => "bi-egg-fill",
        "Prop65" => "bi-exclamation-diamond-fill",
        "Compliance" => "bi-shield-check-fill",
        "Temperature" => "bi-thermometer-half",
        _ => ""
    };

    private class NotationFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string? Name { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(50)]
        public string? Icon { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(1000)]
        public string? Description { get; set; }

        public bool IsActive { get; set; } = true;
    }
}
