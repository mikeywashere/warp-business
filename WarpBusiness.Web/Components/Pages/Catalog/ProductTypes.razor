@page "/catalog/product-types"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using WarpBusiness.Web.Services
@inherits WarpBusiness.Web.Components.AuthenticatedComponentBase
@inject CatalogApiClient CatalogApi
@inject NavigationManager Navigation

<PageTitle>Product Types</PageTitle>

<h1 class="mb-4">Product Types</h1>

<AuthorizeView>
    <Authorized Context="authContext">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
            </div>
        }

        @if (isLoading)
        {
            <div class="d-flex justify-content-center my-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            @* Add/Edit Product Type Modal *@
            @if (showFormModal)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">@(editingId.HasValue ? "Edit Product Type" : "Add Product Type")</h5>
                                <button type="button" class="btn-close" @onclick="CloseModal"></button>
                            </div>
                            <div class="modal-body">
                                <EditForm Model="formModel" OnValidSubmit="HandleSubmit" FormName="productTypeForm">
                                    <DataAnnotationsValidator />
                                    <ValidationSummary class="text-danger mb-3" />
                                    <div class="row g-3">
                                        <div class="col-12">
                                            <label class="form-label">Name <span class="text-danger">*</span></label>
                                            <InputText @bind-Value="formModel.Name" class="form-control" />
                                            <ValidationMessage For="() => formModel.Name" class="text-danger" />
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">Description</label>
                                            <InputTextArea @bind-Value="formModel.Description" class="form-control" rows="2" />
                                        </div>
                                        @if (editingId.HasValue)
                                        {
                                            <div class="col-12">
                                                <div class="form-check form-switch">
                                                    <InputCheckbox @bind-Value="formModel.IsActive" class="form-check-input" id="ptActiveSwitch" />
                                                    <label class="form-check-label" for="ptActiveSwitch">
                                                        @(formModel.IsActive ? "Active" : "Inactive")
                                                    </label>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    <div class="mt-3">
                                        <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                                            @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                            @(editingId.HasValue ? "Update Product Type" : "Create Product Type")
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary ms-2" @onclick="CloseModal">Cancel</button>
                                    </div>
                                </EditForm>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* Manage Attributes Modal *@
            @if (showAttributesModal && selectedProductType != null)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Attributes — @selectedProductType.Name</h5>
                                <button type="button" class="btn-close" @onclick="CloseAttributesModal"></button>
                            </div>
                            <div class="modal-body">
                                @if (!string.IsNullOrEmpty(attributesError))
                                {
                                    <div class="alert alert-danger alert-dismissible fade show">
                                        @attributesError
                                        <button type="button" class="btn-close" @onclick="() => attributesError = null"></button>
                                    </div>
                                }

                                @* Assign attribute form *@
                                @{
                                    var assigned = selectedProductType.Attributes.Select(a => a.AttributeTypeId).ToHashSet();
                                    var available = allAttributeTypes?.Where(at => !assigned.Contains(at.Id) && at.IsActive).ToList() ?? [];
                                }
                                @if (available.Count > 0)
                                {
                                    <div class="card mb-3">
                                        <div class="card-header">Assign Attribute</div>
                                        <div class="card-body">
                                            <EditForm Model="assignForm" OnValidSubmit="HandleAssignSubmit" FormName="assignAttrForm">
                                                <div class="row g-2 align-items-end">
                                                    <div class="col-md-5">
                                                        <label class="form-label">Attribute Type <span class="text-danger">*</span></label>
                                                        <InputSelect @bind-Value="assignForm.AttributeTypeId" class="form-select">
                                                            <option value="">— Select —</option>
                                                            @foreach (var at in available.OrderBy(a => a.Name))
                                                            {
                                                                <option value="@at.Id">@at.Name (@at.ValueType)</option>
                                                            }
                                                        </InputSelect>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <label class="form-label">Sort Order</label>
                                                        <InputNumber @bind-Value="assignForm.SortOrder" class="form-control" />
                                                    </div>
                                                    <div class="col-md-2 d-flex align-items-end">
                                                        <div class="form-check mb-1">
                                                            <InputCheckbox @bind-Value="assignForm.IsRequired" class="form-check-input" id="assignReqCheck" />
                                                            <label class="form-check-label" for="assignReqCheck">Required</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-2 d-flex align-items-end">
                                                        <button type="submit" class="btn btn-sm btn-primary" disabled="@isSubmitting">
                                                            @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                                            Assign
                                                        </button>
                                                    </div>
                                                </div>
                                            </EditForm>
                                        </div>
                                    </div>
                                }

                                @* Assigned attributes table *@
                                <div class="table-responsive">
                                    <table class="table table-sm table-striped">
                                        <thead class="table-dark">
                                            <tr>
                                                <th>Attribute</th>
                                                <th>Value Type</th>
                                                <th>Required</th>
                                                <th>Sort</th>
                                                <th style="width: 250px;">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (selectedProductType.Attributes is { Count: > 0 })
                                            {
                                                @foreach (var a in selectedProductType.Attributes.OrderBy(a => a.SortOrder))
                                                {
                                                    <tr>
                                                        <td>@a.AttributeTypeName</td>
                                                        <td><span class="badge bg-secondary">@a.ValueType</span></td>
                                                        <td>
                                                            @if (a.IsRequired) { <span class="badge bg-warning text-dark">Required</span> }
                                                            else { <span class="text-muted">—</span> }
                                                        </td>
                                                        <td>@a.SortOrder</td>
                                                        <td>
                                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveAttribute(a.AttributeTypeId)">Remove</button>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr><td colspan="5" class="text-center text-muted py-3">No attributes assigned yet.</td></tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* Delete Confirmation Modal *@
            @if (showDeleteConfirm && deleteCandidate != null)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Confirm Delete</h5>
                                <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                            </div>
                            <div class="modal-body">
                                <p>Delete product type <strong>@deleteCandidate.Name</strong>?</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                                <button type="button" class="btn btn-danger" @onclick="ExecuteDelete" disabled="@isSubmitting">
                                    @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                    Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Product Types (@(productTypes?.Count ?? 0))</h5>
                <button class="btn btn-primary" @onclick="ShowAddModal">
                    <span class="bi bi-plus-lg me-1"></span> Add Product Type
                </button>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Attributes</th>
                            <th>Status</th>
                            <th style="width: 250px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (productTypes is { Count: > 0 })
                        {
                            @foreach (var pt in productTypes.OrderBy(p => p.Name))
                            {
                                <tr>
                                    <td>@pt.Name</td>
                                    <td class="text-truncate" style="max-width:250px;">@(pt.Description ?? "—")</td>
                                    <td><span class="badge bg-info text-dark">@pt.Attributes.Count</span></td>
                                    <td>
                                        <span class="badge @(pt.IsActive ? "bg-success" : "bg-secondary")">
                                            @(pt.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ShowEditModal(pt)">Edit</button>
                                        <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => OpenAttributesModal(pt)">Attributes</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(pt)">Delete</button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">No product types defined yet.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-warning"><h4>Access Denied</h4><p>You must be logged in. <a href="/login">Login</a></p></div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<CatalogProductTypeResponse>? productTypes;
    private List<CatalogAttributeTypeResponse>? allAttributeTypes;
    private CatalogProductTypeResponse? selectedProductType;

    private bool isLoading = true;
    private bool isSubmitting;
    private bool showFormModal;
    private bool showAttributesModal;
    private bool showDeleteConfirm;

    private Guid? editingId;
    private CatalogProductTypeResponse? deleteCandidate;

    private string? errorMessage;
    private string? successMessage;
    private string? attributesError;

    private ProductTypeFormModel formModel = new();
    private AssignAttributeFormModel assignForm = new();

    protected override async Task OnAuthenticatedInitializedAsync()
    {
        if (string.IsNullOrEmpty(TokenProvider.SelectedTenantId))
        {
            Navigation.NavigateTo("/select-tenant");
            return;
        }
        await Task.WhenAll(LoadProductTypes(), LoadAllAttributeTypes());
        isLoading = false;
    }

    private async Task LoadProductTypes()
    {
        try { productTypes = await CatalogApi.GetProductTypesAsync(); }
        catch (Exception ex) { errorMessage = $"Failed to load product types: {ex.Message}"; }
    }

    private async Task LoadAllAttributeTypes()
    {
        try { allAttributeTypes = await CatalogApi.GetAttributeTypesAsync(); }
        catch { /* non-critical */ }
    }

    private void ShowAddModal()
    {
        formModel = new ProductTypeFormModel();
        editingId = null;
        showFormModal = true;
    }

    private void ShowEditModal(CatalogProductTypeResponse pt)
    {
        formModel = new ProductTypeFormModel
        {
            Name = pt.Name,
            Description = pt.Description,
            IsActive = pt.IsActive
        };
        editingId = pt.Id;
        showFormModal = true;
    }

    private void CloseModal()
    {
        showFormModal = false;
        editingId = null;
        formModel = new ProductTypeFormModel();
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            if (editingId.HasValue)
            {
                await CatalogApi.UpdateProductTypeAsync(editingId.Value,
                    new UpdateCatalogProductTypeRequest(formModel.Name!, formModel.Description, formModel.IsActive));
                successMessage = "Product type updated.";
            }
            else
            {
                await CatalogApi.CreateProductTypeAsync(new CreateCatalogProductTypeRequest(formModel.Name!, formModel.Description));
                successMessage = "Product type created.";
            }
            CloseModal();
            await LoadProductTypes();
        }
        catch (ApiException ex) { errorMessage = ex.Message; }
        catch (Exception ex) { errorMessage = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private void ConfirmDelete(CatalogProductTypeResponse pt)
    {
        deleteCandidate = pt;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        deleteCandidate = null;
    }

    private async Task ExecuteDelete()
    {
        if (deleteCandidate is null) return;
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            var msg = await CatalogApi.DeleteProductTypeAsync(deleteCandidate.Id);
            successMessage = msg ?? "Product type deleted.";
            CancelDelete();
            await LoadProductTypes();
        }
        catch (ApiException ex) { errorMessage = ex.Message; }
        catch (Exception ex) { errorMessage = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    // ── Attributes modal ──────────────────────────────────────────────────────

    private void OpenAttributesModal(CatalogProductTypeResponse pt)
    {
        selectedProductType = pt;
        assignForm = new AssignAttributeFormModel();
        attributesError = null;
        showAttributesModal = true;
    }

    private void CloseAttributesModal()
    {
        showAttributesModal = false;
        selectedProductType = null;
        attributesError = null;
        assignForm = new AssignAttributeFormModel();
    }

    private async Task HandleAssignSubmit()
    {
        if (selectedProductType is null || !Guid.TryParse(assignForm.AttributeTypeId, out var atId)) return;
        isSubmitting = true;
        attributesError = null;
        try
        {
            await CatalogApi.AssignProductTypeAttributeAsync(selectedProductType.Id,
                new AssignCatalogProductTypeAttributeRequest(atId, assignForm.IsRequired, assignForm.SortOrder));
            assignForm = new AssignAttributeFormModel();
            await RefreshSelectedProductType();
        }
        catch (ApiException ex) { attributesError = ex.Message; }
        catch (Exception ex) { attributesError = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private async Task RemoveAttribute(Guid attributeTypeId)
    {
        if (selectedProductType is null) return;
        isSubmitting = true;
        attributesError = null;
        try
        {
            await CatalogApi.RemoveProductTypeAttributeAsync(selectedProductType.Id, attributeTypeId);
            await RefreshSelectedProductType();
        }
        catch (ApiException ex) { attributesError = ex.Message; }
        catch (Exception ex) { attributesError = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private async Task RefreshSelectedProductType()
    {
        await LoadProductTypes();
        if (selectedProductType != null && productTypes != null)
        {
            selectedProductType = productTypes.FirstOrDefault(pt => pt.Id == selectedProductType.Id) ?? selectedProductType;
        }
    }

    // ── Form models ───────────────────────────────────────────────────────────

    private class ProductTypeFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string? Name { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(1000)]
        public string? Description { get; set; }

        public bool IsActive { get; set; } = true;
    }

    private class AssignAttributeFormModel
    {
        public string? AttributeTypeId { get; set; }
        public bool IsRequired { get; set; }
        public int SortOrder { get; set; }
    }
}
