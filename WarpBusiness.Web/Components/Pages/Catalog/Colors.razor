@page "/catalog/colors"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using WarpBusiness.Web.Services
@inherits WarpBusiness.Web.Components.AuthenticatedComponentBase
@inject CatalogApiClient CatalogApi
@inject NavigationManager Navigation

<PageTitle>Catalog Colors</PageTitle>

<h1 class="mb-4">Catalog Colors</h1>

<AuthorizeView>
    <Authorized Context="authContext">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
            </div>
        }

        @if (isLoading)
        {
            <div class="d-flex justify-content-center my-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            @if (showFormModal)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">@(editingId.HasValue ? "Edit Color" : "Add Color")</h5>
                                <button type="button" class="btn-close" @onclick="CloseModal"></button>
                            </div>
                            <div class="modal-body">
                                <EditForm Model="formModel" OnValidSubmit="HandleSubmit" FormName="colorForm">
                                    <DataAnnotationsValidator />
                                    <ValidationSummary class="text-danger mb-3" />
                                    <div class="row g-3">
                                        <div class="col-md-8">
                                            <label class="form-label">Name <span class="text-danger">*</span></label>
                                            <InputText @bind-Value="formModel.Name" class="form-control" />
                                            <ValidationMessage For="() => formModel.Name" class="text-danger" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label">Hex Code</label>
                                            <div class="input-group">
                                                <InputText @bind-Value="formModel.HexCode" class="form-control" placeholder="#RRGGBB" maxlength="7" />
                                                @if (!string.IsNullOrEmpty(formModel.HexCode))
                                                {
                                                    <span class="input-group-text" style="background:@formModel.HexCode;width:40px;border:1px solid #555;">&nbsp;</span>
                                                }
                                            </div>
                                        </div>
                                        @if (editingId.HasValue)
                                        {
                                            <div class="col-12">
                                                <div class="form-check form-switch">
                                                    <InputCheckbox @bind-Value="formModel.IsActive" class="form-check-input" id="colorActiveSwitch" />
                                                    <label class="form-check-label" for="colorActiveSwitch">
                                                        @(formModel.IsActive ? "Active" : "Inactive")
                                                    </label>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    <div class="mt-3">
                                        <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                                            @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                            @(editingId.HasValue ? "Update Color" : "Create Color")
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary ms-2" @onclick="CloseModal">Cancel</button>
                                    </div>
                                </EditForm>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Colors (@(colors?.Count ?? 0))</h5>
                <button class="btn btn-primary" @onclick="ShowAddModal">
                    <span class="bi bi-plus-lg me-1"></span> Add Color
                </button>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Swatch</th>
                            <th>Name</th>
                            <th>Hex Code</th>
                            <th>Status</th>
                            <th style="width: 250px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (colors is { Count: > 0 })
                        {
                            @foreach (var color in colors)
                            {
                                <tr>
                                    <td>
                                        @if (!string.IsNullOrEmpty(color.HexCode))
                                        {
                                            <span style="display:inline-block;width:24px;height:24px;background:@color.HexCode;border:1px solid #555;border-radius:4px;"></span>
                                        }
                                        else { <span class="text-muted">—</span> }
                                    </td>
                                    <td>@color.Name</td>
                                    <td><code>@(color.HexCode ?? "—")</code></td>
                                    <td>
                                        <span class="badge @(color.IsActive ? "bg-success" : "bg-secondary")">
                                            @(color.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ShowEditModal(color)">Edit</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteColor(color)">Delete</button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">No colors defined yet.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-warning"><h4>Access Denied</h4><p>You must be logged in. <a href="/login">Login</a></p></div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<CatalogColorResponse>? colors;
    private bool isLoading = true;
    private bool isSubmitting;
    private bool showFormModal;
    private Guid? editingId;
    private string? errorMessage;
    private string? successMessage;
    private ColorFormModel formModel = new();

    protected override async Task OnAuthenticatedInitializedAsync()
    {
        if (string.IsNullOrEmpty(TokenProvider.SelectedTenantId))
        {
            Navigation.NavigateTo("/select-tenant");
            return;
        }
        await LoadColors();
        isLoading = false;
    }

    private async Task LoadColors()
    {
        try { colors = await CatalogApi.GetColorsAsync(); }
        catch (Exception ex) { errorMessage = $"Failed to load colors: {ex.Message}"; }
    }

    private void ShowAddModal()
    {
        formModel = new ColorFormModel();
        editingId = null;
        showFormModal = true;
    }

    private void ShowEditModal(CatalogColorResponse color)
    {
        formModel = new ColorFormModel { Name = color.Name, HexCode = color.HexCode, IsActive = color.IsActive };
        editingId = color.Id;
        showFormModal = true;
    }

    private void CloseModal()
    {
        showFormModal = false;
        editingId = null;
        formModel = new ColorFormModel();
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            if (editingId.HasValue)
            {
                await CatalogApi.UpdateColorAsync(editingId.Value,
                    new UpdateCatalogColorRequest(formModel.Name!, formModel.HexCode, formModel.IsActive));
                successMessage = "Color updated.";
            }
            else
            {
                await CatalogApi.CreateColorAsync(new CreateCatalogColorRequest(formModel.Name!, formModel.HexCode));
                successMessage = "Color created.";
            }
            CloseModal();
            await LoadColors();
        }
        catch (ApiException ex) { errorMessage = ex.Message; }
        catch (Exception ex) { errorMessage = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private async Task DeleteColor(CatalogColorResponse color)
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            var msg = await CatalogApi.DeleteColorAsync(color.Id);
            successMessage = msg ?? "Color deleted.";
            await LoadColors();
        }
        catch (ApiException ex) { errorMessage = ex.Message; }
        catch (Exception ex) { errorMessage = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private class ColorFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(100)]
        public string? Name { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(7)]
        public string? HexCode { get; set; }

        public bool IsActive { get; set; } = true;
    }
}
