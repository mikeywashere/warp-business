@page "/catalog/attribute-types"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using WarpBusiness.Web.Services
@inherits WarpBusiness.Web.Components.AuthenticatedComponentBase
@inject CatalogApiClient CatalogApi
@inject NavigationManager Navigation

<PageTitle>Attribute Types</PageTitle>

<h1 class="mb-4">Attribute Types</h1>

<AuthorizeView>
    <Authorized Context="authContext">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
            </div>
        }

        @if (isLoading)
        {
            <div class="d-flex justify-content-center my-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            @* Add/Edit Attribute Type Modal *@
            @if (showFormModal)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">@(editingId.HasValue ? "Edit Attribute Type" : "Add Attribute Type")</h5>
                                <button type="button" class="btn-close" @onclick="CloseModal"></button>
                            </div>
                            <div class="modal-body">
                                <EditForm Model="formModel" OnValidSubmit="HandleSubmit" FormName="attrTypeForm">
                                    <DataAnnotationsValidator />
                                    <ValidationSummary class="text-danger mb-3" />
                                    <div class="row g-3">
                                        <div class="col-md-8">
                                            <label class="form-label">Name <span class="text-danger">*</span></label>
                                            <InputText @bind-Value="formModel.Name" class="form-control" />
                                            <ValidationMessage For="() => formModel.Name" class="text-danger" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label">Sort Order</label>
                                            <InputNumber @bind-Value="formModel.SortOrder" class="form-control" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Value Type <span class="text-danger">*</span></label>
                                            <InputSelect @bind-Value="formModel.ValueType" class="form-select" disabled="@editingId.HasValue">
                                                <option value="Select">Select (dropdown with options)</option>
                                                <option value="FreeText">Free Text</option>
                                                <option value="Number">Number</option>
                                            </InputSelect>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Unit <small class="text-muted">(e.g. kg, cm)</small></label>
                                            <InputText @bind-Value="formModel.Unit" class="form-control" />
                                        </div>
                                        @if (formModel.ValueType == "Select")
                                        {
                                            <div class="col-12">
                                                <div class="form-check">
                                                    <InputCheckbox @bind-Value="formModel.HasColorPicker" class="form-check-input" id="hasColorPickerSwitch" />
                                                    <label class="form-check-label" for="hasColorPickerSwitch">Has Color Picker (options have hex color codes)</label>
                                                </div>
                                            </div>
                                        }
                                        @if (editingId.HasValue)
                                        {
                                            <div class="col-12">
                                                <div class="form-check form-switch">
                                                    <InputCheckbox @bind-Value="formModel.IsActive" class="form-check-input" id="attrActiveSwitch" />
                                                    <label class="form-check-label" for="attrActiveSwitch">
                                                        @(formModel.IsActive ? "Active" : "Inactive")
                                                    </label>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    <div class="mt-3">
                                        <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                                            @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                            @(editingId.HasValue ? "Update Attribute Type" : "Create Attribute Type")
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary ms-2" @onclick="CloseModal">Cancel</button>
                                    </div>
                                </EditForm>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* Manage Options Modal *@
            @if (showOptionsModal && selectedAttrType != null)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Options — @selectedAttrType.Name</h5>
                                <button type="button" class="btn-close" @onclick="CloseOptionsModal"></button>
                            </div>
                            <div class="modal-body">
                                @if (!string.IsNullOrEmpty(optionsError))
                                {
                                    <div class="alert alert-danger alert-dismissible fade show">
                                        @optionsError
                                        <button type="button" class="btn-close" @onclick="() => optionsError = null"></button>
                                    </div>
                                }

                                @* Add/Edit Option Form *@
                                <div class="card mb-3">
                                    <div class="card-header">@(editingOptionId.HasValue ? "Edit Option" : "Add Option")</div>
                                    <div class="card-body">
                                        <EditForm Model="optionForm" OnValidSubmit="HandleOptionSubmit" FormName="optionForm">
                                            <DataAnnotationsValidator />
                                            <ValidationSummary class="text-danger mb-3" />
                                            <div class="row g-2">
                                                <div class="col-md-5">
                                                    <label class="form-label">Value <span class="text-danger">*</span></label>
                                                    <InputText @bind-Value="optionForm.Value" class="form-control" />
                                                    <ValidationMessage For="() => optionForm.Value" class="text-danger" />
                                                </div>
                                                @if (selectedAttrType.HasColorPicker)
                                                {
                                                    <div class="col-md-4">
                                                        <label class="form-label">Hex Code</label>
                                                        <div class="input-group">
                                                            <InputText @bind-Value="optionForm.HexCode" class="form-control" placeholder="#RRGGBB" maxlength="7" />
                                                            @if (!string.IsNullOrEmpty(optionForm.HexCode))
                                                            {
                                                                <span class="input-group-text" style="background:@optionForm.HexCode;width:40px;border:1px solid #555;">&nbsp;</span>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                                <div class="col-md-3">
                                                    <label class="form-label">Sort Order</label>
                                                    <InputNumber @bind-Value="optionForm.SortOrder" class="form-control" />
                                                </div>
                                                @if (editingOptionId.HasValue)
                                                {
                                                    <div class="col-md-3 d-flex align-items-end">
                                                        <div class="form-check form-switch mb-1">
                                                            <InputCheckbox @bind-Value="optionForm.IsActive" class="form-check-input" id="optActiveSwitch" />
                                                            <label class="form-check-label" for="optActiveSwitch">Active</label>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                            <div class="mt-2">
                                                <button type="submit" class="btn btn-sm btn-primary" disabled="@isSubmitting">
                                                    @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                                    @(editingOptionId.HasValue ? "Update" : "Add Option")
                                                </button>
                                                @if (editingOptionId.HasValue)
                                                {
                                                    <button type="button" class="btn btn-sm mt-2 btn-outline-secondary ms-2" @onclick="CancelOptionEdit">Cancel Edit</button>
                                                }
                                            </div>
                                        </EditForm>
                                    </div>
                                </div>

                                @* Options Table *@
                                <div class="table-responsive">
                                    <table class="table table-sm table-striped">
                                        <thead class="table-dark">
                                            <tr>
                                                @if (selectedAttrType.HasColorPicker)
                                                {
                                                    <th style="width:50px;">Color</th>
                                                }
                                                <th>Value</th>
                                                <th>Sort</th>
                                                <th>Status</th>
                                                <th style="width: 250px;">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (selectedOptions is { Count: > 0 })
                                            {
                                                @foreach (var opt in selectedOptions.OrderBy(o => o.SortOrder).ThenBy(o => o.Value))
                                                {
                                                    <tr>
                                                        @if (selectedAttrType.HasColorPicker)
                                                        {
                                                            <td>
                                                                @if (!string.IsNullOrEmpty(opt.HexCode))
                                                                {
                                                                    <span style="display:inline-block;width:24px;height:24px;background:@opt.HexCode;border:1px solid #555;border-radius:4px;"></span>
                                                                }
                                                                else { <span class="text-muted">—</span> }
                                                            </td>
                                                        }
                                                        <td>@opt.Value</td>
                                                        <td>@opt.SortOrder</td>
                                                        <td>
                                                            <span class="badge @(opt.IsActive ? "bg-success" : "bg-secondary")">
                                                                @(opt.IsActive ? "Active" : "Inactive")
                                                            </span>
                                                        </td>
                                                        <td>
                                                            <button class="btn btn-sm mt-2 btn-outline-primary me-1" @onclick="() => EditOption(opt)">Edit</button>
                                                            <button class="btn btn-sm mt-2 btn-outline-danger" @onclick="() => DeleteOption(opt)">Delete</button>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr><td colspan="5" class="text-center text-muted py-3">No options yet. Add one above.</td></tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* Delete Confirmation Modal *@
            @if (showDeleteConfirm && deleteCandidate != null)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Confirm Delete</h5>
                                <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                            </div>
                            <div class="modal-body">
                                <p>Delete attribute type <strong>@deleteCandidate.Name</strong>?</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                                <button type="button" class="btn btn-danger" @onclick="ExecuteDelete" disabled="@isSubmitting">
                                    @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                    Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Attribute Types (@(attributeTypes?.Count ?? 0))</h5>
                <button class="btn btn-primary" @onclick="ShowAddModal">
                    <span class="bi bi-plus-lg me-1"></span> Add Attribute Type
                </button>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Value Type</th>
                            <th>Unit</th>
                            <th>Color Picker</th>
                            <th>Sort</th>
                            <th>Options</th>
                            <th>Status</th>
                            <th style="width: 250px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (attributeTypes is { Count: > 0 })
                        {
                            @foreach (var at in attributeTypes.OrderBy(a => a.SortOrder).ThenBy(a => a.Name))
                            {
                                <tr>
                                    <td>@at.Name</td>
                                    <td><span class="badge bg-secondary">@at.ValueType</span></td>
                                    <td>@(at.Unit ?? "—")</td>
                                    <td>
                                        @if (at.HasColorPicker) { <span class="badge bg-info text-dark">Yes</span> }
                                        else { <span class="text-muted">—</span> }
                                    </td>
                                    <td>@at.SortOrder</td>
                                    <td>
                                        <span class="badge bg-info text-dark">@at.Options.Count</span>
                                    </td>
                                    <td>
                                        <span class="badge @(at.IsActive ? "bg-success" : "bg-secondary")">
                                            @(at.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm mt-2 btn-outline-primary me-1" @onclick="() => ShowEditModal(at)">Edit</button>
                                        @if (at.ValueType == "Select")
                                        {
                                            <button class="btn btn-sm mt-2 btn-outline-secondary me-1" @onclick="() => OpenOptionsModal(at)">Options</button>
                                        }
                                        <button class="btn btn-sm mt-2 btn-outline-danger" @onclick="() => ConfirmDelete(at)">Delete</button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="8" class="text-center text-muted py-4">No attribute types defined yet.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-warning"><h4>Access Denied</h4><p>You must be logged in. <a href="/login">Login</a></p></div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<CatalogAttributeTypeResponse>? attributeTypes;
    private List<CatalogAttributeOptionResponse>? selectedOptions;
    private CatalogAttributeTypeResponse? selectedAttrType;

    private bool isLoading = true;
    private bool isSubmitting;
    private bool showFormModal;
    private bool showOptionsModal;
    private bool showDeleteConfirm;

    private Guid? editingId;
    private Guid? editingOptionId;
    private CatalogAttributeTypeResponse? deleteCandidate;

    private string? errorMessage;
    private string? successMessage;
    private string? optionsError;

    private AttrTypeFormModel formModel = new();
    private OptionFormModel optionForm = new();

    protected override async Task OnAuthenticatedInitializedAsync()
    {
        if (string.IsNullOrEmpty(TokenProvider.SelectedTenantId))
        {
            Navigation.NavigateTo("/select-tenant");
            return;
        }
        await LoadAttributeTypes();
        isLoading = false;
    }

    private async Task LoadAttributeTypes()
    {
        try { attributeTypes = await CatalogApi.GetAttributeTypesAsync(); }
        catch (Exception ex) { errorMessage = $"Failed to load attribute types: {ex.Message}"; }
    }

    private void ShowAddModal()
    {
        formModel = new AttrTypeFormModel();
        editingId = null;
        showFormModal = true;
    }

    private void ShowEditModal(CatalogAttributeTypeResponse at)
    {
        formModel = new AttrTypeFormModel
        {
            Name = at.Name,
            ValueType = at.ValueType,
            Unit = at.Unit,
            HasColorPicker = at.HasColorPicker,
            SortOrder = at.SortOrder,
            IsActive = at.IsActive
        };
        editingId = at.Id;
        showFormModal = true;
    }

    private void CloseModal()
    {
        showFormModal = false;
        editingId = null;
        formModel = new AttrTypeFormModel();
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            if (editingId.HasValue)
            {
                await CatalogApi.UpdateAttributeTypeAsync(editingId.Value,
                    new UpdateCatalogAttributeTypeRequest(formModel.Name!, formModel.Unit, formModel.HasColorPicker, formModel.SortOrder, formModel.IsActive));
                successMessage = "Attribute type updated.";
            }
            else
            {
                await CatalogApi.CreateAttributeTypeAsync(
                    new CreateCatalogAttributeTypeRequest(formModel.Name!, formModel.ValueType, formModel.Unit, formModel.HasColorPicker, formModel.SortOrder));
                successMessage = "Attribute type created.";
            }
            CloseModal();
            await LoadAttributeTypes();
        }
        catch (ApiException ex) { errorMessage = ex.Message; }
        catch (Exception ex) { errorMessage = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private void ConfirmDelete(CatalogAttributeTypeResponse at)
    {
        deleteCandidate = at;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        deleteCandidate = null;
    }

    private async Task ExecuteDelete()
    {
        if (deleteCandidate is null) return;
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            var msg = await CatalogApi.DeleteAttributeTypeAsync(deleteCandidate.Id);
            successMessage = msg ?? "Attribute type deleted.";
            CancelDelete();
            await LoadAttributeTypes();
        }
        catch (ApiException ex) { errorMessage = ex.Message; }
        catch (Exception ex) { errorMessage = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    // ── Options modal ─────────────────────────────────────────────────────────

    private async Task OpenOptionsModal(CatalogAttributeTypeResponse at)
    {
        selectedAttrType = at;
        editingOptionId = null;
        optionForm = new OptionFormModel();
        optionsError = null;
        showOptionsModal = true;
        await RefreshOptions();
    }

    private void CloseOptionsModal()
    {
        showOptionsModal = false;
        selectedAttrType = null;
        selectedOptions = null;
        editingOptionId = null;
        optionForm = new OptionFormModel();
    }

    private async Task RefreshOptions()
    {
        if (selectedAttrType is null) return;
        try
        {
            selectedOptions = await CatalogApi.GetAttributeOptionsAsync(selectedAttrType.Id);
            // sync back into the in-memory list so Options count badge updates
            if (attributeTypes != null)
            {
                var idx = attributeTypes.FindIndex(a => a.Id == selectedAttrType.Id);
                if (idx >= 0)
                {
                    var updated = attributeTypes[idx] with { Options = selectedOptions };
                    attributeTypes[idx] = updated;
                    selectedAttrType = updated;
                }
            }
        }
        catch (Exception ex) { optionsError = $"Failed to load options: {ex.Message}"; }
    }

    private void EditOption(CatalogAttributeOptionResponse opt)
    {
        editingOptionId = opt.Id;
        optionForm = new OptionFormModel
        {
            Value = opt.Value,
            HexCode = opt.HexCode,
            SortOrder = opt.SortOrder,
            IsActive = opt.IsActive
        };
    }

    private void CancelOptionEdit()
    {
        editingOptionId = null;
        optionForm = new OptionFormModel();
    }

    private async Task HandleOptionSubmit()
    {
        if (selectedAttrType is null) return;
        isSubmitting = true;
        optionsError = null;
        try
        {
            if (editingOptionId.HasValue)
            {
                await CatalogApi.UpdateAttributeOptionAsync(selectedAttrType.Id, editingOptionId.Value,
                    new UpdateCatalogAttributeOptionRequest(optionForm.Value!, optionForm.HexCode, optionForm.SortOrder, optionForm.IsActive));
            }
            else
            {
                await CatalogApi.CreateAttributeOptionAsync(selectedAttrType.Id,
                    new CreateCatalogAttributeOptionRequest(optionForm.Value!, optionForm.HexCode, optionForm.SortOrder));
            }
            CancelOptionEdit();
            await RefreshOptions();
        }
        catch (ApiException ex) { optionsError = ex.Message; }
        catch (Exception ex) { optionsError = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private async Task DeleteOption(CatalogAttributeOptionResponse opt)
    {
        if (selectedAttrType is null) return;
        isSubmitting = true;
        optionsError = null;
        try
        {
            await CatalogApi.DeleteAttributeOptionAsync(selectedAttrType.Id, opt.Id);
            await RefreshOptions();
        }
        catch (ApiException ex) { optionsError = ex.Message; }
        catch (Exception ex) { optionsError = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    // ── Form models ───────────────────────────────────────────────────────────

    private class AttrTypeFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string? Name { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        public string ValueType { get; set; } = "Select";

        [System.ComponentModel.DataAnnotations.MaxLength(50)]
        public string? Unit { get; set; }

        public bool HasColorPicker { get; set; }
        public int SortOrder { get; set; }
        public bool IsActive { get; set; } = true;
    }

    private class OptionFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string? Value { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(7)]
        public string? HexCode { get; set; }

        public int SortOrder { get; set; }
        public bool IsActive { get; set; } = true;
    }
}
