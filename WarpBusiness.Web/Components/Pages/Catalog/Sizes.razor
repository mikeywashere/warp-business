@page "/catalog/sizes"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using WarpBusiness.Web.Services
@inherits WarpBusiness.Web.Components.AuthenticatedComponentBase
@inject CatalogApiClient CatalogApi
@inject NavigationManager Navigation

<PageTitle>Catalog Sizes</PageTitle>

<h1 class="mb-4">Catalog Sizes</h1>

<AuthorizeView>
    <Authorized Context="authContext">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
            </div>
        }

        @if (isLoading)
        {
            <div class="d-flex justify-content-center my-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            @if (showFormModal)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">@(editingId.HasValue ? "Edit Size" : "Add Size")</h5>
                                <button type="button" class="btn-close" @onclick="CloseModal"></button>
                            </div>
                            <div class="modal-body">
                                <EditForm Model="formModel" OnValidSubmit="HandleSubmit" FormName="sizeForm">
                                    <DataAnnotationsValidator />
                                    <ValidationSummary class="text-danger mb-3" />
                                    <div class="row g-3">
                                        <div class="col-md-4">
                                            <label class="form-label">Name <span class="text-danger">*</span></label>
                                            <InputText @bind-Value="formModel.Name" class="form-control" placeholder="e.g. M, 42, Large" />
                                            <ValidationMessage For="() => formModel.Name" class="text-danger" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label">Size Type</label>
                                            <InputText @bind-Value="formModel.SizeType" class="form-control" placeholder="Clothing, Shoes, General..." />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label">Sort Order</label>
                                            <InputNumber @bind-Value="formModel.SortOrder" class="form-control" />
                                        </div>
                                        @if (editingId.HasValue)
                                        {
                                            <div class="col-12">
                                                <div class="form-check form-switch">
                                                    <InputCheckbox @bind-Value="formModel.IsActive" class="form-check-input" id="sizeActiveSwitch" />
                                                    <label class="form-check-label" for="sizeActiveSwitch">
                                                        @(formModel.IsActive ? "Active" : "Inactive")
                                                    </label>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    <div class="mt-3">
                                        <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                                            @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                            @(editingId.HasValue ? "Update Size" : "Create Size")
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary ms-2" @onclick="CloseModal">Cancel</button>
                                    </div>
                                </EditForm>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Sizes (@(sizes?.Count ?? 0))</h5>
                <button class="btn btn-primary" @onclick="ShowAddModal">
                    <span class="bi bi-plus-lg me-1"></span> Add Size
                </button>
            </div>

            @foreach (var group in (sizes ?? []).GroupBy(s => s.SizeType).OrderBy(g => g.Key))
            {
                <h6 class="mt-3 text-muted">@group.Key</h6>
                <div class="table-responsive mb-3">
                    <table class="table table-striped table-hover table-sm">
                        <thead class="table-dark">
                            <tr>
                                <th>Name</th>
                                <th>Sort Order</th>
                                <th>Status</th>
                                <th style="width: 250px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var size in group.OrderBy(s => s.SortOrder))
                            {
                                <tr>
                                    <td>@size.Name</td>
                                    <td>@size.SortOrder</td>
                                    <td>
                                        <span class="badge @(size.IsActive ? "bg-success" : "bg-secondary")">
                                            @(size.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ShowEditModal(size)">Edit</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSize(size)">Delete</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (sizes is null || sizes.Count == 0)
            {
                <p class="text-muted text-center py-4">No sizes defined yet.</p>
            }
        }
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-warning"><h4>Access Denied</h4><p>You must be logged in. <a href="/login">Login</a></p></div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<CatalogSizeResponse>? sizes;
    private bool isLoading = true;
    private bool isSubmitting;
    private bool showFormModal;
    private Guid? editingId;
    private string? errorMessage;
    private string? successMessage;
    private SizeFormModel formModel = new();

    protected override async Task OnAuthenticatedInitializedAsync()
    {
        if (string.IsNullOrEmpty(TokenProvider.SelectedTenantId))
        {
            Navigation.NavigateTo("/select-tenant");
            return;
        }
        await LoadSizes();
        isLoading = false;
    }

    private async Task LoadSizes()
    {
        try { sizes = await CatalogApi.GetSizesAsync(); }
        catch (Exception ex) { errorMessage = $"Failed to load sizes: {ex.Message}"; }
    }

    private void ShowAddModal()
    {
        formModel = new SizeFormModel();
        editingId = null;
        showFormModal = true;
    }

    private void ShowEditModal(CatalogSizeResponse size)
    {
        formModel = new SizeFormModel
        {
            Name = size.Name,
            SizeType = size.SizeType,
            SortOrder = size.SortOrder,
            IsActive = size.IsActive
        };
        editingId = size.Id;
        showFormModal = true;
    }

    private void CloseModal()
    {
        showFormModal = false;
        editingId = null;
        formModel = new SizeFormModel();
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            if (editingId.HasValue)
            {
                await CatalogApi.UpdateSizeAsync(editingId.Value,
                    new UpdateCatalogSizeRequest(formModel.Name!, formModel.SizeType, formModel.SortOrder, formModel.IsActive));
                successMessage = "Size updated.";
            }
            else
            {
                await CatalogApi.CreateSizeAsync(new CreateCatalogSizeRequest(formModel.Name!, formModel.SizeType, formModel.SortOrder));
                successMessage = "Size created.";
            }
            CloseModal();
            await LoadSizes();
        }
        catch (ApiException ex) { errorMessage = ex.Message; }
        catch (Exception ex) { errorMessage = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private async Task DeleteSize(CatalogSizeResponse size)
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            var msg = await CatalogApi.DeleteSizeAsync(size.Id);
            successMessage = msg ?? "Size deleted.";
            await LoadSizes();
        }
        catch (ApiException ex) { errorMessage = ex.Message; }
        catch (Exception ex) { errorMessage = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private class SizeFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(50)]
        public string? Name { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(50)]
        public string? SizeType { get; set; } = "General";

        public int SortOrder { get; set; }
        public bool IsActive { get; set; } = true;
    }
}
