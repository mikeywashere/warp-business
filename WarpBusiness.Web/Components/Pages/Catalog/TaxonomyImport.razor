@page "/catalog/taxonomy/import"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using WarpBusiness.Web.Services
@inherits WarpBusiness.Web.Components.AuthenticatedComponentBase
@inject TaxonomyApiClient TaxonomyApi
@inject NavigationManager Navigation

<PageTitle>Taxonomy Browser</PageTitle>

<h1 class="mb-4">Taxonomy Browser</h1>

<AuthorizeView Context="authContext">
    <Authorized>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
            </div>
        }

        @if (isLoading)
        {
            <div class="d-flex justify-content-center my-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            @if (ProviderTabs.Count == 0)
            {
                <div class="alert alert-info">No taxonomy providers are configured.</div>
            }
            else
            {
                <ul class="nav nav-tabs mb-3">
                    @foreach (var provider in ProviderTabs)
                    {
                        <li class="nav-item">
                            <button class="nav-link @(provider.Equals(selectedProvider, StringComparison.OrdinalIgnoreCase) ? "active" : "")"
                                    type="button" @onclick="() => SelectProvider(provider)">
                                @provider
                            </button>
                        </li>
                    }
                </ul>

                <div class="card mb-3">
                    <div class="card-body">
                        <div class="d-flex flex-wrap justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-1">@selectedProvider Taxonomy</h5>
                                <div class="text-muted small">
                                    Last download: @(FormatDate(CurrentStatus?.LastDownloadedAt))
                                    &bull; @(CurrentStatus?.NodeCount ?? 0) nodes
                                </div>
                                <div class="mt-2">
                                    <span class="badge @GetStatusBadgeClass(CurrentStatus)">@GetStatusText(CurrentStatus)</span>
                                </div>
                            </div>
                            <button class="btn btn-outline-info" @onclick="() => DownloadProviderAsync(selectedProvider)"
                                    disabled="@(!IsProviderEnabled(CurrentStatus) || isDownloading)">
                                @if (isDownloading) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                Download Now
                            </button>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Search</label>
                    <input class="form-control" placeholder="Search by name or path" value="@searchText" @oninput="OnSearchInput" />
                </div>

                @if (isLoadingExternal)
                {
                    <div class="d-flex justify-content-center my-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Node</th>
                                    <th>Path</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (VisibleExternalNodes.Any())
                                {
                                    @foreach (var node in VisibleExternalNodes)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center" style="padding-left: @(node.Depth * 20)px;">
                                                    @if (HasExternalChildren(node))
                                                    {
                                                        <button type="button" class="btn btn-sm btn-link p-0 me-2"
                                                                style="color: var(--clr-accent);" @onclick="() => ToggleExternalNode(node)">
                                                            @(IsExpanded(node.Id) ? "▼" : "▶")
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <span class="me-4"></span>
                                                    }
                                                    <span>@node.Name</span>
                                                </div>
                                            </td>
                                            <td class="text-muted small">@node.FullPath</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="2" class="text-center text-muted py-4">No external nodes loaded yet.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        }
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-warning">
            <h4>Access Denied</h4>
            <p>You must be logged in. <a href="/login">Login</a></p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private string selectedProvider = string.Empty;
    private bool isLoading = true;
    private bool isLoadingExternal;
    private bool isDownloading;
    private string? errorMessage;
    private string? successMessage;
    private string? searchText;

    private List<ProviderStatusResponse> providerStatuses = [];
    private Dictionary<string, List<ExternalNodeResponse>> externalTrees = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, Dictionary<Guid, List<ExternalNodeResponse>>> externalChildrenCache = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, HashSet<Guid>> expandedExternalNodes = new(StringComparer.OrdinalIgnoreCase);

    private List<string> ProviderTabs =>
        providerStatuses
            .Select(s => s.Key)
            .Where(p => !string.IsNullOrWhiteSpace(p))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(p => p)
            .ToList();

    private ProviderStatusResponse? CurrentStatus =>
        string.IsNullOrWhiteSpace(selectedProvider)
            ? null
            : providerStatuses.FirstOrDefault(s => s.Key.Equals(selectedProvider, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<ExternalNodeResponse> VisibleExternalNodes
    {
        get
        {
            if (string.IsNullOrWhiteSpace(selectedProvider)) return [];
            if (!externalTrees.TryGetValue(selectedProvider, out var roots)) return [];

            if (!string.IsNullOrWhiteSpace(searchText))
                return FilteredExternalNodes();

            var result = new List<ExternalNodeResponse>();
            foreach (var root in roots.OrderBy(n => n.Name))
            {
                result.Add(root);
                AppendExpandedChildren(root.Id, result);
            }
            return result;
        }
    }

    protected override Task OnAuthenticatedInitializedAsync()
    {
        // Tenant check only — no API calls during SSR prerender
        if (string.IsNullOrEmpty(TokenProvider.SelectedTenantId))
            Navigation.NavigateTo("/select-tenant");
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (string.IsNullOrEmpty(TokenProvider.SelectedTenantId)) return;

        await LoadProviderStatusAsync();
        EnsureSelectedProvider();
        if (!string.IsNullOrWhiteSpace(selectedProvider))
            await LoadExternalNodesAsync(selectedProvider, forceReload: true);
        isLoading = false;
        StateHasChanged();
    }

    private async Task LoadProviderStatusAsync()
    {
        try
        {
            providerStatuses = await TaxonomyApi.GetProviderStatusAsync();
            EnsureSelectedProvider();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load provider status: {ex.Message}";
        }
    }

    private void EnsureSelectedProvider()
    {
        if (ProviderTabs.Count == 0)
        {
            selectedProvider = string.Empty;
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedProvider)
            || !ProviderTabs.Contains(selectedProvider, StringComparer.OrdinalIgnoreCase))
        {
            selectedProvider = ProviderTabs[0];
        }
    }

    private async Task LoadExternalNodesAsync(string provider, bool forceReload)
    {
        if (!forceReload && externalTrees.ContainsKey(provider)) return;

        isLoadingExternal = true;
        try
        {
            var result = await TaxonomyApi.GetExternalNodesAsync(provider);
            externalTrees[provider] = result.Nodes;
            externalChildrenCache.Remove(provider);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load external taxonomy: {ex.Message}";
        }
        finally
        {
            isLoadingExternal = false;
        }
    }

    private async Task SelectProvider(string provider)
    {
        if (provider.Equals(selectedProvider, StringComparison.OrdinalIgnoreCase)) return;

        selectedProvider = provider;
        await LoadExternalNodesAsync(provider, forceReload: false);
    }

    private async Task DownloadProviderAsync(string provider)
    {
        isDownloading = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            await TaxonomyApi.TriggerDownloadAsync(provider);
            successMessage = $"{provider} download started.";
            await LoadProviderStatusAsync();
            await LoadExternalNodesAsync(provider, forceReload: true);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            isDownloading = false;
        }
    }

    private string FormatDate(DateTimeOffset? date) =>
        date.HasValue ? date.Value.ToLocalTime().ToString("g") : "Never";

    private bool IsProviderEnabled(ProviderStatusResponse? status) =>
        status is null || status.IsActive;

    private string GetStatusText(ProviderStatusResponse? status)
    {
        if (status is null) return "Unknown";
        if (!status.IsActive) return "Inactive";
        return status.LastDownloadedAt.HasValue ? "Downloaded" : "Never downloaded";
    }

    private string GetStatusBadgeClass(ProviderStatusResponse? status)
    {
        if (status is null || !status.IsActive) return "badge bg-secondary";
        return status.LastDownloadedAt.HasValue ? "badge bg-success" : "badge bg-warning text-dark";
    }

    private IEnumerable<ExternalNodeResponse> FilteredExternalNodes()
    {
        var allNodes = GetAllCachedNodes();
        if (string.IsNullOrWhiteSpace(searchText)) return allNodes;
        var term = searchText.Trim();
        return allNodes.Where(n =>
            n.Name.Contains(term, StringComparison.OrdinalIgnoreCase)
            || n.FullPath.Contains(term, StringComparison.OrdinalIgnoreCase));
    }

    private IEnumerable<ExternalNodeResponse> GetAllCachedNodes()
    {
        if (!externalTrees.TryGetValue(selectedProvider, out var roots)) return [];
        var all = new List<ExternalNodeResponse>(roots);
        if (externalChildrenCache.TryGetValue(selectedProvider, out var byProvider))
            foreach (var children in byProvider.Values)
                all.AddRange(children);
        return all;
    }

    private bool HasExternalChildren(ExternalNodeResponse node) => !node.IsLeaf;

    private bool IsExpanded(Guid nodeId) =>
        expandedExternalNodes.TryGetValue(selectedProvider, out var set) && set.Contains(nodeId);

    private void AppendExpandedChildren(Guid parentId, List<ExternalNodeResponse> result)
    {
        if (!IsExpanded(parentId)) return;
        if (!externalChildrenCache.TryGetValue(selectedProvider, out var byProvider)) return;
        if (!byProvider.TryGetValue(parentId, out var children)) return;
        foreach (var child in children.OrderBy(n => n.Name))
        {
            result.Add(child);
            AppendExpandedChildren(child.Id, result);
        }
    }

    private async Task ToggleExternalNode(ExternalNodeResponse node)
    {
        if (!expandedExternalNodes.TryGetValue(selectedProvider, out var set))
        {
            set = new HashSet<Guid>();
            expandedExternalNodes[selectedProvider] = set;
        }

        if (set.Contains(node.Id))
        {
            set.Remove(node.Id);
            return;
        }

        // Expand: load children if not cached
        if (!externalChildrenCache.TryGetValue(selectedProvider, out var byProvider) || !byProvider.ContainsKey(node.Id))
        {
            if (!externalChildrenCache.ContainsKey(selectedProvider))
                externalChildrenCache[selectedProvider] = new();

            try
            {
                var result = await TaxonomyApi.GetExternalNodesAsync(selectedProvider, parentId: node.Id);
                externalChildrenCache[selectedProvider][node.Id] = result.Nodes;
            }
            catch (Exception ex)
            {
                errorMessage = $"Failed to load children: {ex.Message}";
                return;
            }
        }

        set.Add(node.Id);
    }

    private void OnSearchInput(ChangeEventArgs args)
    {
        searchText = args.Value?.ToString();
    }
}
