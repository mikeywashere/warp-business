@page "/catalog/taxonomy/import"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using WarpBusiness.Web.Services
@inherits WarpBusiness.Web.Components.AuthenticatedComponentBase
@inject TaxonomyApiClient TaxonomyApi
@inject NavigationManager Navigation

<PageTitle>Import Taxonomy</PageTitle>

<h1 class="mb-4">Import Taxonomy</h1>

<AuthorizeView Context="authContext">
    <Authorized>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
            </div>
        }

        @if (isLoading)
        {
            <div class="d-flex justify-content-center my-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            @if (showImportModal && SelectedNodeNames.Count > 0)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Import Selected Nodes</h5>
                                <button type="button" class="btn-close" @onclick="CloseImportModal"></button>
                            </div>
                            <div class="modal-body">
                                <p>You are about to import <strong>@SelectedNodeNames.Count</strong> nodes from <strong>@selectedProvider</strong>.</p>
                                <ul class="mb-2">
                                    @foreach (var name in SelectedNodeNames.Take(10))
                                    {
                                        <li>@name</li>
                                    }
                                </ul>
                                @if (SelectedNodeNames.Count > 10)
                                {
                                    <div class="text-muted small">and @(SelectedNodeNames.Count - 10) more...</div>
                                }

                                <div class="mt-3">
                                    <label class="form-label">Import into...</label>
                                    <select class="form-select" @bind="importParentId">
                                        <option value="">— Root level —</option>
                                        @foreach (var node in WarpNodeOptions)
                                        {
                                            <option value="@node.Id">@GetWarpNodeLabel(node)</option>
                                        }
                                    </select>
                                </div>

                                <div class="mt-3">
                                    <button type="button" class="btn btn-primary" @onclick="ConfirmImport" disabled="@isImporting">
                                        @if (isImporting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                        Import Selected
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary ms-2" @onclick="CloseImportModal">Cancel</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (ProviderTabs.Count == 0)
            {
                <div class="alert alert-info">No taxonomy providers are configured.</div>
            }
            else
            {
                <ul class="nav nav-tabs mb-3">
                    @foreach (var provider in ProviderTabs)
                    {
                        <li class="nav-item">
                            <button class="nav-link @(provider.Equals(selectedProvider, StringComparison.OrdinalIgnoreCase) ? "active" : "")"
                                    type="button" @onclick="() => SelectProvider(provider)">
                                @provider
                            </button>
                        </li>
                    }
                </ul>

                <div class="card mb-3">
                    <div class="card-body">
                        <div class="d-flex flex-wrap justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-1">@selectedProvider Taxonomy</h5>
                                <div class="text-muted small">
                                    Last download: @(FormatDate(CurrentStatus?.LastDownload))
                                    • @(CurrentStatus?.NodeCount ?? 0) nodes
                                    @if (!string.IsNullOrWhiteSpace(CurrentStatus?.Version))
                                    {
                                        <span>• Version @CurrentStatus!.Version</span>
                                    }
                                </div>
                                <div class="mt-2">
                                    <span class="badge @GetStatusBadgeClass(CurrentStatus)">@GetStatusText(CurrentStatus)</span>
                                </div>
                            </div>
                            <button class="btn btn-outline-info" @onclick="() => DownloadProviderAsync(selectedProvider)"
                                    disabled="@(!IsProviderEnabled(CurrentStatus) || isDownloading)">
                                @if (isDownloading) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                Download Now
                            </button>
                        </div>
                    </div>
                </div>

                @if (CurrentStatus is { RequiresApiKey: true, Enabled: false })
                {
                    <div class="alert alert-info">
                        This provider requires API credentials. Configure Taxonomy:@selectedProvider in appsettings.
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label">Search</label>
                    <input class="form-control" placeholder="Search by name or path" value="@searchText" @oninput="OnSearchInput" />
                </div>

                @if (isLoadingExternal)
                {
                    <div class="d-flex justify-content-center my-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Node</th>
                                    <th>Path</th>
                                    <th style="width: 250px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (VisibleExternalNodes.Any())
                                {
                                    @foreach (var node in VisibleExternalNodes)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center" style="padding-left: @(node.Level * 20)px;">
                                                    @if (HasExternalChildren(node))
                                                    {
                                                        <button type="button" class="btn btn-sm btn-link p-0 me-2"
                                                                style="color: var(--clr-accent);" @onclick="() => ToggleExternalNode(node)">
                                                            @(CurrentCollapsedSet.Contains(node.ExternalId) ? "▶" : "▼")
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <span class="me-4"></span>
                                                    }

                                                    @if (node.IsImported)
                                                    {
                                                        <span class="badge bg-secondary me-2">✓ Imported</span>
                                                    }
                                                    else
                                                    {
                                                        <input class="form-check-input me-2" type="checkbox" checked="@IsSelected(node)"
                                                               @onchange="(e => ToggleNodeSelection(node, e))" />
                                                    }
                                                    <span>@node.Name</span>
                                                </div>
                                            </td>
                                            <td class="text-muted small">@node.FullPath</td>
                                            <td>
                                                <button class="btn btn-sm mt-2 btn-outline-secondary"
                                                        @onclick="() => SelectAllChildren(node)" disabled="@node.IsLeaf">
                                                    Select All Children
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="3" class="text-center text-muted py-4">No external nodes loaded yet.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted">Selected: <strong>@SelectedCount</strong> nodes</div>
                    <button class="btn btn-primary" @onclick="ShowImportModal" disabled="@(SelectedCount == 0 || isImporting)">
                        Import Selected
                    </button>
                </div>
            }
        }
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-warning">
            <h4>Access Denied</h4>
            <p>You must be logged in. <a href="/login">Login</a></p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private string selectedProvider = string.Empty;
    private bool isLoading = true;
    private bool isLoadingExternal;
    private bool isDownloading;
    private bool isImporting;
    private bool showImportModal;
    private string? errorMessage;
    private string? successMessage;
    private string? searchText;
    private string? importParentId;

    private List<ProviderStatusResponse> providerStatuses = [];
    private List<TaxonomyNodeResponse> warpNodes = [];
    private readonly Dictionary<string, List<ExternalNodeResponse>> externalTrees = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, HashSet<string>> selectedExternalNodes = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, HashSet<string>> collapsedExternalNodes = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, Dictionary<string, List<ExternalNodeResponse>>> externalChildrenLookup = new(StringComparer.OrdinalIgnoreCase);

    private List<string> ProviderTabs =>
        providerStatuses
            .Select(s => s.Provider)
            .Where(p => !string.IsNullOrWhiteSpace(p))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(p => p)
            .ToList();

    private ProviderStatusResponse? CurrentStatus =>
        string.IsNullOrWhiteSpace(selectedProvider)
            ? null
            : providerStatuses.FirstOrDefault(s => s.Provider.Equals(selectedProvider, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<ExternalNodeResponse> CurrentExternalNodes =>
        string.IsNullOrWhiteSpace(selectedProvider)
            ? []
            : externalTrees.TryGetValue(selectedProvider, out var nodes) ? nodes : [];

    private HashSet<string> CurrentSelectedSet
    {
        get
        {
            if (!selectedExternalNodes.TryGetValue(selectedProvider, out var set))
            {
                set = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                selectedExternalNodes[selectedProvider] = set;
            }
            return set;
        }
    }

    private HashSet<string> CurrentCollapsedSet
    {
        get
        {
            if (!collapsedExternalNodes.TryGetValue(selectedProvider, out var set))
            {
                set = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                collapsedExternalNodes[selectedProvider] = set;
            }
            return set;
        }
    }

    private Dictionary<string, ExternalNodeResponse> CurrentExternalLookup =>
        CurrentExternalNodes.ToDictionary(n => n.ExternalId, StringComparer.OrdinalIgnoreCase);

    private IReadOnlyList<string> SelectedNodeNames =>
        CurrentSelectedSet
            .Select(id => CurrentExternalLookup.TryGetValue(id, out var node) ? node.Name : id)
            .OrderBy(name => name)
            .ToList();

    private int SelectedCount => CurrentSelectedSet.Count;

    private IEnumerable<TaxonomyNodeResponse> WarpNodeOptions =>
        warpNodes.OrderBy(n => n.MaterializedPath);

    private IEnumerable<ExternalNodeResponse> VisibleExternalNodes
    {
        get
        {
            var lookup = CurrentExternalLookup;
            return FilteredExternalNodes()
                .OrderBy(n => n.FullPath)
                .ThenBy(n => n.Name)
                .Where(n => IsExternalNodeVisible(n, lookup));
        }
    }

    protected override async Task OnAuthenticatedInitializedAsync()
    {
        if (string.IsNullOrEmpty(TokenProvider.SelectedTenantId))
        {
            Navigation.NavigateTo("/select-tenant");
            return;
        }

        await LoadProviderStatusAsync();
        EnsureSelectedProvider();
        await LoadWarpNodesAsync();
        if (!string.IsNullOrWhiteSpace(selectedProvider))
        {
            await LoadExternalNodesAsync(selectedProvider, forceReload: true);
        }
        isLoading = false;
    }

    private async Task LoadProviderStatusAsync()
    {
        try
        {
            providerStatuses = await TaxonomyApi.GetProviderStatusAsync();
            EnsureSelectedProvider();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load provider status: {ex.Message}";
        }
    }

    private void EnsureSelectedProvider()
    {
        if (ProviderTabs.Count == 0)
        {
            selectedProvider = string.Empty;
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedProvider)
            || !ProviderTabs.Contains(selectedProvider, StringComparer.OrdinalIgnoreCase))
        {
            selectedProvider = ProviderTabs[0];
        }
    }

    private async Task LoadWarpNodesAsync()
    {
        try
        {
            warpNodes = await TaxonomyApi.GetTaxonomyTreeAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load Warp taxonomy: {ex.Message}";
        }
    }

    private async Task LoadExternalNodesAsync(string provider, bool forceReload)
    {
        if (!forceReload && externalTrees.ContainsKey(provider)) return;

        isLoadingExternal = true;
        try
        {
            var nodes = await TaxonomyApi.GetExternalTreeAsync(provider);
            externalTrees[provider] = nodes;
            externalChildrenLookup.Remove(provider);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load external taxonomy: {ex.Message}";
        }
        finally
        {
            isLoadingExternal = false;
        }
    }

    private async Task SelectProvider(string provider)
    {
        if (provider.Equals(selectedProvider, StringComparison.OrdinalIgnoreCase)) return;

        selectedProvider = provider;
        await LoadExternalNodesAsync(provider, forceReload: false);
    }

    private async Task DownloadProviderAsync(string provider)
    {
        isDownloading = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            await TaxonomyApi.TriggerDownloadAsync(provider);
            successMessage = $"{provider} download started.";
            await LoadProviderStatusAsync();
            await LoadExternalNodesAsync(provider, forceReload: true);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            isDownloading = false;
        }
    }

    private string FormatDate(DateTime? date) =>
        date.HasValue ? date.Value.ToLocalTime().ToString("g") : "Never";

    private bool IsProviderEnabled(ProviderStatusResponse? status) =>
        status is null || status.Enabled;

    private string GetStatusText(ProviderStatusResponse? status)
    {
        if (status is null) return "Unknown";
        if (!string.IsNullOrWhiteSpace(status.Status)) return status.Status;
        return status.LastDownload.HasValue ? "Downloaded" : "Never downloaded";
    }

    private string GetStatusBadgeClass(ProviderStatusResponse? status)
    {
        if (status is null) return "bg-secondary";

        var statusValue = status.Status?.ToLowerInvariant() ?? string.Empty;
        if (statusValue.Contains("downloading") || statusValue.Contains("inprogress") || statusValue.Contains("queued"))
            return "bg-warning text-dark";
        if (statusValue.Contains("failed") || statusValue.Contains("error"))
            return "bg-danger";
        if (status.LastDownload.HasValue)
            return "bg-success";
        return "bg-secondary";
    }

    private IEnumerable<ExternalNodeResponse> FilteredExternalNodes()
    {
        if (string.IsNullOrWhiteSpace(searchText)) return CurrentExternalNodes;

        var term = searchText.Trim();
        return CurrentExternalNodes.Where(n =>
            n.Name.Contains(term, StringComparison.OrdinalIgnoreCase)
            || n.FullPath.Contains(term, StringComparison.OrdinalIgnoreCase));
    }

    private bool IsExternalNodeVisible(ExternalNodeResponse node, Dictionary<string, ExternalNodeResponse> lookup)
    {
        var parentId = node.ParentExternalId;
        while (!string.IsNullOrWhiteSpace(parentId))
        {
            if (CurrentCollapsedSet.Contains(parentId)) return false;
            if (!lookup.TryGetValue(parentId, out var parent)) break;
            parentId = parent.ParentExternalId;
        }
        return true;
    }

    private Dictionary<string, List<ExternalNodeResponse>> GetExternalChildrenLookup()
    {
        if (externalChildrenLookup.TryGetValue(selectedProvider, out var lookup))
            return lookup;

        lookup = new Dictionary<string, List<ExternalNodeResponse>>(StringComparer.OrdinalIgnoreCase);
        foreach (var node in CurrentExternalNodes)
        {
            if (string.IsNullOrWhiteSpace(node.ParentExternalId)) continue;
            if (!lookup.TryGetValue(node.ParentExternalId, out var children))
            {
                children = new List<ExternalNodeResponse>();
                lookup[node.ParentExternalId] = children;
            }
            children.Add(node);
        }

        externalChildrenLookup[selectedProvider] = lookup;
        return lookup;
    }

    private bool HasExternalChildren(ExternalNodeResponse node) =>
        GetExternalChildrenLookup().ContainsKey(node.ExternalId);

    private void ToggleExternalNode(ExternalNodeResponse node)
    {
        if (CurrentCollapsedSet.Contains(node.ExternalId))
            CurrentCollapsedSet.Remove(node.ExternalId);
        else
            CurrentCollapsedSet.Add(node.ExternalId);
    }

    private bool IsSelected(ExternalNodeResponse node) =>
        CurrentSelectedSet.Contains(node.ExternalId);

    private void ToggleNodeSelection(ExternalNodeResponse node, ChangeEventArgs args)
    {
        if (node.IsImported) return;

        var isSelected = args.Value is bool checkedValue
            ? checkedValue
            : bool.TryParse(args.Value?.ToString(), out var parsed) && parsed;

        if (isSelected)
            CurrentSelectedSet.Add(node.ExternalId);
        else
            CurrentSelectedSet.Remove(node.ExternalId);
    }

    private void SelectAllChildren(ExternalNodeResponse node)
    {
        var lookup = GetExternalChildrenLookup();
        AddNodeAndChildren(node, lookup);
    }

    private void AddNodeAndChildren(ExternalNodeResponse node, Dictionary<string, List<ExternalNodeResponse>> lookup)
    {
        if (!node.IsImported)
            CurrentSelectedSet.Add(node.ExternalId);

        if (!lookup.TryGetValue(node.ExternalId, out var children)) return;

        foreach (var child in children)
        {
            AddNodeAndChildren(child, lookup);
        }
    }

    private void ShowImportModal()
    {
        if (SelectedCount == 0) return;
        showImportModal = true;
    }

    private void CloseImportModal()
    {
        showImportModal = false;
        importParentId = null;
    }

    private async Task ConfirmImport()
    {
        if (SelectedCount == 0) return;

        isImporting = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            var parentId = Guid.TryParse(importParentId, out var parsed) ? (Guid?)parsed : null;
            var result = await TaxonomyApi.ImportNodesAsync(new ImportNodesRequest(
                selectedProvider,
                CurrentSelectedSet.ToList(),
                parentId));

            successMessage = $"{result.NodesCreated} nodes created, {result.NodesSkipped} already existed.";
            CurrentSelectedSet.Clear();
            CloseImportModal();
            await LoadWarpNodesAsync();
            await LoadExternalNodesAsync(selectedProvider, forceReload: true);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            isImporting = false;
        }
    }

    private string GetWarpNodeLabel(TaxonomyNodeResponse node) =>
        $"{new string('—', node.Level)} {node.Name}".Trim();

    private void OnSearchInput(ChangeEventArgs args)
    {
        searchText = args.Value?.ToString();
    }
}
