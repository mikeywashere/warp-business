@page "/catalog/products"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using WarpBusiness.Web.Services
@inherits WarpBusiness.Web.Components.AuthenticatedComponentBase
@inject CatalogApiClient CatalogApi
@inject NavigationManager Navigation
@inject CatalogTemplateRenderer TemplateRenderer
@inject Microsoft.JSInterop.IJSRuntime JS

<PageTitle>Product Catalog</PageTitle>

<h1 class="mb-4">Product Catalog</h1>

<AuthorizeView>
    <Authorized Context="authContext">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
            </div>
        }

        @if (isLoading)
        {
            <div class="d-flex justify-content-center align-items-center gap-3 my-5">
                <div class="spinner-border text-primary" role="status" aria-hidden="true"></div>
                <span>@(loadedCount > 0 ? $"Loading\u2026 ({loadedCount} products so far)" : "Loading\u2026")</span>
            </div>
        }
        else
        {
            @* Add / Edit Product Modal *@
            @if (showProductModal)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">@(editingProductId.HasValue ? "Edit Product" : "Add Product")</h5>
                                <button type="button" class="btn-close" @onclick="CloseProductModal"></button>
                            </div>
                            <div class="modal-body">
                                <EditForm Model="productForm" OnValidSubmit="HandleProductSubmit" FormName="productForm">
                                    <DataAnnotationsValidator />
                                    <ValidationSummary class="text-danger mb-3" />
                                    <div class="row g-3">
                                        <div class="col-md-8">
                                            <label class="form-label">Name <span class="text-danger">*</span></label>
                                            <InputText @bind-Value="productForm.Name" class="form-control" />
                                            <ValidationMessage For="() => productForm.Name" class="text-danger" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label">SKU</label>
                                            <InputText @bind-Value="productForm.SKU" class="form-control" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Brand</label>
                                            <InputText @bind-Value="productForm.Brand" class="form-control" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Category</label>
                                            <InputSelect @bind-Value="productForm.CategoryId" class="form-select">
                                                <option value="">— No category —</option>
                                                @foreach (var cat in categories ?? [])
                                                {
                                                    <option value="@cat.Id">@cat.Name</option>
                                                }
                                            </InputSelect>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Base Price <span class="text-danger">*</span></label>
                                            <InputNumber @bind-Value="productForm.BasePrice" class="form-control" />
                                            <ValidationMessage For="() => productForm.BasePrice" class="text-danger" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label">Currency <span class="text-danger">*</span></label>
                                            <InputText @bind-Value="productForm.Currency" class="form-control" placeholder="USD" maxlength="3" />
                                            <ValidationMessage For="() => productForm.Currency" class="text-danger" />
                                        </div>
                                        @if (editingProductId.HasValue)
                                        {
                                            <div class="col-md-4">
                                                <label class="form-label">Status</label>
                                                <div class="form-check form-switch mt-2">
                                                    <InputCheckbox @bind-Value="productForm.IsActive" class="form-check-input" id="productActiveSwitch" />
                                                    <label class="form-check-label" for="productActiveSwitch">
                                                        @(productForm.IsActive ? "Active" : "Inactive")
                                                    </label>
                                                </div>
                                            </div>
                                        }
                                        @if (allNotations != null && allNotations.Count > 0)
                                        {
                                            <div class="col-12">
                                                <label class="form-label">Notations</label>
                                                <div class="d-flex flex-wrap gap-2">
                                                    @foreach (var n in allNotations.Where(n => n.IsActive))
                                                    {
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="checkbox" id="notation-@n.Id"
                                                                   checked="@productForm.SelectedNotationIds.Contains(n.Id)"
                                                                   @onchange="@(e => ToggleNotation(n.Id, e.Value is true))" />
                                                            <label class="form-check-label" for="notation-@n.Id">
                                                                @if (!string.IsNullOrWhiteSpace(n.Icon))
                                                                {
                                                                    <i class="bi @GetIconClass(n.Icon) me-1"></i>
                                                                }
                                                                @n.Name
                                                            </label>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                        <div class="col-12">
                                            <label class="form-label">Description</label>
                                            <InputTextArea @bind-Value="productForm.Description" class="form-control" rows="3" />
                                        </div>
                                        @if (editingProductId.HasValue)
                                        {
                                            <div class="col-12">
                                                <label class="form-label">Product Media</label>
                                                @if (isUploadingMedia)
                                                {
                                                    <div class="alert alert-info py-2">
                                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                                        Uploading...
                                                    </div>
                                                }

                                                @if (currentProductMedia != null && currentProductMedia.Count > 0)
                                                {
                                                    <div class="media-gallery mb-2">
                                                        @foreach (var m in currentProductMedia.OrderBy(m => m.SortOrder))
                                                        {
                                                            <div class="media-gallery-item">
                                                                @if (m.MediaType == MediaType.Image)
                                                                {
                                                                    <img src="@CatalogApi.GetMediaUrl(m.Id)" class="media-gallery-thumb" alt="@(m.Description ?? m.FileName)" />
                                                                }
                                                                else
                                                                {
                                                                    <div class="media-gallery-video-card">
                                                                        <span class="media-type-icon">🎬</span>
                                                                        <span class="media-filename">@m.FileName</span>
                                                                    </div>
                                                                }
                                                                @if (editingMediaId == m.Id)
                                                                {
                                                                    <div class="media-description-edit mt-1">
                                                                        <input type="text" class="form-control form-control-sm" maxlength="500"
                                                                               @bind="editingMediaDescription" placeholder="Description..." />
                                                                        <div class="d-flex gap-1 mt-1">
                                                                            <button type="button" class="btn btn-xs btn-success" @onclick="SaveMediaDescription">✓</button>
                                                                            <button type="button" class="btn btn-xs btn-secondary" @onclick="CancelMediaDescriptionEdit">✕</button>
                                                                        </div>
                                                                    </div>
                                                                }
                                                                else
                                                                {
                                                                    <div class="media-item-footer mt-1">
                                                                        <span class="media-description small text-muted">@(m.Description ?? "")</span>
                                                                        <button type="button" class="btn btn-xs btn-outline-secondary ms-1"
                                                                                title="Edit description" @onclick="() => StartMediaDescriptionEdit(m.Id, m.Description)">✎</button>
                                                                    </div>
                                                                }
                                                                <button type="button" class="btn btn-xs btn-outline-danger media-delete-btn"
                                                                        @onclick="() => RemoveProductMedia(m.Id)" disabled="@isSubmitting">✕</button>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                                else if (!isUploadingMedia)
                                                {
                                                    <div class="mb-2 text-muted small">No media uploaded yet</div>
                                                }

                                                <div class="mb-2">
                                                    <input type="text" class="form-control form-control-sm" maxlength="500"
                                                           @bind="pendingProductMediaDescription"
                                                           placeholder="Media description (optional — applies to all files in next upload)" />
                                                </div>
                                                <InputFile OnChange="@HandleProductMediaUpload" accept="image/*,video/mp4,video/webm,video/quicktime"
                                                           class="form-control" disabled="@(isSubmitting || isUploadingMedia)" multiple />
                                                <div class="form-text">Images: max 5MB (JPG, PNG, WebP). Videos: max 500MB (MP4, WebM).</div>
                                            </div>
                                        }
                                    </div>
                                    <div class="mt-3">
                                        <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                                            @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                            @(editingProductId.HasValue ? "Update Product" : "Create Product")
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary ms-2" @onclick="CloseProductModal">Cancel</button>
                                    </div>
                                </EditForm>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* Variant Management Modal *@
            @if (showVariantsModal && selectedProduct != null)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog modal-xl">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Variants — @selectedProduct.Name</h5>
                                <button type="button" class="btn-close" @onclick="CloseVariantsModal"></button>
                            </div>
                            <div class="modal-body">
                                @if (!string.IsNullOrEmpty(variantError))
                                {
                                    <div class="alert alert-danger alert-dismissible fade show">
                                        @variantError
                                        <button type="button" class="btn-close" @onclick="() => variantError = null"></button>
                                    </div>
                                }

                                @* Product Options Section *@
                                <div class="card mb-3">
                                    <div class="card-header d-flex justify-content-between align-items-center">
                                        <span>Product Options</span>
                                        <div class="d-flex gap-2">
                                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ShowAddOptionForm" disabled="@isSubmitting">
                                                <span class="bi bi-plus-lg me-1"></span> Add Option
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="HandleGenerateVariants" disabled="@isSubmitting">
                                                <span class="bi bi-lightning me-1"></span> Generate Variants
                                            </button>
                                        </div>
                                    </div>
                                    <div class="card-body">
                                        @if (!string.IsNullOrEmpty(optionError))
                                        {
                                            <div class="alert alert-danger alert-dismissible fade show py-2">
                                                @optionError
                                                <button type="button" class="btn-close" @onclick="() => optionError = null"></button>
                                            </div>
                                        }

                                        @if (showAddOptionForm || editingOptionId.HasValue)
                                        {
                                            <div class="border rounded p-2 mb-3">
                                                <div class="row g-2 align-items-end">
                                                    <div class="col-md-5">
                                                        <label class="form-label form-label-sm mb-1">Option Name</label>
                                                        <input type="text" class="form-control form-control-sm" @bind="optionFormName" placeholder="e.g. Color, Size" />
                                                    </div>
                                                    <div class="col-md-3">
                                                        <div class="form-check mt-3">
                                                            <input type="checkbox" class="form-check-input" id="optionVariantAxisCheck" @bind="optionFormIsVariantAxis" />
                                                            <label class="form-check-label small" for="optionVariantAxisCheck">Variant Axis</label>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-4 d-flex gap-1">
                                                        <button type="button" class="btn btn-sm btn-primary" @onclick="HandleOptionSubmit" disabled="@(isSubmitting || string.IsNullOrWhiteSpace(optionFormName))">
                                                            @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                                            @(editingOptionId.HasValue ? "Update" : "Add")
                                                        </button>
                                                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CancelOptionEdit">Cancel</button>
                                                    </div>
                                                </div>
                                            </div>
                                        }

                                        @if (isLoadingOptions)
                                        {
                                            <div class="text-muted small"><span class="spinner-border spinner-border-sm me-1" role="status"></span> Loading options...</div>
                                        }
                                        else if (selectedProductOptions is { Count: 0 })
                                        {
                                            <div class="text-muted small">No options defined yet. Add an option (e.g. Color, Size) to create product variants.</div>
                                        }
                                        else if (selectedProductOptions != null)
                                        {
                                            @foreach (var opt in selectedProductOptions)
                                            {
                                                <div class="border rounded p-2 mb-2">
                                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                                        <div>
                                                            <strong class="me-1">@opt.Name</strong>
                                                            @if (opt.IsVariantAxis)
                                                            {
                                                                <span class="badge bg-primary" style="font-size:0.65rem;">Variant Axis</span>
                                                            }
                                                        </div>
                                                        <div class="d-flex gap-1">
                                                            <button type="button" class="btn btn-xs btn-outline-secondary" @onclick="() => StartEditOption(opt)">Edit</button>
                                                            <button type="button" class="btn btn-xs btn-outline-danger" @onclick="() => DeleteOptionAsync(opt)" disabled="@isSubmitting">Delete</button>
                                                        </div>
                                                    </div>
                                                    <div class="d-flex flex-wrap gap-1 mb-2">
                                                        @foreach (var val in opt.Values)
                                                        {
                                                            @if (editingValueId == val.Id && editingValueOptionId == opt.Id)
                                                            {
                                                                <div class="d-inline-flex align-items-center gap-1">
                                                                    <input type="text" class="form-control form-control-sm" style="width:130px;" @bind="valueFormValue" />
                                                                    <button type="button" class="btn btn-xs btn-success" @onclick="() => HandleUpdateOptionValue(opt.Id, val.Id)" disabled="@isSubmitting">✓</button>
                                                                    <button type="button" class="btn btn-xs btn-secondary" @onclick="CancelValueEdit">✕</button>
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge bg-secondary d-inline-flex align-items-center gap-1" style="font-size:0.8rem;">
                                                                    @val.Value
                                                                    <button type="button" class="btn btn-xs btn-link text-white p-0 ms-1" style="line-height:1;" @onclick="() => StartEditValue(opt.Id, val)" title="Edit">✎</button>
                                                                    <button type="button" class="btn btn-xs btn-link text-danger p-0" style="line-height:1;" @onclick="() => DeleteOptionValueAsync(opt.Id, val.Id)" title="Delete" disabled="@isSubmitting">✕</button>
                                                                </span>
                                                            }
                                                        }
                                                    </div>
                                                    @if (addingValueForOptionId == opt.Id)
                                                    {
                                                        <div class="d-flex gap-1 align-items-center">
                                                            <input type="text" class="form-control form-control-sm" style="width:160px;" @bind="valueFormValue" placeholder="Value..." />
                                                            <button type="button" class="btn btn-xs btn-success" @onclick="() => HandleAddOptionValue(opt.Id)" disabled="@(isSubmitting || string.IsNullOrWhiteSpace(valueFormValue))">Add</button>
                                                            <button type="button" class="btn btn-xs btn-secondary" @onclick="CancelValueEdit">Cancel</button>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <button type="button" class="btn btn-xs btn-outline-secondary" @onclick="() => { addingValueForOptionId = opt.Id; valueFormValue = string.Empty; }">
                                                            <span class="bi bi-plus-lg"></span> Add Value
                                                        </button>
                                                    }
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>

                                @* Add/Edit Variant Form *@
                                <div class="card mb-3">
                                    <div class="card-header">@(editingVariantId.HasValue ? "Edit Variant" : "Add Variant")</div>
                                    <div class="card-body">
                                        <EditForm Model="variantForm" OnValidSubmit="HandleVariantSubmit" FormName="variantForm">
                                            <div class="row g-2">
                                                <div class="col-md-2">
                                                    <label class="form-label">SKU</label>
                                                    <InputText @bind-Value="variantForm.SKU" class="form-control" />
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="form-label">Price Override</label>
                                                    <InputNumber @bind-Value="variantForm.Price" class="form-control" />
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="form-label">Stock Qty</label>
                                                    <InputNumber @bind-Value="variantForm.StockQuantity" class="form-control" />
                                                </div>
                                            </div>
                                            <div class="mt-2">
                                                <button type="submit" class="btn btn-sm btn-primary" disabled="@isSubmitting">
                                                    @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                                    @(editingVariantId.HasValue ? "Update" : "Add Variant")
                                                </button>
                                                @if (editingVariantId.HasValue)
                                                {
                                                    <button type="button" class="btn btn-sm mt-2 btn-outline-secondary ms-2" @onclick="CancelVariantEdit">Cancel Edit</button>
                                                }
                                            </div>
                                        </EditForm>
                                    </div>
                                </div>

                                @* Variants Table *@
                                <div class="table-responsive">
                                    <table class="table table-sm table-striped">
                                        <thead class="table-dark">
                                            <tr>
                                                <th style="width: 60px;">Image</th>
                                                <th>Attributes</th>
                                                <th>SKU</th>
                                                <th>Price</th>
                                                <th>Stock</th>
                                                <th>Status</th>
                                                <th style="width: 250px;">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (selectedVariants is { Count: > 0 })
                                            {
                                                @foreach (var v in selectedVariants)
                                                {
                                                    <tr>
                                                        <td>
                                                            <div class="d-flex align-items-center">
                                                                @if (v.ThumbnailMediaId != null)
                                                                {
                                                                    <img src="@GetProductImageUrl(v.ThumbnailMediaId)" class="product-thumbnail" alt="Variant" />
                                                                }
                                                                else
                                                                {
                                                                    <span class="no-image-placeholder-sm">📷</span>
                                                                }
                                                            </div>
                                                        </td>
                                                        <td>
                                                            @if (v.OptionValues != null && v.OptionValues.Count > 0)
                                                            {
                                                                <span>@string.Join(", ", v.OptionValues.Select(a => $"{a.OptionName}: {a.Value}"))</span>
                                                            }
                                                            else { <span class="text-muted">—</span> }
                                                        </td>
                                                        <td><code>@(v.SKU ?? "—")</code></td>
                                                        <td>
                                                            @if (v.Price.HasValue)
                                                            { <span>@v.Price.Value.ToString("F2") @selectedProduct.Currency</span> }
                                                            else
                                                            { <span class="text-muted">Base (@selectedProduct.BasePrice.ToString("F2"))</span> }
                                                        </td>
                                                        <td>@v.StockQuantity</td>
                                                        <td>
                                                            <span class="badge @(v.IsActive ? "bg-success" : "bg-secondary")">
                                                                @(v.IsActive ? "Active" : "Inactive")
                                                            </span>
                                                        </td>
                                                        <td>
                                                            <button class="btn btn-sm mt-2 btn-outline-primary me-1" @onclick="() => EditVariant(v)">Edit</button>
                                                            <button class="btn btn-sm mt-2 btn-outline-info me-1" @onclick="() => ShowVariantImageUpload(v)" title="Manage Media">
                                                                <span class="bi bi-images"></span>
                                                            </button>
                                                            <button class="btn btn-sm mt-2 btn-outline-danger" @onclick="() => DeleteVariantAsync(v)">Delete</button>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr><td colspan="7" class="text-center text-muted py-3">No variants yet. Add one above.</td></tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* Product List *@
            @if (isStreaming)
            {
                <div class="alert alert-info d-flex align-items-center gap-2 py-2 mb-3" role="status">
                    <div class="spinner-border spinner-border-sm text-info flex-shrink-0" aria-hidden="true"></div>
                    <span>Loading&hellip; (@loadedCount products so far)</span>
                </div>
            }
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Products (@(FilteredProducts.Count)@(!string.IsNullOrWhiteSpace(searchTerm) ? $" of {products?.Count ?? 0}" : ""))</h5>
                <button class="btn btn-primary" @onclick="ShowAddProductModal">
                    <span class="bi bi-plus-lg me-1"></span> Add Product
                </button>
            </div>

            <div class="mb-3">
                <input type="text" class="form-control" placeholder="Search by name, brand, or SKU..."
                       @bind="searchTerm" @bind:event="oninput" />
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 60px;">Image</th>
                            <th>Name</th>
                            <th>Brand</th>
                            <th>SKU</th>
                            <th>Category</th>
                            <th>Base Price</th>
                            <th>Variants</th>
                            <th>Status</th>
                            <th style="width: 250px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (FilteredProducts is { Count: > 0 })
                        {
                            @foreach (var product in FilteredProducts)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            @if (product.ThumbnailMediaId != null)
                                            {
                                                <img src="@GetProductImageUrl(product.ThumbnailMediaId)" class="product-thumbnail" alt="@product.Name" />
                                            }
                                            else
                                            {
                                                <span class="no-image-placeholder">📷</span>
                                            }
                                        </div>
                                    </td>
                                    <td>@product.Name</td>
                                    <td>@(product.Brand ?? "—")</td>
                                    <td><code>@(product.SKU ?? "—")</code></td>
                                    <td>@(product.CategoryName ?? "—")</td>
                                    <td>@product.BasePrice.ToString("F2") @product.Currency</td>
                                    <td>
                                        <span class="badge bg-info text-dark">@product.VariantCount</span>
                                    </td>
                                    <td>
                                        <span class="badge @(product.IsActive ? "bg-success" : "bg-secondary")">
                                            @(product.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm mt-2 btn-outline-secondary me-1" @onclick="() => OpenVariantsModal(product)" title="Manage Variants">
                                            Variants
                                        </button>
                                        <button class="btn btn-sm mt-2 btn-outline-primary me-1" @onclick="() => ShowEditProductModal(product)" title="Edit">
                                            Edit
                                        </button>
                                        <button class="btn btn-sm mt-2 btn-outline-info me-1" @onclick="() => NavigateToPreview(product.Id)" title="Catalog Preview">
                                            Preview
                                        </button>
                                        <button class="btn btn-sm mt-2 btn-outline-danger" @onclick="() => ConfirmDeleteProduct(product)" title="Delete">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center text-muted py-4">
                                    @(string.IsNullOrWhiteSpace(searchTerm) ? "No products found." : "No products match your search.")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Delete Confirmation Modal *@
            @if (showDeleteConfirm && deleteProductCandidate != null)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Confirm Delete</h5>
                                <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                            </div>
                            <div class="modal-body">
                                <p>Delete <strong>@deleteProductCandidate.Name</strong>?</p>
                                @if (deleteProductCandidate.VariantCount > 0)
                                {
                                    <p class="text-warning">This will also delete all <strong>@deleteProductCandidate.VariantCount</strong> variant(s).</p>
                                }
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                                <button type="button" class="btn btn-danger" @onclick="ExecuteDeleteProduct" disabled="@isSubmitting">
                                    @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                    Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* Variant Media Modal *@
            @if (showVariantImageModal && selectedVariantForImage != null)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Variant Media — @(selectedVariantForImage.SKU ?? selectedVariantForImage.Id.ToString("N")[..8])</h5>
                                <button type="button" class="btn-close" @onclick="CloseVariantImageModal"></button>
                            </div>
                            <div class="modal-body">
                                @if (!string.IsNullOrEmpty(variantImageError))
                                {
                                    <div class="alert alert-danger alert-dismissible fade show">
                                        @variantImageError
                                        <button type="button" class="btn-close" @onclick="() => variantImageError = null"></button>
                                    </div>
                                }
                                @if (isUploadingVariantMedia)
                                {
                                    <div class="alert alert-info py-2">
                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                        Uploading...
                                    </div>
                                }

                                @if (currentVariantMedia != null && currentVariantMedia.Count > 0)
                                {
                                    <div class="media-gallery mb-2">
                                        @foreach (var m in currentVariantMedia.OrderBy(m => m.SortOrder))
                                        {
                                            <div class="media-gallery-item">
                                                @if (m.MediaType == MediaType.Image)
                                                {
                                                    <img src="@CatalogApi.GetMediaUrl(m.Id)" class="media-gallery-thumb" alt="@(m.Description ?? m.FileName)" />
                                                }
                                                else
                                                {
                                                    <div class="media-gallery-video-card">
                                                        <span class="media-type-icon">🎬</span>
                                                        <span class="media-filename">@m.FileName</span>
                                                    </div>
                                                }
                                                @if (editingMediaId == m.Id)
                                                {
                                                    <div class="media-description-edit mt-1">
                                                        <input type="text" class="form-control form-control-sm" maxlength="500"
                                                               @bind="editingMediaDescription" placeholder="Description..." />
                                                        <div class="d-flex gap-1 mt-1">
                                                            <button type="button" class="btn btn-xs btn-success" @onclick="SaveMediaDescription">✓</button>
                                                            <button type="button" class="btn btn-xs btn-secondary" @onclick="CancelMediaDescriptionEdit">✕</button>
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="media-item-footer mt-1">
                                                        <span class="media-description small text-muted">@(m.Description ?? "")</span>
                                                        <button type="button" class="btn btn-xs btn-outline-secondary ms-1"
                                                                title="Edit description" @onclick="() => StartMediaDescriptionEdit(m.Id, m.Description)">✎</button>
                                                    </div>
                                                }
                                                <button type="button" class="btn btn-xs btn-outline-danger media-delete-btn"
                                                        @onclick="() => RemoveVariantMedia(m.Id)" disabled="@isSubmitting">✕</button>
                                            </div>
                                        }
                                    </div>
                                }
                                else if (!isUploadingVariantMedia)
                                {
                                    <div class="mb-2 text-muted small">No media uploaded yet</div>
                                }

                                <div class="mb-2">
                                    <input type="text" class="form-control form-control-sm" maxlength="500"
                                           @bind="pendingVariantMediaDescription"
                                           placeholder="Media description (optional — applies to all files in next upload)" />
                                </div>
                                <InputFile OnChange="@HandleVariantMediaUpload" accept="image/*,video/mp4,video/webm,video/quicktime"
                                           class="form-control" disabled="@(isSubmitting || isUploadingVariantMedia)" multiple />
                                <div class="form-text">Images: max 5MB (JPG, PNG, WebP). Videos: max 500MB (MP4, WebM).</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }

        @* Catalog Preview Modal *@
        @if (showPreviewModal)
        {
            <div class="modal d-block catalog-preview-modal" tabindex="-1" style="background-color: rgba(0,0,0,0.75);" @onclick="ClosePreviewModal">
                <div class="modal-dialog modal-xl modal-dialog-scrollable" style="max-width:960px;" @onclick:stopPropagation="true">
                    <div class="modal-content">
                        <div class="modal-header">
                            <div class="d-flex align-items-center gap-2 flex-grow-1">
                                <h5 class="modal-title mb-0">Catalog Preview — @previewProductName</h5>
                                <div class="ms-auto d-flex align-items-center gap-2">
                                    <label class="form-label mb-0 me-1 small">Template:</label>
                                    <select class="form-select form-select-sm" style="width:auto;"
                                            @bind="previewSelectedTemplate" @bind:after="RefreshPreviewAsync">
                                        @foreach (var t in previewAvailableTemplates)
                                        {
                                            <option value="@t">@t</option>
                                        }
                                    </select>
                                    <button class="btn btn-sm mt-2 btn-outline-primary" @onclick="PrintPreviewAsync">🖨 Print</button>
                                </div>
                            </div>
                            <button type="button" class="btn-close ms-2" @onclick="ClosePreviewModal"></button>
                        </div>
                        <div class="modal-body p-0">
                            @if (isLoadingPreview)
                            {
                                <div class="d-flex justify-content-center my-5">
                                    <div class="spinner-border text-primary" role="status">
                                        <span class="visually-hidden">Loading preview…</span>
                                    </div>
                                </div>
                            }
                            else if (!string.IsNullOrEmpty(previewError))
                            {
                                <div class="alert alert-danger m-3">@previewError</div>
                            }
                            else
                            {
                                <iframe class="catalog-preview-iframe"
                                        srcdoc="@previewRenderedHtml"
                                        style="width:100%; height:72vh; border:none; display:block;"
                                        title="Catalog Preview"></iframe>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-warning">
            <h4>Access Denied</h4>
            <p>You must be logged in. <a href="/login">Login</a></p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<CatalogProductResponse>? products;
    private List<CatalogCategoryResponse>? categories;
    private List<CatalogNotationResponse>? allNotations;
    private List<CatalogProductVariantResponse>? selectedVariants;
    private List<ProductOptionDto>? selectedProductOptions;
    private CatalogProductResponse? selectedProduct;

    private bool isLoading = true;
    private bool isStreaming;
    private int loadedCount;
    private bool isSubmitting;
    private bool showProductModal;
    private bool showVariantsModal;
    private bool showDeleteConfirm;
    private bool showVariantImageModal;
    private bool isUploadingMedia;
    private bool isUploadingVariantMedia;
    private bool showPreviewModal;
    private bool isLoadingPreview;
    private bool isLoadingOptions;
    private string previewProductName = "";
    private string previewRenderedHtml = "";
    private string? previewError;
    private string previewSelectedTemplate = "default";
    private List<string> previewAvailableTemplates = ["default"];
    private Guid previewProductId;

    private Guid? editingProductId;
    private Guid? editingVariantId;
    private CatalogProductResponse? deleteProductCandidate;
    private CatalogProductVariantResponse? selectedVariantForImage;

    // Option state
    private bool showAddOptionForm;
    private Guid? editingOptionId;
    private string optionFormName = "";
    private bool optionFormIsVariantAxis = true;
    private string? optionError;

    // Option value state
    private Guid? addingValueForOptionId;
    private Guid? editingValueId;
    private Guid? editingValueOptionId;
    private string valueFormValue = "";

    private string? errorMessage;
    private string? successMessage;
    private string? variantError;
    private string? variantImageError;
    private string searchTerm = "";
    private List<ProductMediaResponse>? currentProductMedia;
    private List<ProductMediaResponse>? currentVariantMedia;

    private string pendingProductMediaDescription = "";
    private string pendingVariantMediaDescription = "";
    private Guid? editingMediaId;
    private string editingMediaDescription = "";

    private ProductFormModel productForm = new();
    private VariantFormModel variantForm = new();

    private List<CatalogProductResponse> FilteredProducts =>
        products?.Where(p =>
            string.IsNullOrWhiteSpace(searchTerm) ||
            p.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            (p.Brand?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (p.SKU?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
        ).ToList() ?? [];

    protected override async Task OnAuthenticatedInitializedAsync()
    {
        if (string.IsNullOrEmpty(TokenProvider.SelectedTenantId))
        {
            Navigation.NavigateTo("/select-tenant");
            return;
        }
        await Task.WhenAll(LoadCategories(), LoadNotations());
        // Products are streamed progressively in OnAfterRenderAsync
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await StreamProductsAsync();
    }

    private async Task StreamProductsAsync()
    {
        const int batchSize = 25;
        var batch = new List<CatalogProductResponse>();
        isStreaming = true;
        try
        {
            await foreach (var product in CatalogApi.GetProductsStreamAsync())
            {
                batch.Add(product);
                loadedCount++;
                if (batch.Count >= batchSize)
                {
                    products = [..products ?? [], ..batch];
                    batch.Clear();
                    isLoading = false;
                    await InvokeAsync(StateHasChanged);
                    await Task.Delay(1);
                }
            }
            if (batch.Count > 0)
            {
                products = [..products ?? [], ..batch];
            }
        }
        catch (Exception ex)
        {
            await InvokeAsync(() => errorMessage = $"Failed to load products: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            isStreaming = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadProducts()
    {
        try { products = await CatalogApi.GetProductsAsync(); }
        catch (Exception ex) { errorMessage = $"Failed to load products: {ex.Message}"; }
    }

    private async Task LoadCategories()
    {
        try { categories = await CatalogApi.GetCategoriesAsync(); }
        catch { /* non-critical */ }
    }

    private async Task LoadNotations()
    {
        try { allNotations = await CatalogApi.GetNotationsAsync(); }
        catch { /* non-critical */ }
    }

    private void ToggleNotation(Guid notationId, bool add)
    {
        if (add) { if (!productForm.SelectedNotationIds.Contains(notationId)) productForm.SelectedNotationIds.Add(notationId); }
        else { productForm.SelectedNotationIds.Remove(notationId); }
    }

    // ── Product modal ─────────────────────────────────────────────────────────

    private void ShowAddProductModal()
    {
        productForm = new ProductFormModel { Currency = "USD" };
        editingProductId = null;
        showProductModal = true;
    }

    private void ShowEditProductModal(CatalogProductResponse product)
    {
        productForm = new ProductFormModel
        {
            Name = product.Name,
            Description = product.Description,
            Brand = product.Brand,
            SKU = product.SKU,
            BasePrice = product.BasePrice,
            Currency = product.Currency,
            CategoryId = product.CategoryId?.ToString(),
            IsActive = product.IsActive,
            SelectedNotationIds = product.Notations?.Select(n => n.NotationId).ToList() ?? []
        };
        editingProductId = product.Id;
        currentProductMedia = null;
        showProductModal = true;
        _ = Task.Run(async () =>
        {
            currentProductMedia = await CatalogApi.GetProductMediaAsync(product.Id);
            await InvokeAsync(StateHasChanged);
        });
    }

    private void CloseProductModal()
    {
        showProductModal = false;
        editingProductId = null;
        currentProductMedia = null;
        pendingProductMediaDescription = "";
        editingMediaId = null;
        editingMediaDescription = "";
        productForm = new ProductFormModel();
    }

    private async Task HandleProductSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            var categoryId = Guid.TryParse(productForm.CategoryId, out var catGuid) ? (Guid?)catGuid : null;

            if (editingProductId.HasValue)
            {
                await CatalogApi.UpdateProductAsync(editingProductId.Value, new UpdateCatalogProductRequest(
                    productForm.Name!, productForm.BasePrice, productForm.Currency!,
                    productForm.Description, productForm.Brand, productForm.SKU,
                    categoryId, productForm.IsActive,
                    NotationIds: productForm.SelectedNotationIds));
                successMessage = "Product updated.";
            }
            else
            {
                await CatalogApi.CreateProductAsync(new CreateCatalogProductRequest(
                    productForm.Name!, productForm.BasePrice, productForm.Currency!,
                    productForm.Description, productForm.Brand, productForm.SKU, categoryId,
                    NotationIds: productForm.SelectedNotationIds));
                successMessage = "Product created.";
            }
            CloseProductModal();
            await LoadProducts();
        }
        catch (ApiException ex) { errorMessage = ex.Message; }
        catch (Exception ex) { errorMessage = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    // ── Delete product ────────────────────────────────────────────────────────

    private void ConfirmDeleteProduct(CatalogProductResponse product)
    {
        deleteProductCandidate = product;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        deleteProductCandidate = null;
    }

    private async Task ExecuteDeleteProduct()
    {
        if (deleteProductCandidate is null) return;
        isSubmitting = true;
        try
        {
            await CatalogApi.DeleteProductAsync(deleteProductCandidate.Id);
            successMessage = "Product deleted.";
            CancelDelete();
            await LoadProducts();
        }
        catch (ApiException ex) { errorMessage = ex.Message; }
        catch (Exception ex) { errorMessage = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    // ── Variants modal ────────────────────────────────────────────────────────

    private async Task OpenVariantsModal(CatalogProductResponse product)
    {
        selectedProduct = product;
        editingVariantId = null;
        variantForm = new VariantFormModel();
        variantError = null;
        optionError = null;
        showAddOptionForm = false;
        editingOptionId = null;
        addingValueForOptionId = null;
        editingValueId = null;
        showVariantsModal = true;
        await Task.WhenAll(RefreshVariants(), RefreshOptions());
    }

    private void CloseVariantsModal()
    {
        showVariantsModal = false;
        selectedProduct = null;
        selectedVariants = null;
        selectedProductOptions = null;
        editingVariantId = null;
        showAddOptionForm = false;
        editingOptionId = null;
        addingValueForOptionId = null;
        editingValueId = null;
        optionError = null;
    }

    private async Task RefreshVariants()
    {
        if (selectedProduct is null) return;
        try { selectedVariants = await CatalogApi.GetVariantsAsync(selectedProduct.Id); }
        catch (Exception ex) { variantError = $"Failed to load variants: {ex.Message}"; }
    }

    private void EditVariant(CatalogProductVariantResponse v)
    {
        editingVariantId = v.Id;
        variantForm = new VariantFormModel
        {
            SKU = v.SKU,
            Price = v.Price,
            StockQuantity = v.StockQuantity
        };
    }

    private void CancelVariantEdit()
    {
        editingVariantId = null;
        variantForm = new VariantFormModel();
    }

    private async Task HandleVariantSubmit()
    {
        if (selectedProduct is null) return;
        isSubmitting = true;
        variantError = null;
        try
        {
            if (editingVariantId.HasValue)
            {
                await CatalogApi.UpdateVariantAsync(selectedProduct.Id, editingVariantId.Value,
                    new UpdateCatalogVariantRequest(variantForm.SKU, variantForm.Price, StockQuantity: variantForm.StockQuantity));
            }
            else
            {
                await CatalogApi.CreateVariantAsync(selectedProduct.Id,
                    new CreateCatalogVariantRequest(variantForm.SKU, variantForm.Price, StockQuantity: variantForm.StockQuantity));
            }
            CancelVariantEdit();
            await RefreshVariants();
            await LoadProducts();
        }
        catch (ApiException ex) { variantError = ex.Message; }
        catch (Exception ex) { variantError = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private async Task DeleteVariantAsync(CatalogProductVariantResponse v)
    {
        if (selectedProduct is null) return;
        isSubmitting = true;
        variantError = null;
        try
        {
            await CatalogApi.DeleteVariantAsync(selectedProduct.Id, v.Id);
            await RefreshVariants();
            await LoadProducts();
        }
        catch (ApiException ex) { variantError = ex.Message; }
        catch (Exception ex) { variantError = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    // ── Media management ──────────────────────────────────────────────────────

    private void NavigateToPreview(Guid productId)
    {
        previewProductId = productId;
        showPreviewModal = true;
        previewAvailableTemplates = TemplateRenderer.GetAvailableTemplates().ToList();
        if (previewAvailableTemplates.Count > 0 && !previewAvailableTemplates.Contains(previewSelectedTemplate))
            previewSelectedTemplate = previewAvailableTemplates[0];
        _ = LoadPreviewAsync();
    }

    private void ClosePreviewModal()
    {
        showPreviewModal = false;
        previewRenderedHtml = "";
        previewError = null;
    }

    private async Task LoadPreviewAsync()
    {
        isLoadingPreview = true;
        previewError = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            var product = await CatalogApi.GetProductAsync(previewProductId);
            if (product is null) { previewError = "Product not found."; return; }
            previewProductName = product.Name;
            var variants = await CatalogApi.GetVariantsAsync(previewProductId);
            previewRenderedHtml = TemplateRenderer.Render(previewSelectedTemplate, BuildPreviewTemplateData(product, variants));
        }
        catch (Exception ex) { previewError = $"Failed to load preview: {ex.Message}"; }
        finally { isLoadingPreview = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task RefreshPreviewAsync() => await LoadPreviewAsync();

    private async Task PrintPreviewAsync() => await JS.InvokeVoidAsync("eval", "document.querySelector('.catalog-preview-iframe').contentWindow.print()");

    private string? GetProductImageUrl(Guid? mediaId)
        => mediaId.HasValue ? CatalogApi.GetMediaUrl(mediaId.Value) : null;

    private object BuildPreviewTemplateData(CatalogProductResponse product, List<CatalogProductVariantResponse> variants)
    {
        var formattedBase = $"{product.Currency} {product.BasePrice:N2}";
        return new
        {
            previewDate = DateTime.Now.ToString("MMMM d, yyyy"),
            hasVariants = variants.Count > 0,
            variantCount = variants.Count,
            hasNotations = product.Notations is { Count: > 0 },
            product = new
            {
                name = product.Name,
                description = product.Description,
                brand = product.Brand,
                sku = product.SKU,
                basePrice = product.BasePrice,
                formattedPrice = formattedBase,
                currency = product.Currency,
                category = product.CategoryName,
                isActive = product.IsActive,
                thumbnailUrl = product.ThumbnailMediaId.HasValue
                    ? CatalogApi.GetMediaUrl(product.ThumbnailMediaId.Value)
                    : (string?)null,
                notations = product.Notations?.Select(n => new
                {
                    icon = n.Icon,
                    iconClass = GetIconClass(n.Icon),
                    name = n.Name,
                    description = n.Description
                }).ToList() ?? (object)new List<object>()
            },
            variants = variants.Select(v =>
            {
                var price = v.Price.HasValue ? $"{product.Currency} {v.Price.Value:N2}" : formattedBase;
                return new
                {
                    sku = v.SKU,
                    formattedPrice = price,
                    stockQuantity = v.StockQuantity,
                    lowStock = v.StockQuantity is >= 0 and <= 5,
                    isActive = v.IsActive,
                    thumbnailUrl = v.ThumbnailMediaId.HasValue
                        ? CatalogApi.GetMediaUrl(v.ThumbnailMediaId.Value)
                        : (string?)null,
                    hasAttributes = v.OptionValues is { Count: > 0 },
                    attributes = v.OptionValues?.Select(a => new
                    {
                        name = a.OptionName,
                        value = a.Value
                    }).ToList() ?? (object)new List<object>()
                };
            }).ToList()
        };
    }

    private async Task HandleProductMediaUpload(InputFileChangeEventArgs e)
    {
        if (!editingProductId.HasValue) return;
        isUploadingMedia = true;
        errorMessage = null;
        StateHasChanged();
        try
        {
            var desc = string.IsNullOrWhiteSpace(pendingProductMediaDescription) ? null : pendingProductMediaDescription.Trim();
            foreach (var file in e.GetMultipleFiles(10))
            {
                var maxSize = file.ContentType.StartsWith("video/") ? 500L * 1024 * 1024 : 5L * 1024 * 1024;
                using var stream = file.OpenReadStream(maxAllowedSize: maxSize);
                await CatalogApi.UploadProductMediaAsync(editingProductId.Value, stream, file.Name, file.ContentType, desc);
            }
            pendingProductMediaDescription = "";
            currentProductMedia = await CatalogApi.GetProductMediaAsync(editingProductId.Value);
            await LoadProducts();
            StateHasChanged();
        }
        catch (ApiException ex) { errorMessage = ex.Message; }
        catch (Exception ex) { errorMessage = $"Upload failed: {ex.Message}"; }
        finally { isUploadingMedia = false; StateHasChanged(); }
    }

    private async Task RemoveProductMedia(Guid mediaId)
    {
        if (!editingProductId.HasValue) return;
        isSubmitting = true;
        errorMessage = null;
        try
        {
            await CatalogApi.DeleteMediaAsync(mediaId);
            currentProductMedia = await CatalogApi.GetProductMediaAsync(editingProductId.Value);
            await LoadProducts();
            StateHasChanged();
        }
        catch (ApiException ex) { errorMessage = ex.Message; }
        catch (Exception ex) { errorMessage = $"Failed to remove media: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private async Task HandleVariantMediaUpload(InputFileChangeEventArgs e)
    {
        if (selectedVariantForImage is null) return;
        isUploadingVariantMedia = true;
        variantImageError = null;
        StateHasChanged();
        try
        {
            var desc = string.IsNullOrWhiteSpace(pendingVariantMediaDescription) ? null : pendingVariantMediaDescription.Trim();
            foreach (var file in e.GetMultipleFiles(10))
            {
                var maxSize = file.ContentType.StartsWith("video/") ? 500L * 1024 * 1024 : 5L * 1024 * 1024;
                using var stream = file.OpenReadStream(maxAllowedSize: maxSize);
                await CatalogApi.UploadVariantMediaAsync(selectedVariantForImage.Id, stream, file.Name, file.ContentType, desc);
            }
            pendingVariantMediaDescription = "";
            currentVariantMedia = await CatalogApi.GetVariantMediaAsync(selectedVariantForImage.Id);
            await RefreshVariants();
            StateHasChanged();
        }
        catch (ApiException ex) { variantImageError = ex.Message; }
        catch (Exception ex) { variantImageError = $"Upload failed: {ex.Message}"; }
        finally { isUploadingVariantMedia = false; StateHasChanged(); }
    }

    private async Task RemoveVariantMedia(Guid mediaId)
    {
        if (selectedVariantForImage is null) return;
        isSubmitting = true;
        variantImageError = null;
        try
        {
            await CatalogApi.DeleteMediaAsync(mediaId);
            currentVariantMedia = await CatalogApi.GetVariantMediaAsync(selectedVariantForImage.Id);
            await RefreshVariants();
            StateHasChanged();
        }
        catch (ApiException ex) { variantImageError = ex.Message; }
        catch (Exception ex) { variantImageError = $"Failed to remove media: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private void StartMediaDescriptionEdit(Guid mediaId, string? currentDescription)
    {
        editingMediaId = mediaId;
        editingMediaDescription = currentDescription ?? "";
    }

    private void CancelMediaDescriptionEdit()
    {
        editingMediaId = null;
        editingMediaDescription = "";
    }

    private async Task SaveMediaDescription()
    {
        if (!editingMediaId.HasValue) return;
        try
        {
            var updated = await CatalogApi.UpdateMediaDescriptionAsync(editingMediaId.Value, editingMediaDescription);
            if (currentProductMedia != null)
            {
                var idx = currentProductMedia.FindIndex(m => m.Id == updated.Id);
                if (idx >= 0) currentProductMedia[idx] = updated;
            }
            if (currentVariantMedia != null)
            {
                var idx = currentVariantMedia.FindIndex(m => m.Id == updated.Id);
                if (idx >= 0) currentVariantMedia[idx] = updated;
            }
        }
        catch (ApiException ex) { errorMessage = ex.Message; }
        catch (Exception ex) { errorMessage = $"Failed to update description: {ex.Message}"; }
        finally { editingMediaId = null; editingMediaDescription = ""; }
    }
    
    private void ShowVariantImageUpload(CatalogProductVariantResponse variant)
    {
        selectedVariantForImage = variant;
        variantImageError = null;
        currentVariantMedia = null;
        showVariantImageModal = true;
        _ = Task.Run(async () =>
        {
            currentVariantMedia = await CatalogApi.GetVariantMediaAsync(variant.Id);
            await InvokeAsync(StateHasChanged);
        });
    }

    private void CloseVariantImageModal()
    {
        showVariantImageModal = false;
        selectedVariantForImage = null;
        variantImageError = null;
        currentVariantMedia = null;
        pendingVariantMediaDescription = "";
        editingMediaId = null;
        editingMediaDescription = "";
    }

    // ── Form models ───────────────────────────────────────────────────────────

    private class ProductFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(500)]
        public string? Name { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(4000)]
        public string? Description { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string? Brand { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(100)]
        public string? SKU { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.Range(0, 9999999999)]
        public decimal BasePrice { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(3)]
