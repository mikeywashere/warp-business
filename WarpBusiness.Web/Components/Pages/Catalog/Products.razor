    {
        public string? SKU { get; set; }
        public decimal? Price { get; set; }
        public int StockQuantity { get; set; }
    }

    // ── Product Options handlers ──────────────────────────────────────────────

    private async Task RefreshOptions()
    {
        if (selectedProduct is null) return;
        isLoadingOptions = true;
        try { selectedProductOptions = await CatalogApi.GetProductOptionsAsync(selectedProduct.Id); }
        catch (Exception ex) { optionError = $"Failed to load options: {ex.Message}"; }
        finally { isLoadingOptions = false; }
    }

    private void ShowAddOptionForm()
    {
        editingOptionId = null;
        optionFormName = "";
        optionFormIsVariantAxis = true;
        showAddOptionForm = true;
    }

    private void StartEditOption(ProductOptionDto opt)
    {
        showAddOptionForm = false;
        editingOptionId = opt.Id;
        optionFormName = opt.Name;
        optionFormIsVariantAxis = opt.IsVariantAxis;
    }

    private void CancelOptionEdit()
    {
        showAddOptionForm = false;
        editingOptionId = null;
        optionFormName = "";
        optionFormIsVariantAxis = true;
    }

    private async Task HandleOptionSubmit()
    {
        if (selectedProduct is null || string.IsNullOrWhiteSpace(optionFormName)) return;
        isSubmitting = true;
        optionError = null;
        try
        {
            if (editingOptionId.HasValue)
            {
                await CatalogApi.UpdateProductOptionAsync(selectedProduct.Id, editingOptionId.Value,
                    new UpdateProductOptionRequest(optionFormName.Trim(), IsVariantAxis: optionFormIsVariantAxis));
            }
            else
            {
                await CatalogApi.CreateProductOptionAsync(selectedProduct.Id,
                    new CreateProductOptionRequest(optionFormName.Trim(), IsVariantAxis: optionFormIsVariantAxis));
            }
            CancelOptionEdit();
            await RefreshOptions();
        }
        catch (ApiException ex) { optionError = ex.Message; }
        catch (Exception ex) { optionError = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private async Task DeleteOptionAsync(ProductOptionDto opt)
    {
        if (selectedProduct is null) return;
        isSubmitting = true;
        optionError = null;
        try
        {
            await CatalogApi.DeleteProductOptionAsync(selectedProduct.Id, opt.Id);
            await RefreshOptions();
        }
        catch (ApiException ex) { optionError = ex.Message; }
        catch (Exception ex) { optionError = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private void StartEditValue(Guid optionId, ProductOptionValueDto val)
    {
        addingValueForOptionId = null;
        editingValueOptionId = optionId;
        editingValueId = val.Id;
        valueFormValue = val.Value;
    }

    private void CancelValueEdit()
    {
        addingValueForOptionId = null;
        editingValueId = null;
        editingValueOptionId = null;
        valueFormValue = "";
    }

    private async Task HandleAddOptionValue(Guid optionId)
    {
        if (selectedProduct is null || string.IsNullOrWhiteSpace(valueFormValue)) return;
        isSubmitting = true;
        optionError = null;
        try
        {
            await CatalogApi.CreateProductOptionValueAsync(selectedProduct.Id, optionId,
                new CreateProductOptionValueRequest(valueFormValue.Trim()));
            CancelValueEdit();
            await RefreshOptions();
        }
        catch (ApiException ex) { optionError = ex.Message; }
        catch (Exception ex) { optionError = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private async Task HandleUpdateOptionValue(Guid optionId, Guid valueId)
    {
        if (selectedProduct is null || string.IsNullOrWhiteSpace(valueFormValue)) return;
        isSubmitting = true;
        optionError = null;
        try
        {
            await CatalogApi.UpdateProductOptionValueAsync(selectedProduct.Id, optionId, valueId,
                new UpdateProductOptionValueRequest(valueFormValue.Trim()));
            CancelValueEdit();
            await RefreshOptions();
        }
        catch (ApiException ex) { optionError = ex.Message; }
        catch (Exception ex) { optionError = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private async Task DeleteOptionValueAsync(Guid optionId, Guid valueId)
    {
        if (selectedProduct is null) return;
        isSubmitting = true;
        optionError = null;
        try
        {
            await CatalogApi.DeleteProductOptionValueAsync(selectedProduct.Id, optionId, valueId);
            await RefreshOptions();
        }
        catch (ApiException ex) { optionError = ex.Message; }
        catch (Exception ex) { optionError = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private async Task HandleGenerateVariants()
    {
        if (selectedProduct is null) return;
        isSubmitting = true;
        optionError = null;
        variantError = null;
        try
        {
            var created = await CatalogApi.GenerateVariantsAsync(selectedProduct.Id);
            await Task.WhenAll(RefreshVariants(), LoadProducts());
            if (created > 0)
                variantError = null; // clear any previous error; success is implicit from new rows
        }
        catch (ApiException ex) { variantError = ex.Message; }
        catch (Exception ex) { variantError = $"Unexpected error: {ex.Message}"; }
        finally { isSubmitting = false; }
    }

    private static string GetIconClass(string? icon) => icon switch
    {
        "Warning" => "bi-exclamation-triangle-fill",
        "Info" => "bi-info-circle-fill",
        "Note" => "bi-journal-text",
        "Caution" => "bi-exclamation-circle-fill",
        "Danger" => "bi-x-octagon-fill",
        "Prohibited" => "bi-slash-circle",
        "Flammable" => "bi-fire",
        "Chemical" => "bi-droplet-fill",
        "ElectricalHazard" => "bi-lightning-fill",
        "Recyclable" => "bi-recycle",
        "EcoFriendly" => "bi-leaf-fill",
        "FoodAllergen" => "bi-egg-fill",
        "Prop65" => "bi-exclamation-diamond-fill",
        "Compliance" => "bi-shield-check-fill",
        "Temperature" => "bi-thermometer-half",
        _ => ""
    };
}

