@page "/catalog/taxonomy"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using WarpBusiness.Web.Services
@inherits WarpBusiness.Web.Components.AuthenticatedComponentBase
@inject TaxonomyApiClient TaxonomyApi
@inject NavigationManager Navigation

<PageTitle>Catalog Taxonomy</PageTitle>

<h1 class="mb-4">Catalog Taxonomy</h1>

<AuthorizeView Context="authContext">
    <Authorized>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
            </div>
        }

        @if (isLoading)
        {
            <div class="d-flex justify-content-center my-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            @if (showFormModal)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">@(editingId.HasValue ? "Edit Taxonomy Node" : "Add Taxonomy Node")</h5>
                                <button type="button" class="btn-close" @onclick="CloseFormModal"></button>
                            </div>
                            <div class="modal-body">
                                <EditForm Model="formModel" OnValidSubmit="HandleSubmit" FormName="taxonomyNodeForm">
                                    <DataAnnotationsValidator />
                                    <ValidationSummary class="text-danger mb-3" />
                                    <div class="row g-3">
                                        <div class="col-12">
                                            <label class="form-label">Name <span class="text-danger">*</span></label>
                                            <InputText @bind-Value="formModel.Name" class="form-control" />
                                            <ValidationMessage For="() => formModel.Name" class="text-danger" />
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">Description</label>
                                            <InputTextArea @bind-Value="formModel.Description" class="form-control" rows="2" />
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label">Parent</label>
                                            <div class="form-control-plaintext text-muted">
                                                @(formModel.ParentNodeId.HasValue ? GetNodeName(formModel.ParentNodeId.Value) : "Root level")
                                            </div>
                                        </div>
                                        @if (editingId.HasValue)
                                        {
                                            <div class="col-12">
                                                <div class="form-check form-switch">
                                                    <InputCheckbox @bind-Value="formModel.IsActive" class="form-check-input" id="taxonomyActiveSwitch" />
                                                    <label class="form-check-label" for="taxonomyActiveSwitch">
                                                        @(formModel.IsActive ? "Active" : "Inactive")
                                                    </label>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    <div class="mt-3">
                                        <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                                            @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                            @(editingId.HasValue ? "Update Node" : "Create Node")
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary ms-2" @onclick="CloseFormModal">Cancel</button>
                                    </div>
                                </EditForm>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (showDeleteBranchModal && deleteBranchTarget is not null)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" style="color: var(--clr-accent);">Delete Branch</h5>
                                <button type="button" class="btn-close" @onclick="CloseDeleteBranchModal"></button>
                            </div>
                            <div class="modal-body">
                                @if (!string.IsNullOrEmpty(deleteBranchError))
                                {
                                    <div class="alert alert-danger">@deleteBranchError</div>
                                }
                                <p>Are you sure? This will delete <strong>@deleteBranchTarget.Name</strong> and all its children.</p>
                                <div class="form-check mt-3">
                                    <InputCheckbox @bind-Value="deleteBranchConfirmed" class="form-check-input" id="deleteBranchCheck" />
                                    <label class="form-check-label" for="deleteBranchCheck">
                                        I understand this is permanent
                                    </label>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-outline-secondary" @onclick="CloseDeleteBranchModal">Cancel</button>
                                <button type="button" class="btn btn-danger" @onclick="ConfirmDeleteBranch"
                                        disabled="@(!deleteBranchConfirmed || isSubmitting)">
                                    @if (isSubmitting) { <span class="spinner-border spinner-border-sm me-1" role="status"></span> }
                                    Delete Branch
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h5 class="mb-0">Taxonomy Nodes (@(nodes?.Count ?? 0))</h5>
                    <small class="text-muted">Ordered by materialized path for hierarchical display.</small>
                </div>
                <button class="btn btn-primary" @onclick="ShowAddRootModal">
                    <span class="bi bi-plus-lg me-1"></span> Add Root Node
                </button>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Node</th>
                            <th>Level</th>
                            <th>Source</th>
                            <th>Status</th>
                            <th style="width: 250px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (nodes is { Count: > 0 })
                        {
                            @foreach (var node in VisibleNodes)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center" style="padding-left: @(node.Level * 20)px;">
                                            @if (node.ChildCount > 0)
                                            {
                                                <button type="button" class="btn btn-sm btn-link p-0 me-2"
                                                        style="color: var(--clr-accent);" @onclick="() => ToggleNode(node)">
                                                    @(collapsedNodes.Contains(node.Id) ? "▶" : "▼")
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="me-4"></span>
                                            }
                                            <span>@node.Name</span>
                                        </div>
                                    </td>
                                    <td><span class="text-muted">L@node.Level</span></td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(node.SourceProvider))
                                        {
                                            <span class="badge bg-info text-dark" title="@node.SourceExternalId">@node.SourceProvider</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @(node.IsActive ? "bg-success" : "bg-secondary")">
                                            @(node.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm mt-2 btn-outline-info me-1" @onclick="() => ShowAddChildModal(node)">Add Child</button>
                                        <button class="btn btn-sm mt-2 btn-outline-primary me-1" @onclick="() => ShowEditModal(node)">Edit</button>
                                        <button class="btn btn-sm mt-2 btn-outline-danger"
                                                @onclick="() => ShowDeleteBranchModal(node)">
                                            Delete Branch
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">No taxonomy nodes defined yet.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1200;">
            @foreach (var toast in toastMessages)
            {
                <div class="toast show mb-2" role="alert" aria-live="polite">
                    <div class="toast-body rounded text-white"
                         style="background-color: @(toast.Type == "success" ? "#198754" : "#dc3545");">
                        @toast.Text
                    </div>
                </div>
            }
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-warning">
            <h4>Access Denied</h4>
            <p>You must be logged in. <a href="/login">Login</a></p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<TaxonomyNodeResponse>? nodes;
    private Dictionary<Guid, TaxonomyNodeResponse> nodeLookup = new();
    private bool isLoading = true;
    private bool isSubmitting;
    private bool showFormModal;
    private bool showDeleteBranchModal;
    private bool deleteBranchConfirmed;
    private TaxonomyNodeResponse? deleteBranchTarget;
    private string? deleteBranchError;
    private Guid? editingId;
    private string? errorMessage;
    private string? successMessage;
    private TaxonomyFormModel formModel = new();
    private readonly HashSet<Guid> collapsedNodes = new();
    private record ToastEntry(Guid Id, string Text, string Type);
    private readonly List<ToastEntry> toastMessages = [];

    private IEnumerable<TaxonomyNodeResponse> VisibleNodes =>
        nodes?
            .OrderBy(n => n.MaterializedPath)
            .Where(IsNodeVisible) ?? [];

    protected override async Task OnAuthenticatedInitializedAsync()
    {
        if (string.IsNullOrEmpty(TokenProvider.SelectedTenantId))
        {
            Navigation.NavigateTo("/select-tenant");
            return;
        }

        await LoadNodesAsync();
        isLoading = false;
    }

    private async Task LoadNodesAsync()
    {
        try
        {
            nodes = await TaxonomyApi.GetTaxonomyTreeAsync();
            nodeLookup = nodes.ToDictionary(n => n.Id);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load taxonomy: {ex.Message}";
        }
    }

    private string GetNodeName(Guid nodeId) =>
        nodeLookup.TryGetValue(nodeId, out var node) ? node.Name : "Unknown node";

    private bool IsNodeVisible(TaxonomyNodeResponse node)
    {
        var parentId = node.ParentNodeId;
        while (parentId.HasValue)
        {
            if (collapsedNodes.Contains(parentId.Value)) return false;
            if (!nodeLookup.TryGetValue(parentId.Value, out var parent)) break;
            parentId = parent.ParentNodeId;
        }
        return true;
    }

    private void ToggleNode(TaxonomyNodeResponse node)
    {
        if (collapsedNodes.Contains(node.Id))
            collapsedNodes.Remove(node.Id);
        else
            collapsedNodes.Add(node.Id);
    }

    private void ShowAddRootModal()
    {
        formModel = new TaxonomyFormModel();
        editingId = null;
        showFormModal = true;
    }

    private void ShowAddChildModal(TaxonomyNodeResponse parent)
    {
        formModel = new TaxonomyFormModel { ParentNodeId = parent.Id };
        editingId = null;
        showFormModal = true;
    }

    private void ShowEditModal(TaxonomyNodeResponse node)
    {
        formModel = new TaxonomyFormModel
        {
            Name = node.Name,
            Description = node.Description,
            IsActive = node.IsActive,
            ParentNodeId = node.ParentNodeId
        };
        editingId = node.Id;
        showFormModal = true;
    }

    private void CloseFormModal()
    {
        showFormModal = false;
        editingId = null;
        formModel = new TaxonomyFormModel();
    }

    private void ShowDeleteBranchModal(TaxonomyNodeResponse node)
    {
        deleteBranchTarget = node;
        deleteBranchConfirmed = false;
        deleteBranchError = null;
        showDeleteBranchModal = true;
    }

    private void CloseDeleteBranchModal()
    {
        deleteBranchTarget = null;
        deleteBranchConfirmed = false;
        deleteBranchError = null;
        showDeleteBranchModal = false;
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            if (editingId.HasValue)
            {
                await TaxonomyApi.UpdateTaxonomyNodeAsync(editingId.Value,
                    new UpdateTaxonomyNodeRequest(formModel.Name, formModel.Description, formModel.IsActive));
                successMessage = "Taxonomy node updated.";
            }
            else
            {
                await TaxonomyApi.CreateTaxonomyNodeAsync(
                    new CreateTaxonomyNodeRequest(formModel.Name!, formModel.ParentNodeId, formModel.Description));
                successMessage = "Taxonomy node created.";
            }

            CloseFormModal();
            await LoadNodesAsync();
        }
        catch (ApiException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task ConfirmDeleteBranch()
    {
        if (deleteBranchTarget is null || !deleteBranchConfirmed) return;

        isSubmitting = true;
        deleteBranchError = null;
        try
        {
            var result = await TaxonomyApi.DeleteBranchAsync(deleteBranchTarget.Id, cascade: true);
            if (result.Success)
            {
                RemoveNodeAndDescendants(deleteBranchTarget.Id);
                CloseDeleteBranchModal();
                _ = ShowToastAsync("Branch deleted.");
            }
            else if (result.ConflictingNodeIds != null)
            {
                deleteBranchError = "Cannot delete — some nodes in this branch are used in the catalog. Remove catalog references first.";
            }
            else
            {
                deleteBranchError = string.IsNullOrWhiteSpace(result.ErrorMessage)
                    ? "Failed to delete branch."
                    : result.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            deleteBranchError = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void RemoveNodeAndDescendants(Guid nodeId)
    {
        if (nodes == null) return;
        var toRemove = new HashSet<Guid>();
        CollectDescendants(nodeId, nodes, toRemove);
        nodes = nodes.Where(n => !toRemove.Contains(n.Id)).ToList();
        nodeLookup = nodes.ToDictionary(n => n.Id);
        collapsedNodes.RemoveWhere(id => toRemove.Contains(id));
    }

    private static void CollectDescendants(Guid nodeId, List<TaxonomyNodeResponse> allNodes, HashSet<Guid> collected)
    {
        collected.Add(nodeId);
        foreach (var child in allNodes.Where(n => n.ParentNodeId == nodeId))
            CollectDescendants(child.Id, allNodes, collected);
    }

    private async Task ShowToastAsync(string text, string type = "success")
    {
        var toast = new ToastEntry(Guid.NewGuid(), text, type);
        toastMessages.Add(toast);
        await InvokeAsync(StateHasChanged);
        await Task.Delay(4000);
        toastMessages.Remove(toast);
        await InvokeAsync(StateHasChanged);
    }

    private class TaxonomyFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string? Name { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(1000)]
        public string? Description { get; set; }

        public Guid? ParentNodeId { get; set; }
        public bool IsActive { get; set; } = true;
    }
}
