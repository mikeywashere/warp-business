@page "/not-found"
@layout MainLayout

<PageTitle>Not Found — Warp Business</PageTitle>

<div class="container py-5">
    <div class="text-center">
        <div style="font-size: 4rem; margin-bottom: 1rem;">🚀</div>
        <h1 style="font-family: var(--font-heading, 'Orbitron', sans-serif); color: var(--clr-accent, #00c8ff);">404 — Lost in Space</h1>
