@page "/users"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using WarpBusiness.Web.Services
@inherits WarpBusiness.Web.Components.AuthenticatedComponentBase
@inject UserApiClient UserApi

<PageTitle>User Management</PageTitle>

<h1 class="mb-4">User Management</h1>

<AuthorizeView>
    <Authorized Context="authContext">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
            </div>
        }

        @if (isLoading)
        {
            <div class="d-flex justify-content-center my-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            @* Add / Edit Form *@
            @if (showForm)
            {
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">@(editingUserId.HasValue ? "Edit User" : "Add User")</h5>
                    </div>
                    <div class="card-body">
                        <EditForm Model="formModel" OnValidSubmit="HandleFormSubmit" FormName="userForm">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="text-danger mb-3" />

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">First Name</label>
                                    <InputText @bind-Value="formModel.FirstName" class="form-control" />
                                    <ValidationMessage For="() => formModel.FirstName" class="text-danger" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Last Name</label>
                                    <InputText @bind-Value="formModel.LastName" class="form-control" />
                                    <ValidationMessage For="() => formModel.LastName" class="text-danger" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Email</label>
                                    <InputText @bind-Value="formModel.Email" class="form-control" type="email" />
                                    <ValidationMessage For="() => formModel.Email" class="text-danger" />
                                </div>
                                @if (!editingUserId.HasValue)
                                {
                                    <div class="col-md-6">
                                        <label class="form-label">Password</label>
                                        <InputText @bind-Value="formModel.Password" class="form-control" type="password" />
                                        <ValidationMessage For="() => formModel.Password" class="text-danger" />
                                        <small class="text-muted d-block mt-1">
                                            Must be at least 8 characters with uppercase, lowercase, digit, and special character.
                                        </small>
                                        @if (!string.IsNullOrEmpty(formModel.Password))
                                        {
                                            <ul class="list-unstyled mt-1 mb-0 small">
                                                <li class="@(formModel.Password.Length >= 8 ? "text-success" : "text-danger")">
                                                    @(formModel.Password.Length >= 8 ? "✓" : "✗") At least 8 characters
                                                </li>
                                                <li class="@(formModel.Password.Any(char.IsUpper) ? "text-success" : "text-danger")">
                                                    @(formModel.Password.Any(char.IsUpper) ? "✓" : "✗") Uppercase letter
                                                </li>
                                                <li class="@(formModel.Password.Any(char.IsLower) ? "text-success" : "text-danger")">
                                                    @(formModel.Password.Any(char.IsLower) ? "✓" : "✗") Lowercase letter
                                                </li>
                                                <li class="@(formModel.Password.Any(char.IsDigit) ? "text-success" : "text-danger")">
                                                    @(formModel.Password.Any(char.IsDigit) ? "✓" : "✗") Digit
                                                </li>
                                                <li class="@(formModel.Password.Any(c => !char.IsLetterOrDigit(c)) ? "text-success" : "text-danger")">
                                                    @(formModel.Password.Any(c => !char.IsLetterOrDigit(c)) ? "✓" : "✗") Special character
                                                </li>
                                            </ul>
                                        }
                                    </div>
                                }
                                <div class="col-md-6">
                                    <label class="form-label">Role</label>
                                    <InputSelect @bind-Value="formModel.RoleName" class="form-select">
                                        <option value="">-- Select Role --</option>
                                        <option value="SystemAdministrator">System Administrator</option>
                                        <option value="User">User</option>
                                    </InputSelect>
                                    <ValidationMessage For="() => formModel.RoleName" class="text-danger" />
                                </div>
                            </div>

                            <div class="mt-3">
                                <button type="submit" class="btn btn-primary" disabled="@(isSubmitting || (!editingUserId.HasValue && !IsPasswordValid()))">
                                    @if (isSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    }
                                    @(editingUserId.HasValue ? "Update User" : "Create User")
                                </button>
                                <button type="button" class="btn btn-outline-secondary ms-2" @onclick="CancelForm">Cancel</button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            }

            @* Users Table *@
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Users (@(users?.Count ?? 0))</h5>
                @if (!showForm)
                {
                    <button class="btn btn-primary" @onclick="ShowAddForm">
                        <span class="bi bi-plus-lg me-1"></span> Add User
                    </button>
                }
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Created</th>
                            <th style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (users is { Count: > 0 })
                        {
                            @foreach (var user in users)
                            {
                                <tr>
                                    <td>@user.FirstName @user.LastName</td>
                                    <td>@user.Email</td>
                                    <td>
                                        <span class="badge @(user.RoleName == "SystemAdministrator" ? "bg-warning text-dark" : "bg-info")">
                                            @FormatRoleName(user.RoleName)
                                        </span>
                                    </td>
                                    <td>@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ShowEditForm(user)" title="Edit">
                                            Edit
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(user)" title="Delete">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">No users found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Delete Confirmation Modal *@
            @if (showDeleteConfirm && deletingUser != null)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Confirm Delete</h5>
                                <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                            </div>
                            <div class="modal-body">
                                <p>Are you sure you want to delete <strong>@deletingUser.FirstName @deletingUser.LastName</strong> (@deletingUser.Email)?</p>
                                <p class="text-danger mb-0">This action cannot be undone.</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                                <button type="button" class="btn btn-danger" @onclick="ExecuteDelete" disabled="@isSubmitting">
                                    @if (isSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    }
                                    Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-warning">
            <h4>Access Denied</h4>
            <p>You must be logged in to access user management. <a href="/login">Login</a></p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<UserResponse>? users;
    private bool isLoading = true;
    private bool isSubmitting;
    private bool showForm;
    private bool showDeleteConfirm;
    private Guid? editingUserId;
    private UserResponse? deletingUser;
    private string? errorMessage;
    private string? successMessage;
    private UserFormModel formModel = new();

    protected override async Task OnAuthenticatedInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        isLoading = true;
        try
        {
            users = await UserApi.GetUsersAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load users: {ex.Message}";
            users = [];
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowAddForm()
    {
        editingUserId = null;
        formModel = new UserFormModel();
        showForm = true;
        ClearMessages();
    }

    private void ShowEditForm(UserResponse user)
    {
        editingUserId = user.Id;
        formModel = new UserFormModel
        {
            FirstName = user.FirstName,
            LastName = user.LastName,
            Email = user.Email,
            RoleName = user.RoleName
        };
        showForm = true;
        ClearMessages();
    }

    private void CancelForm()
    {
        showForm = false;
        editingUserId = null;
        formModel = new UserFormModel();
    }

    private async Task HandleFormSubmit()
    {
        // Double-check password validation for new users
        if (!editingUserId.HasValue && !IsPasswordValid())
        {
            errorMessage = "Password does not meet the required policy. Please check the password requirements.";
            return;
        }

        isSubmitting = true;
        ClearMessages();

        try
        {
            if (editingUserId.HasValue)
            {
                await UserApi.UpdateUserAsync(editingUserId.Value, new UpdateUserRequest(
                    formModel.FirstName,
                    formModel.LastName,
                    formModel.Email,
                    formModel.RoleName));
                successMessage = "User updated successfully.";
            }
            else
            {
                await UserApi.CreateUserAsync(new CreateUserRequest(
                    formModel.FirstName,
                    formModel.LastName,
                    formModel.Email,
                    formModel.Password,
                    formModel.RoleName));
                successMessage = "User created successfully.";
            }

            showForm = false;
            editingUserId = null;
            formModel = new UserFormModel();
            await LoadUsers();
        }
        catch (ApiException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = $"Operation failed: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void ConfirmDelete(UserResponse user)
    {
        deletingUser = user;
        showDeleteConfirm = true;
        ClearMessages();
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        deletingUser = null;
    }

    private async Task ExecuteDelete()
    {
        if (deletingUser == null) return;

        isSubmitting = true;
        try
        {
            await UserApi.DeleteUserAsync(deletingUser.Id);
            successMessage = $"User {deletingUser.FirstName} {deletingUser.LastName} deleted.";
            showDeleteConfirm = false;
            deletingUser = null;
            await LoadUsers();
        }
        catch (Exception ex)
        {
            errorMessage = $"Delete failed: {ex.Message}";
            showDeleteConfirm = false;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private bool IsPasswordValid()
    {
        var p = formModel.Password;
        return !string.IsNullOrEmpty(p)
            && p.Length >= 8
            && p.Any(char.IsUpper)
            && p.Any(char.IsLower)
            && p.Any(char.IsDigit)
            && p.Any(c => !char.IsLetterOrDigit(c));
    }

    private void ClearMessages()
    {
        errorMessage = null;
        successMessage = null;
    }

    private static string FormatRoleName(string roleName) =>
        roleName == "SystemAdministrator" ? "System Administrator" : roleName;

    public class UserFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string FirstName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        public string LastName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = "";

        public string Password { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        public string RoleName { get; set; } = "";
    }
}
