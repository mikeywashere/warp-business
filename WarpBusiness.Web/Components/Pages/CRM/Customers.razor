@page "/crm/customers"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using WarpBusiness.Web.Services
@inherits WarpBusiness.Web.Components.AuthenticatedComponentBase
@inject CrmApiClient CrmApi
@inject NavigationManager Navigation

<PageTitle>Customer Management</PageTitle>

<h1 class="mb-4">Customer Management</h1>

<AuthorizeView>
    <Authorized Context="authContext">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
            </div>
        }

        @if (isLoading)
        {
            <div class="d-flex justify-content-center my-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            @* Add / Edit Customer Modal *@
            @if (showFormModal)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">@(editingCustomerId.HasValue ? "Edit Customer" : "Add Customer")</h5>
                                <button type="button" class="btn-close" @onclick="CloseFormModal"></button>
                            </div>
                            <div class="modal-body">
                                <EditForm Model="formModel" OnValidSubmit="HandleFormSubmit" FormName="customerForm">
                                    <DataAnnotationsValidator />
                                    <ValidationSummary class="text-danger mb-3" />

                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label">Name <span class="text-danger">*</span></label>
                                            <InputText @bind-Value="formModel.Name" class="form-control" />
                                            <ValidationMessage For="() => formModel.Name" class="text-danger" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Email <span class="text-danger">*</span></label>
                                            <InputText @bind-Value="formModel.Email" class="form-control" type="email" />
                                            <ValidationMessage For="() => formModel.Email" class="text-danger" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Phone</label>
                                            <InputText @bind-Value="formModel.Phone" class="form-control" type="tel" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Website</label>
                                            <InputText @bind-Value="formModel.Website" class="form-control" type="url" />
                                        </div>
                                        <div class="col-md-12">
                                            <label class="form-label">Address</label>
                                            <InputText @bind-Value="formModel.Address" class="form-control" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label">City</label>
                                            <InputText @bind-Value="formModel.City" class="form-control" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label">State</label>
                                            <InputText @bind-Value="formModel.State" class="form-control" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label">Postal Code</label>
                                            <InputText @bind-Value="formModel.PostalCode" class="form-control" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Country</label>
                                            <InputText @bind-Value="formModel.Country" class="form-control" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Industry</label>
                                            <InputText @bind-Value="formModel.Industry" class="form-control" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Company Size</label>
                                            <InputSelect @bind-Value="formModel.CompanySize" class="form-select">
                                                <option value="">-- Select Size --</option>
                                                <option value="1-10">1-10</option>
                                                <option value="11-50">11-50</option>
                                                <option value="51-200">51-200</option>
                                                <option value="201-500">201-500</option>
                                                <option value="501+">501+</option>
                                            </InputSelect>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Currency <span class="text-danger">*</span></label>
                                            <InputSelect @bind-Value="formModel.Currency" class="form-select">
                                                <option value="USD">USD - US Dollar</option>
                                                <option value="EUR">EUR - Euro</option>
                                                <option value="GBP">GBP - British Pound</option>
                                                <option value="CAD">CAD - Canadian Dollar</option>
                                                <option value="AUD">AUD - Australian Dollar</option>
                                                <option value="JPY">JPY - Japanese Yen</option>
                                                <option value="CHF">CHF - Swiss Franc</option>
                                                <option value="CNY">CNY - Chinese Yuan</option>
                                                <option value="INR">INR - Indian Rupee</option>
                                            </InputSelect>
                                            <ValidationMessage For="() => formModel.Currency" class="text-danger" />
                                        </div>
                                        <div class="col-md-12">
                                            <label class="form-label">Notes</label>
                                            <InputTextArea @bind-Value="formModel.Notes" class="form-control" rows="3" />
                                        </div>
                                    </div>

                                    <div class="mt-3">
                                        <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                                            @if (isSubmitting)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                            }
                                            @(editingCustomerId.HasValue ? "Update Customer" : "Create Customer")
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary ms-2" @onclick="CloseFormModal">Cancel</button>
                                    </div>
                                </EditForm>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* Customer List *@
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Customers (@(FilteredCustomers.Count)@(!string.IsNullOrWhiteSpace(searchTerm) ? $" of {customers?.Count ?? 0}" : ""))</h5>
                <button class="btn btn-primary" @onclick="ShowAddModal">
                    <span class="bi bi-plus-lg me-1"></span> Add Customer
                </button>
            </div>

            @* Search/Filter *@
            <div class="mb-3">
                <input type="text" class="form-control" placeholder="Search by name or email..." 
                       @bind="searchTerm" @bind:event="oninput" />
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Industry</th>
                            <th>Company Size</th>
                            <th>Currency</th>
                            <th>Status</th>
                            <th style="width: 250px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (FilteredCustomers is { Count: > 0 })
                        {
                            @foreach (var customer in FilteredCustomers)
                            {
                                <tr>
                                    <td>@customer.Name</td>
                                    <td>@customer.Email</td>
                                    <td>@(customer.Phone ?? "—")</td>
                                    <td>@(customer.Industry ?? "—")</td>
                                    <td>@(customer.CompanySize ?? "—")</td>
                                    <td><code>@customer.Currency</code></td>
                                    <td>
                                        <span class="badge @(customer.IsActive ? "bg-success" : "bg-secondary")">
                                            @(customer.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm mt-2 btn-outline-primary me-1" @onclick="() => ShowEditModal(customer)" title="Edit">
                                            Edit
                                        </button>
                                        <button class="btn btn-sm mt-2 btn-outline-info me-1" @onclick="() => ViewDetails(customer.Id)" title="View Details">
                                            Details
                                        </button>
                                        @if (customer.IsActive)
                                        {
                                            <button class="btn btn-sm mt-2 btn-outline-warning" @onclick="() => ConfirmDeactivate(customer)" title="Deactivate">
                                                Deactivate
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm mt-2 btn-outline-success" @onclick="() => ConfirmActivate(customer)" title="Activate">
                                                Activate
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    @(string.IsNullOrWhiteSpace(searchTerm) ? "No customers found." : "No customers match your search.")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Deactivate/Activate Confirmation Modal *@
            @if (showStatusConfirm && statusChangeCustomer != null)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Confirm @(statusChangeCustomer.IsActive ? "Deactivate" : "Activate")</h5>
                                <button type="button" class="btn-close" @onclick="CancelStatusChange"></button>
                            </div>
                            <div class="modal-body">
                                <p>Are you sure you want to @(statusChangeCustomer.IsActive ? "deactivate" : "activate") <strong>@statusChangeCustomer.Name</strong>?</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" @onclick="CancelStatusChange">Cancel</button>
                                <button type="button" class="btn @(statusChangeCustomer.IsActive ? "btn-warning" : "btn-success")" 
                                        @onclick="ExecuteStatusChange" disabled="@isSubmitting">
                                    @if (isSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    }
                                    @(statusChangeCustomer.IsActive ? "Deactivate" : "Activate")
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-warning">
            <h4>Access Denied</h4>
            <p>You must be logged in to access customer management. <a href="/login">Login</a></p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<CustomerResponse>? customers;
    private bool isLoading = true;
    private bool isSubmitting;
    private bool showFormModal;
    private bool showStatusConfirm;
    private Guid? editingCustomerId;
    private CustomerResponse? statusChangeCustomer;
    private string? errorMessage;
    private string? successMessage;
    private string searchTerm = "";
    private CustomerFormModel formModel = new();

    private List<CustomerResponse> FilteredCustomers =>
        customers?.Where(c =>
            string.IsNullOrWhiteSpace(searchTerm) ||
            c.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            c.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
        ).ToList() ?? [];

    protected override async Task OnAuthenticatedInitializedAsync()
    {
        // Ensure user has selected a tenant before loading customers
        if (string.IsNullOrEmpty(TokenProvider.SelectedTenantId))
        {
            Navigation.NavigateTo("/select-tenant");
            return;
        }
        
        await LoadCustomers();
    }

    private async Task LoadCustomers()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            customers = await CrmApi.GetCustomersAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load customers: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowAddModal()
    {
        formModel = new CustomerFormModel { Currency = "USD" }; // Default to USD
        editingCustomerId = null;
        showFormModal = true;
    }

    private void ShowEditModal(CustomerResponse customer)
    {
        formModel = new CustomerFormModel
        {
            Name = customer.Name,
            Email = customer.Email,
            Phone = customer.Phone,
            Address = customer.Address,
            City = customer.City,
            State = customer.State,
            PostalCode = customer.PostalCode,
            Country = customer.Country,
            Website = customer.Website,
            Industry = customer.Industry,
            CompanySize = customer.CompanySize,
            Notes = customer.Notes,
            Currency = customer.Currency
        };
        editingCustomerId = customer.Id;
        showFormModal = true;
    }

    private void CloseFormModal()
    {
        showFormModal = false;
        formModel = new CustomerFormModel();
        editingCustomerId = null;
    }

    private async Task HandleFormSubmit()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            if (editingCustomerId.HasValue)
            {
                var updateRequest = new UpdateCustomerRequest(
                    formModel.Name!,
                    formModel.Email!,
                    formModel.Phone,
                    formModel.Address,
                    formModel.City,
                    formModel.State,
                    formModel.PostalCode,
                    formModel.Country,
                    formModel.Website,
                    formModel.Industry,
                    formModel.CompanySize,
                    formModel.Notes,
                    formModel.Currency!);
                await CrmApi.UpdateCustomerAsync(editingCustomerId.Value, updateRequest);
                successMessage = "Customer updated successfully.";
            }
            else
            {
                var createRequest = new CreateCustomerRequest(
                    formModel.Name!,
                    formModel.Email!,
                    formModel.Phone,
                    formModel.Address,
                    formModel.City,
                    formModel.State,
                    formModel.PostalCode,
                    formModel.Country,
                    formModel.Website,
                    formModel.Industry,
                    formModel.CompanySize,
                    formModel.Notes,
                    formModel.Currency!);
                await CrmApi.CreateCustomerAsync(createRequest);
                successMessage = "Customer created successfully.";
            }
            CloseFormModal();
            await LoadCustomers();
        }
        catch (ApiException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void ConfirmDeactivate(CustomerResponse customer)
    {
        statusChangeCustomer = customer;
        showStatusConfirm = true;
    }

    private void ConfirmActivate(CustomerResponse customer)
    {
        statusChangeCustomer = customer;
        showStatusConfirm = true;
    }

    private void CancelStatusChange()
    {
        showStatusConfirm = false;
        statusChangeCustomer = null;
    }

    private async Task ExecuteStatusChange()
    {
        if (statusChangeCustomer == null) return;

        isSubmitting = true;
        errorMessage = null;
        successMessage = null;
        try
        {
            if (statusChangeCustomer.IsActive)
            {
                await CrmApi.DeactivateCustomerAsync(statusChangeCustomer.Id);
                successMessage = "Customer deactivated successfully.";
            }
            else
            {
                await CrmApi.ActivateCustomerAsync(statusChangeCustomer.Id);
                successMessage = "Customer activated successfully.";
            }
            CancelStatusChange();
            await LoadCustomers();
        }
        catch (ApiException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void ViewDetails(Guid customerId)
    {
        Navigation.NavigateTo($"/crm/customers/{customerId}");
    }

    private class CustomerFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string? Name { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string? Email { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(50)]
        public string? Phone { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(500)]
        public string? Address { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(100)]
        public string? City { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(100)]
        public string? State { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(20)]
        public string? PostalCode { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(100)]
        public string? Country { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(200)]
        public string? Website { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(100)]
        public string? Industry { get; set; }

        [System.ComponentModel.DataAnnotations.MaxLength(20)]
        public string? CompanySize { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(3)]
        public string? Currency { get; set; } = "USD";

        [System.ComponentModel.DataAnnotations.MaxLength(2000)]
        public string? Notes { get; set; }
    }
}
