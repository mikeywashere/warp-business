@page "/scheduling/locations"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using WarpBusiness.Web.Services
@inherits WarpBusiness.Web.Components.AuthenticatedComponentBase
@inject SchedulingApiClient SchedulingApi

<PageTitle>Work Locations</PageTitle>

<h1 class="mb-4">Work Locations</h1>

<AuthorizeView Context="authContext">
    <Authorized>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
            </div>
        }

        @if (isLoading)
        {
            <div class="d-flex justify-content-center my-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            @if (showForm)
            {
                <div class="card mb-4">
                    <div class="card-header">@(editingId.HasValue ? "Edit Work Location" : "Add Work Location")</div>
                    <div class="card-body">
                        <EditForm Model="formModel" OnValidSubmit="SaveLocation" Context="editFormContext">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Name *</label>
                                    <InputText class="form-control" @bind-Value="formModel.Name" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Address</label>
                                    <InputText class="form-control" @bind-Value="formModel.Address" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">City</label>
                                    <InputText class="form-control" @bind-Value="formModel.City" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">State *</label>
                                    <InputText class="form-control" maxlength="2" @bind-Value="formModel.State" placeholder="WA" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Country</label>
                                    <InputText class="form-control" @bind-Value="formModel.Country" />
                                </div>
                                @if (editingId.HasValue)
                                {
                                    <div class="col-md-3">
                                        <label class="form-label">Active</label>
                                        <div class="form-check mt-1">
                                            <InputCheckbox class="form-check-input" @bind-Value="formModel.IsActive" />
                                            <label class="form-check-label">Active</label>
                                        </div>
                                    </div>
                                }
                            </div>
                            <div class="mt-3 d-flex gap-2">
                                <button type="submit" class="btn btn-primary" disabled="@isSaving">
                                    @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    Save
                                </button>
                                <button type="button" class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            }

            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted">@locations.Count location(s)</span>
                @if (!showForm)
                {
                    <button class="btn btn-primary btn-sm" @onclick="ShowAddForm">+ Add Location</button>
                }
            </div>

            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Address</th>
                        <th>City</th>
                        <th>State</th>
                        <th>Status</th>
                        <th style="width: 250px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var loc in locations)
                    {
                        <tr>
                            <td>@loc.Name</td>
                            <td>@loc.Address</td>
                            <td>@loc.City</td>
                            <td><span class="badge bg-secondary">@loc.State</span></td>
                            <td>
                                @if (loc.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditLocation(loc)">Edit</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteLocation(loc.Id)">Delete</button>
                            </td>
                        </tr>
                    }
                    @if (locations.Count == 0)
                    {
                        <tr><td colspan="6" class="text-center text-muted py-4">No work locations yet. Add one above.</td></tr>
                    }
                </tbody>
            </table>
        }
    </Authorized>
</AuthorizeView>

@code {
    private List<WorkLocationResponse> locations = [];
    private bool isLoading = true;
    private bool showForm = false;
    private bool isSaving = false;
    private string? errorMessage;
    private string? successMessage;
    private Guid? editingId;

    private LocationFormModel formModel = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);
        if (firstRender)
        {
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            StateHasChanged();
            locations = await SchedulingApi.GetLocationsAsync() ?? [];
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load locations: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void ShowAddForm()
    {
        editingId = null;
        formModel = new();
        showForm = true;
    }

    private void EditLocation(WorkLocationResponse loc)
    {
        editingId = loc.Id;
        formModel = new() { Name = loc.Name, Address = loc.Address, City = loc.City, State = loc.State, Country = loc.Country, IsActive = loc.IsActive };
        showForm = true;
    }

    private void CancelForm()
    {
        showForm = false;
        editingId = null;
        formModel = new();
    }

    private async Task SaveLocation()
    {
        try
        {
            isSaving = true;
            if (editingId.HasValue)
            {
                await SchedulingApi.UpdateLocationAsync(editingId.Value, new UpdateWorkLocationRequest(formModel.Name!, formModel.Address, formModel.City, formModel.State!, formModel.Country, formModel.IsActive));
                successMessage = "Location updated.";
            }
            else
            {
                await SchedulingApi.CreateLocationAsync(new CreateWorkLocationRequest(formModel.Name!, formModel.Address, formModel.City, formModel.State!, formModel.Country));
                successMessage = "Location created.";
            }
            showForm = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to save: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteLocation(Guid id)
    {
        try
        {
            errorMessage = null;
            await SchedulingApi.DeleteLocationAsync(id);
            successMessage = "Location deleted.";
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to delete: {ex.Message}";
        }
    }

    private class LocationFormModel
    {
        public string? Name { get; set; }
        public string? Address { get; set; }
        public string? City { get; set; }
        public string? State { get; set; }
        public string? Country { get; set; }
        public bool IsActive { get; set; } = true;
    }
}
