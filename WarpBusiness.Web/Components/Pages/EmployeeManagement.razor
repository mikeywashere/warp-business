@page "/employees"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@using WarpBusiness.Web.Services
@inherits WarpBusiness.Web.Components.AuthenticatedComponentBase
@inject EmployeeApiClient EmployeeApi
@inject NavigationManager Navigation

<PageTitle>Employee Management</PageTitle>

<h1 class="mb-4">Employee Management</h1>

<style>
    .chevron-toggle {
        display: inline-block;
        transition: transform 0.2s ease;
        cursor: pointer;
    }
    .chevron-toggle.expanded {
        transform: rotate(90deg);
    }
    .user-dropdown-list {
        z-index: 1050;
        max-height: 200px;
        overflow-y: auto;
    }
</style>

<AuthorizeView>
    <Authorized Context="authContext">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
            </div>
        }

        @if (isLoading)
        {
            <div class="d-flex justify-content-center my-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            @* Add / Edit Form *@
            @if (showForm)
            {
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">@(editingEmployeeId.HasValue ? "Edit Employee" : "Add Employee")</h5>
                    </div>
                    <div class="card-body">
                        <EditForm Model="formModel" OnValidSubmit="HandleFormSubmit" FormName="employeeForm">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="text-danger mb-3" />

                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label">First Name <span class="text-danger">*</span></label>
                                    <InputText @bind-Value="formModel.FirstName" class="form-control" />
                                    <ValidationMessage For="() => formModel.FirstName" class="text-danger" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Middle Name</label>
                                    <InputText @bind-Value="formModel.MiddleName" class="form-control" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Last Name <span class="text-danger">*</span></label>
                                    <InputText @bind-Value="formModel.LastName" class="form-control" />
                                    <ValidationMessage For="() => formModel.LastName" class="text-danger" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Email <span class="text-danger">*</span></label>
                                    <InputText @bind-Value="formModel.Email" class="form-control" type="email"
                                               @bind-Value:after="OnEmployeeEmailChanged" />
                                    <ValidationMessage For="() => formModel.Email" class="text-danger" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Phone</label>
                                    <InputText @bind-Value="formModel.Phone" class="form-control" type="tel" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Date of Birth</label>
                                    <InputDate @bind-Value="formModel.DateOfBirth" class="form-control" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Hire Date <span class="text-danger">*</span></label>
                                    <InputDate @bind-Value="formModel.HireDate" class="form-control" />
                                    <ValidationMessage For="() => formModel.HireDate" class="text-danger" />
                                </div>
                                @if (editingEmployeeId.HasValue)
                                {
                                    <div class="col-md-4">
                                        <label class="form-label">Termination Date</label>
                                        <InputDate @bind-Value="formModel.TerminationDate" class="form-control" />
                                    </div>
                                }
                                <div class="col-md-6">
                                    <label class="form-label">Department</label>
                                    <InputText @bind-Value="formModel.Department" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Job Title</label>
                                    <InputText @bind-Value="formModel.JobTitle" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Employment Status <span class="text-danger">*</span></label>
                                    <InputSelect @bind-Value="formModel.EmploymentStatus" class="form-select">
                                        <option value="">-- Select Status --</option>
                                        <option value="Active">Active</option>
                                        <option value="OnLeave">On Leave</option>
                                        <option value="Terminated">Terminated</option>
                                        <option value="Suspended">Suspended</option>
                                    </InputSelect>
                                    <ValidationMessage For="() => formModel.EmploymentStatus" class="text-danger" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Employment Type <span class="text-danger">*</span></label>
                                    <InputSelect @bind-Value="formModel.EmploymentType" class="form-select">
                                        <option value="">-- Select Type --</option>
                                        <option value="FullTime">Full Time</option>
                                        <option value="PartTime">Part Time</option>
                                        <option value="Contract">Contract</option>
                                        <option value="Intern">Intern</option>
                                    </InputSelect>
                                    <ValidationMessage For="() => formModel.EmploymentType" class="text-danger" />
                                </div>
                            </div>

                            @* User Account Section *@
                            @if (editingEmployeeId.HasValue && editingEmployeeHasUser)
                            {
                                @* Combined edit: show role for linked user *@
                                <hr class="my-4" />
                                <h6 class="text-muted mb-3">Linked User Account</h6>
                                <div class="alert alert-info py-2 mb-3">
                                    <small>Changes to name and email will update both the employee record and user account.</small>
                                </div>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Role</label>
                                        <InputSelect @bind-Value="formModel.UserRole" class="form-select">
                                            <option value="User">User</option>
                                            <option value="SystemAdministrator">System Administrator</option>
                                        </InputSelect>
                                    </div>
                                </div>
                            }
                            else if (!editingEmployeeId.HasValue)
                            {
                                @* Add mode: user account section *@
                                <hr class="my-4" />
                                <h6 class="text-muted mb-3">User Account (Optional)</h6>

                                @if (isLoadingUnlinkedUsers)
                                {
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                                        <span class="text-muted">Loading available users…</span>
                                    </div>
                                }
                                else
                                {
                                    @* Link to Existing User dropdown *@
                                    <div class="mb-3">
                                        <label class="form-label">Link to Existing User</label>
                                        <div class="position-relative">
                                            <div class="input-group">
                                                <input type="text" class="form-control"
                                                       placeholder="Search users to link..."
                                                       value="@userSearchText"
                                                       @onfocus="() => showUserDropdown = true"
                                                       @onblur="HandleUserSearchBlur"
                                                       @oninput="FilterUnlinkedUsers"
                                                       disabled="@formModel.CreateNewUser" />
                                                @if (formModel.LinkedUserId.HasValue)
                                                {
                                                    <button type="button" class="btn btn-outline-secondary" @onclick="ClearLinkedUser" title="Clear selection">✕</button>
                                                }
                                            </div>
                                            @if (showUserDropdown && filteredUnlinkedUsers.Count > 0 && !formModel.LinkedUserId.HasValue)
                                            {
                                                <ul class="list-group position-absolute w-100 shadow user-dropdown-list">
                                                    @foreach (var user in filteredUnlinkedUsers)
                                                    {
                                                        <li class="list-group-item list-group-item-action"
                                                            @onmousedown="() => SelectLinkedUser(user)"
                                                            @onmousedown:preventDefault>
                                                            @user.FirstName @user.LastName (@user.Email)
                                                        </li>
                                                    }
                                                </ul>
                                            }
                                            @if (formModel.LinkedUserId.HasValue)
                                            {
                                                <small class="text-success">✓ Will link to this user account</small>
                                            }
                                        </div>
                                    </div>

                                    @* Create New User Account expandable section *@
                                    <div class="mb-3">
                                        <div class="@(formModel.LinkedUserId.HasValue ? "text-muted" : "")"
                                             @onclick="ToggleCreateNewUser"
                                             style="cursor: @(formModel.LinkedUserId.HasValue ? "default" : "pointer");">
                                            <span class="chevron-toggle @(formModel.CreateNewUser ? "expanded" : "")">▶</span>
                                            <strong class="ms-1">Create New User Account</strong>
                                        </div>
                                        @if (formModel.CreateNewUser && !formModel.LinkedUserId.HasValue)
                                        {
                                            <div class="mt-2 ms-4">
                                                <div class="row g-3">
                                                    <div class="col-md-6">
                                                        <label class="form-label">Username</label>
                                                        <InputText @bind-Value="formModel.NewUserUsername" class="form-control" />
                                                        <small class="text-muted d-block mt-1">
                                                            Defaults to the local part of the email. Cannot be changed after creation.
                                                        </small>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label">Role</label>
                                                        <InputSelect @bind-Value="formModel.UserRole" class="form-select">
                                                            <option value="User">User</option>
                                                            <option value="SystemAdministrator">System Administrator</option>
                                                        </InputSelect>
                                                    </div>
                                                </div>
                                                <p class="text-muted small mt-2 mb-0">
                                                    A "set password" email will be sent to the employee's email address.
                                                </p>
                                            </div>
                                        }
                                    </div>
                                }
                            }

                            <div class="mt-3">
                                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                                    @if (isSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    }
                                    @(editingEmployeeId.HasValue ? "Update Employee" : "Create Employee")
                                </button>
                                <button type="button" class="btn btn-outline-secondary ms-2" @onclick="CancelForm">Cancel</button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            }

            @* Employees Table *@
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Employees (@(FilteredEmployees.Count)@(!string.IsNullOrWhiteSpace(employeeSearchTerm) ? $" of {employees?.Count ?? 0}" : ""))</h5>
                @if (!showForm)
                {
                    <button class="btn btn-primary" @onclick="ShowAddForm">
                        <span class="bi bi-plus-lg me-1"></span> Add Employee
                    </button>
                }
            </div>

            @* Search/Filter *@
            <div class="mb-3">
                <input type="text" class="form-control" placeholder="Search by name, email, employee #, department, or job title..."
                       @bind="employeeSearchTerm" @bind:event="oninput" />
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Employee #</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Department</th>
                            <th>Job Title</th>
                            <th>Status</th>
                            <th>Type</th>
                            <th>Hire Date</th>
                            <th>User Account</th>
                            <th style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (FilteredEmployees is { Count: > 0 })
                        {
                            @foreach (var emp in FilteredEmployees)
                            {
                                <tr>
                                    <td><code>@emp.EmployeeNumber</code></td>
                                    <td>@emp.FirstName @emp.LastName</td>
                                    <td>@emp.Email</td>
                                    <td>@(emp.Department ?? "—")</td>
                                    <td>@(emp.JobTitle ?? "—")</td>
                                    <td>
                                        <span class="badge @GetStatusBadgeClass(emp.EmploymentStatus)">
                                            @FormatStatus(emp.EmploymentStatus)
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">
                                            @FormatType(emp.EmploymentType)
                                        </span>
                                    </td>
                                    <td>@emp.HireDate.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        @if (emp.UserId.HasValue)
                                        {
                                            <span class="badge bg-primary">🔗 Linked</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ShowEditForm(emp)" title="Edit">
                                            Edit
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(emp)" title="Delete">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="10" class="text-center text-muted py-4">
                                    @(string.IsNullOrWhiteSpace(employeeSearchTerm) ? "No employees found." : "No employees match your search.")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Delete Confirmation Modal *@
            @if (showDeleteConfirm && deletingEmployee != null)
            {
                <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Confirm Delete</h5>
                                <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                            </div>
                            <div class="modal-body">
                                <p>Are you sure you want to delete <strong>@deletingEmployee.FirstName @deletingEmployee.LastName</strong> (@deletingEmployee.EmployeeNumber)?</p>
                                <p class="text-danger mb-0">This action cannot be undone.</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                                <button type="button" class="btn btn-danger" @onclick="ExecuteDelete" disabled="@isSubmitting">
                                    @if (isSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    }
                                    Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </Authorized>
    <NotAuthorized>
        <div class="alert alert-warning">
            <h4>Access Denied</h4>
            <p>You must be logged in to access employee management. <a href="/login">Login</a></p>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<EmployeeResponse>? employees;
    private bool isLoading = true;
    private bool isSubmitting;
    private bool showForm;
    private bool showDeleteConfirm;
    private Guid? editingEmployeeId;
    private bool editingEmployeeHasUser;
    private EmployeeResponse? deletingEmployee;
    private string? errorMessage;
    private string? successMessage;
    private string employeeSearchTerm = "";
    private EmployeeFormModel formModel = new();

    private List<EmployeeResponse> FilteredEmployees =>
        employees?.Where(e =>
            string.IsNullOrWhiteSpace(employeeSearchTerm) ||
            e.EmployeeNumber.Contains(employeeSearchTerm, StringComparison.OrdinalIgnoreCase) ||
            e.FirstName.Contains(employeeSearchTerm, StringComparison.OrdinalIgnoreCase) ||
            e.LastName.Contains(employeeSearchTerm, StringComparison.OrdinalIgnoreCase) ||
            e.Email.Contains(employeeSearchTerm, StringComparison.OrdinalIgnoreCase) ||
            (e.Department ?? "").Contains(employeeSearchTerm, StringComparison.OrdinalIgnoreCase) ||
            (e.JobTitle ?? "").Contains(employeeSearchTerm, StringComparison.OrdinalIgnoreCase)
        ).ToList() ?? [];

    // User linking state
    private List<UserResponse> unlinkedUsers = [];
    private List<UserResponse> filteredUnlinkedUsers = [];
    private string userSearchText = "";
    private bool showUserDropdown;
    private bool isLoadingUnlinkedUsers;

    [SupplyParameterFromQuery(Name = "edit")]
    public string? EditEmployeeId { get; set; }

    protected override async Task OnAuthenticatedInitializedAsync()
    {
        await LoadEmployees();

        // Support /employees?edit={id} deep link
        if (!string.IsNullOrEmpty(EditEmployeeId) && Guid.TryParse(EditEmployeeId, out var editId))
        {
            var emp = employees?.FirstOrDefault(e => e.Id == editId);
            if (emp != null)
            {
                ShowEditForm(emp);
            }
        }
    }

    private async Task LoadEmployees()
    {
        isLoading = true;
        try
        {
            employees = await EmployeeApi.GetEmployeesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load employees: {ex.Message}";
            employees = [];
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ShowAddForm()
    {
        editingEmployeeId = null;
        editingEmployeeHasUser = false;
        formModel = new EmployeeFormModel();
        showForm = true;
        ClearMessages();

        // Load unlinked users for the dropdown
        isLoadingUnlinkedUsers = true;
        StateHasChanged();
        try
        {
            unlinkedUsers = await EmployeeApi.GetUnlinkedUsersAsync();
            filteredUnlinkedUsers = unlinkedUsers;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load available users: {ex.Message}";
            unlinkedUsers = [];
            filteredUnlinkedUsers = [];
        }
        finally
        {
            isLoadingUnlinkedUsers = false;
        }
    }

    private void ShowEditForm(EmployeeResponse emp)
    {
        editingEmployeeId = emp.Id;
        editingEmployeeHasUser = emp.UserId.HasValue;
        formModel = new EmployeeFormModel
        {
            FirstName = emp.FirstName,
            LastName = emp.LastName,
            MiddleName = emp.MiddleName ?? "",
            Email = emp.Email,
            Phone = emp.Phone ?? "",
            DateOfBirth = emp.DateOfBirth,
            HireDate = emp.HireDate,
            TerminationDate = emp.TerminationDate,
            Department = emp.Department ?? "",
            JobTitle = emp.JobTitle ?? "",
            EmploymentStatus = emp.EmploymentStatus,
            EmploymentType = emp.EmploymentType,
            UserRole = "User"
        };
        showForm = true;
        ClearMessages();
    }

    private void CancelForm()
    {
        showForm = false;
        editingEmployeeId = null;
        editingEmployeeHasUser = false;
        formModel = new EmployeeFormModel();
        userSearchText = "";
        showUserDropdown = false;
    }

    private async Task HandleFormSubmit()
    {
        isSubmitting = true;
        ClearMessages();

        try
        {
            if (editingEmployeeId.HasValue)
            {
                if (editingEmployeeHasUser)
                {
                    // Combined update: employee + linked user
                    await EmployeeApi.UpdateEmployeeWithUserAsync(editingEmployeeId.Value, new UpdateEmployeeWithUserRequest(
                        formModel.FirstName,
                        formModel.LastName,
                        string.IsNullOrWhiteSpace(formModel.MiddleName) ? null : formModel.MiddleName,
                        formModel.Email,
                        string.IsNullOrWhiteSpace(formModel.Phone) ? null : formModel.Phone,
                        formModel.DateOfBirth,
                        formModel.HireDate,
                        formModel.TerminationDate,
                        string.IsNullOrWhiteSpace(formModel.Department) ? null : formModel.Department,
                        string.IsNullOrWhiteSpace(formModel.JobTitle) ? null : formModel.JobTitle,
                        null,
                        formModel.EmploymentStatus,
                        formModel.EmploymentType,
                        formModel.UserRole));
                    successMessage = "Employee and linked user account updated successfully.";
                }
                else
                {
                    await EmployeeApi.UpdateEmployeeAsync(editingEmployeeId.Value, new UpdateEmployeeRequest(
                        formModel.FirstName,
                        formModel.LastName,
                        string.IsNullOrWhiteSpace(formModel.MiddleName) ? null : formModel.MiddleName,
                        formModel.Email,
                        string.IsNullOrWhiteSpace(formModel.Phone) ? null : formModel.Phone,
                        formModel.DateOfBirth,
                        formModel.HireDate,
                        formModel.TerminationDate,
                        string.IsNullOrWhiteSpace(formModel.Department) ? null : formModel.Department,
                        string.IsNullOrWhiteSpace(formModel.JobTitle) ? null : formModel.JobTitle,
                        null,
                        formModel.EmploymentStatus,
                        formModel.EmploymentType,
                        null));
                    successMessage = "Employee updated successfully.";
                }
            }
            else
            {
                if (formModel.CreateNewUser)
                {
                    // Create employee with new user account
                    await EmployeeApi.CreateEmployeeWithUserAsync(new CreateEmployeeWithUserRequest(
                        formModel.FirstName,
                        formModel.LastName,
                        string.IsNullOrWhiteSpace(formModel.MiddleName) ? null : formModel.MiddleName,
                        formModel.Email,
                        string.IsNullOrWhiteSpace(formModel.Phone) ? null : formModel.Phone,
                        formModel.DateOfBirth,
                        formModel.HireDate,
                        string.IsNullOrWhiteSpace(formModel.Department) ? null : formModel.Department,
                        string.IsNullOrWhiteSpace(formModel.JobTitle) ? null : formModel.JobTitle,
                        null,
                        formModel.EmploymentStatus,
                        formModel.EmploymentType,
                        formModel.UserRole,
                        string.IsNullOrWhiteSpace(formModel.NewUserUsername) ? null : formModel.NewUserUsername));
                    successMessage = "Employee created with new user account. A 'set password' email will be sent.";
                }
                else
                {
                    // Create employee, optionally linked to existing user
                    await EmployeeApi.CreateEmployeeAsync(new CreateEmployeeRequest(
                        formModel.FirstName,
                        formModel.LastName,
                        string.IsNullOrWhiteSpace(formModel.MiddleName) ? null : formModel.MiddleName,
                        formModel.Email,
                        string.IsNullOrWhiteSpace(formModel.Phone) ? null : formModel.Phone,
                        formModel.DateOfBirth,
                        formModel.HireDate,
                        string.IsNullOrWhiteSpace(formModel.Department) ? null : formModel.Department,
                        string.IsNullOrWhiteSpace(formModel.JobTitle) ? null : formModel.JobTitle,
                        null,
                        formModel.EmploymentStatus,
                        formModel.EmploymentType,
                        formModel.LinkedUserId));
                    successMessage = formModel.LinkedUserId.HasValue
                        ? "Employee created and linked to existing user account."
                        : "Employee created successfully.";
                }
            }

            showForm = false;
            editingEmployeeId = null;
            editingEmployeeHasUser = false;
            formModel = new EmployeeFormModel();
            userSearchText = "";
            await LoadEmployees();
        }
        catch (ApiException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = $"Operation failed: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void ConfirmDelete(EmployeeResponse emp)
    {
        deletingEmployee = emp;
        showDeleteConfirm = true;
        ClearMessages();
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        deletingEmployee = null;
    }

    private async Task ExecuteDelete()
    {
        if (deletingEmployee == null) return;

        isSubmitting = true;
        try
        {
            await EmployeeApi.DeleteEmployeeAsync(deletingEmployee.Id);
            successMessage = $"Employee {deletingEmployee.FirstName} {deletingEmployee.LastName} deleted.";
            showDeleteConfirm = false;
            deletingEmployee = null;
            await LoadEmployees();
        }
        catch (Exception ex)
        {
            errorMessage = $"Delete failed: {ex.Message}";
            showDeleteConfirm = false;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    // User linking helpers
    private void FilterUnlinkedUsers(ChangeEventArgs e)
    {
        userSearchText = e.Value?.ToString() ?? "";
        filteredUnlinkedUsers = string.IsNullOrWhiteSpace(userSearchText)
            ? unlinkedUsers
            : unlinkedUsers.Where(u =>
                $"{u.FirstName} {u.LastName} {u.Email}".Contains(userSearchText, StringComparison.OrdinalIgnoreCase))
                .ToList();
        showUserDropdown = true;
        formModel.LinkedUserId = null;
    }

    private void SelectLinkedUser(UserResponse user)
    {
        formModel.LinkedUserId = user.Id;
        userSearchText = $"{user.FirstName} {user.LastName} ({user.Email})";
        showUserDropdown = false;
        // Mutual exclusion: selecting existing user clears create-new
        formModel.CreateNewUser = false;
    }

    private void ClearLinkedUser()
    {
        formModel.LinkedUserId = null;
        userSearchText = "";
        showUserDropdown = false;
    }

    private void ToggleCreateNewUser()
    {
        if (formModel.LinkedUserId.HasValue) return; // disabled when user is selected
        formModel.CreateNewUser = !formModel.CreateNewUser;
        if (formModel.CreateNewUser)
        {
            // Mutual exclusion: expanding create clears linked user
            formModel.LinkedUserId = null;
            userSearchText = "";
            formModel.UserRole = "User";
            // Auto-derive username from current email
            if (string.IsNullOrEmpty(formModel.NewUserUsername) && !string.IsNullOrEmpty(formModel.Email))
            {
                formModel.NewUserUsername = formModel.Email.Contains('@') ? formModel.Email.Split('@')[0] : formModel.Email;
            }
        }
    }

    private void OnEmployeeEmailChanged()
    {
        // Auto-derive new-user username from email if create-new-user is toggled on
        if (formModel.CreateNewUser && string.IsNullOrEmpty(formModel.NewUserUsername))
        {
            var email = formModel.Email;
            formModel.NewUserUsername = email.Contains('@') ? email.Split('@')[0] : email;
        }
    }

    private async Task HandleUserSearchBlur()
    {
        await Task.Delay(200);
        showUserDropdown = false;
    }

    private void ClearMessages()
    {
        errorMessage = null;
        successMessage = null;
    }

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "Active" => "bg-success",
        "OnLeave" => "bg-warning text-dark",
        "Terminated" => "bg-danger",
        "Suspended" => "bg-orange",
        _ => "bg-secondary"
    };

    private static string FormatStatus(string status) => status switch
    {
        "OnLeave" => "On Leave",
        _ => status
    };

    private static string FormatType(string type) => type switch
    {
        "FullTime" => "Full Time",
        "PartTime" => "Part Time",
        _ => type
    };

    public class EmployeeFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string FirstName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        public string LastName { get; set; } = "";

        public string MiddleName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = "";

        public string Phone { get; set; } = "";

        public DateOnly? DateOfBirth { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        public DateOnly HireDate { get; set; } = DateOnly.FromDateTime(DateTime.Today);

        public DateOnly? TerminationDate { get; set; }

        public string Department { get; set; } = "";

        public string JobTitle { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        public string EmploymentStatus { get; set; } = "Active";

        [System.ComponentModel.DataAnnotations.Required]
        public string EmploymentType { get; set; } = "";

        // User account linking fields
        public Guid? LinkedUserId { get; set; }
        public bool CreateNewUser { get; set; }
        public string UserRole { get; set; } = "User";
        public string NewUserUsername { get; set; } = "";
    }
}
