@using WarpBusiness.Web.Services
@inject TenantStateService TenantState
@inject IHttpContextAccessor HttpContextAccessor

<nav class="navbar navbar-expand-lg warp-navbar">
    <div class="container-fluid">
        <a class="navbar-brand warp-brand" href="">
            <svg class="warp-logo" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="28" height="28" aria-hidden="true">
                <defs>
                    <filter id="nav-glow">
                        <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
                        <feMerge>
                            <feMergeNode in="coloredBlur"/>
                            <feMergeNode in="SourceGraphic"/>
                        </feMerge>
                    </filter>
                </defs>
                <circle cx="50" cy="50" r="50" fill="#0a0e1a"/>
                <circle cx="50" cy="50" r="46" fill="none" stroke="#00d4ff" stroke-width="1.5" opacity="0.4"/>
                <polyline points="15,28 32,72 45,45 58,72 75,28" fill="none" stroke="#00d4ff" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
                <polyline points="15,28 32,72 45,45 58,72 75,28" fill="none" stroke="#00d4ff" stroke-width="8" stroke-linecap="round" stroke-linejoin="round" filter="url(#nav-glow)" opacity="0.7"/>
            </svg>
            <span>WARP BUSINESS</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarContent">
            <ul class="navbar-nav me-auto">
                <AuthorizeView>
                    <Authorized Context="modulesContext">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Modules
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><NavLink class="dropdown-item" href="employees">Employees</NavLink></li>
                                <li><NavLink class="dropdown-item" href="crm/customers">Customers</NavLink></li>
                                <li><NavLink class="dropdown-item" href="crm/businesses">Businesses</NavLink></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><NavLink class="dropdown-item" href="catalog/products">Catalog Products</NavLink></li>
                                <li><NavLink class="dropdown-item" href="catalog/categories">Catalog Categories</NavLink></li>
                                <li><NavLink class="dropdown-item" href="catalog/colors">Catalog Colors</NavLink></li>
                                <li><NavLink class="dropdown-item" href="catalog/sizes">Catalog Sizes</NavLink></li>
                            </ul>
                        </li>
                    </Authorized>
                </AuthorizeView>
                <AuthorizeView>
                    <Authorized>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Admin
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><NavLink class="dropdown-item" href="users">Users</NavLink></li>
                                <AuthorizeView Roles="SystemAdministrator">
                                    <Authorized Context="adminContext">
                                        <li><NavLink class="dropdown-item" href="tenants">Tenants</NavLink></li>
                                        <li><NavLink class="dropdown-item" href="currencies">Currencies</NavLink></li>
                                    </Authorized>
                                </AuthorizeView>
                            </ul>
                        </li>
                    </Authorized>
                </AuthorizeView>
            </ul>
            <div class="d-flex align-items-center">
                <AuthorizeView>
                    <Authorized>
                        @{
                            var tenantName = GetSelectedTenantName();
                        }
                        @if (!string.IsNullOrEmpty(tenantName))
                        {
                            <span class="text-light me-3">
                                Working in: <strong>@tenantName</strong>
                                <a href="/select-tenant" class="ms-1 text-decoration-none text-info" title="Switch organization">[Switch]</a>
                            </span>
                        }
                        <a href="/profile" class="text-light text-decoration-none me-3 profile-link">@context.User.Identity?.Name</a>
                        <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="btn btn-outline-light btn-sm">Login</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </div>
</nav>

<style>
    .warp-navbar {
        background-color: rgba(5, 11, 24, 0.92);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(0, 200, 255, 0.18);
    }

    .warp-brand {
        font-family: 'Orbitron', sans-serif;
        font-weight: 700;
        letter-spacing: 0.05em;
        color: #e8f0fe !important;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .warp-logo {
        flex-shrink: 0;
    }

    .navbar-toggler {
        border-color: rgba(0, 200, 255, 0.3);
    }

    .navbar-toggler-icon {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba(0,200,255,0.8)' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
    }

    .warp-navbar .nav-link {
        color: #8899bb !important;
        transition: color 0.2s;
    }

    .warp-navbar .nav-link:hover,
    .warp-navbar .nav-link:focus {
        color: #00c8ff !important;
    }

    .warp-navbar .nav-link.active {
        color: #00c8ff !important;
        font-weight: 600;
    }

    .warp-navbar .dropdown-menu {
        background-color: #0b1628;
        border: 1px solid rgba(0, 200, 255, 0.18);
    }

    .warp-navbar .dropdown-item {
        color: #8899bb;
    }

    .warp-navbar .dropdown-item:hover,
    .warp-navbar .dropdown-item:focus {
        background-color: rgba(0, 200, 255, 0.1);
        color: #00c8ff;
    }

    .warp-navbar .dropdown-item.active,
    .warp-navbar .dropdown-item:active {
        background-color: rgba(0, 200, 255, 0.15);
        color: #00c8ff;
    }

    .warp-navbar .text-light {
        color: #8899bb !important;
    }

    .warp-navbar .text-info {
        color: #00c8ff !important;
    }

    .profile-link:hover {
        text-decoration: underline !important;
        color: #00c8ff !important;
    }
</style>

@code {
    private string? GetSelectedTenantName()
    {
        if (!string.IsNullOrEmpty(TenantState.SelectedTenantName))
            return TenantState.SelectedTenantName;

        // SSR fallback: TenantStateService isn't populated yet, read from cookies
        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext is not null)
        {
            if (httpContext.Request.Cookies.TryGetValue("X-Selected-Tenant-Name", out var name)
                && !string.IsNullOrEmpty(name))
                return name;

            if (httpContext.Request.Cookies.ContainsKey("X-Selected-Tenant"))
                return "Selected Organization";
        }

        return null;
    }
}
