<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WarpBusiness.MobileApp.Views.TenantSettingsPage"
             Title="Tenant Settings"
             BackgroundColor="#050b18">

    <Grid>
        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="#00c8ff"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           ZIndex="1" />

        <ScrollView>
            <VerticalStackLayout Spacing="12" Padding="16">

                <!-- Messages -->
                <Label Text="{Binding ErrorMessage}"
                       TextColor="#f44336"
                       IsVisible="{Binding ErrorMessage, FallbackValue=False, TargetNullValue=False}"
                       Margin="0,0,0,4" />
                <Label Text="{Binding SuccessMessage}"
                       TextColor="#4caf50"
                       IsVisible="{Binding SuccessMessage, FallbackValue=False, TargetNullValue=False}"
                       Margin="0,0,0,4" />

                <!-- Tenant Info Section -->
                <Label Text="TENANT INFORMATION" TextColor="#00c8ff" FontSize="14" FontAttributes="Bold" Margin="0,8,0,4" />

                <Label Text="Tenant Name" TextColor="#aaaaaa" FontSize="12" />
                <Entry Text="{Binding TenantName}"
                       TextColor="White"
                       BackgroundColor="#0f1e35"
                       PlaceholderColor="#666666"
                       Placeholder="Tenant name" />

                <Label Text="Display Name" TextColor="#aaaaaa" FontSize="12" />
                <Entry Text="{Binding DisplayName}"
                       TextColor="White"
                       BackgroundColor="#0f1e35"
                       PlaceholderColor="#666666"
                       Placeholder="Display name" />

                <!-- Save Button -->
                <Button Text="Save"
                        Command="{Binding SaveCommand}"
                        BackgroundColor="#00c8ff"
                        TextColor="#050b18"
                        FontAttributes="Bold"
                        CornerRadius="8"
                        HeightRequest="48"
                        Margin="0,8,0,0" />

                <!-- Members Section -->
                <Label Text="MEMBERS"
                       TextColor="#00c8ff"
                       FontSize="14"
                       FontAttributes="Bold"
                       Margin="0,16,0,4" />

                <CollectionView ItemsSource="{Binding Members}">
                    <CollectionView.EmptyView>
                        <Label Text="No members"
                               TextColor="#666666"
                               HorizontalOptions="Center"
                               Margin="0,16" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame BackgroundColor="#0f1e35"
                                   BorderColor="#1a3a5c"
                                   CornerRadius="8"
                                   Margin="0,4"
                                   Padding="12">
                                <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="2">
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding FullName}"
                                           TextColor="White"
                                           FontAttributes="Bold"
                                           FontSize="16" />
                                    <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="8">
                                        <Label Text="{Binding Email}"
                                               TextColor="#aaaaaa"
                                               FontSize="12" />
                                        <Label Text="{Binding Role, StringFormat='• {0}'}"
                                               TextColor="#00c8ff"
                                               FontSize="12" />
                                    </HorizontalStackLayout>
                                    <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                            Text="Change Role"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ChangeMemberRoleCommand}"
                                            CommandParameter="{Binding}"
                                            BackgroundColor="#1a3a5c"
                                            TextColor="White"
                                            CornerRadius="8"
                                            HeightRequest="36"
                                            Padding="12,0"
                                            FontSize="12"
                                            VerticalOptions="Center" />
                                    <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                            Text="Remove"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveMemberCommand}"
                                            CommandParameter="{Binding}"
                                            BackgroundColor="#f44336"
                                            TextColor="White"
                                            CornerRadius="8"
                                            HeightRequest="36"
                                            Padding="12,0"
                                            FontSize="12"
                                            VerticalOptions="Center" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <BoxView HeightRequest="24" Color="Transparent" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
