<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:WarpBusiness.MobileApp.ViewModels"
             xmlns:converters="clr-namespace:WarpBusiness.MobileApp.Converters"
             x:Class="WarpBusiness.MobileApp.Views.ActivityListPage"
             x:DataType="vm:ActivityListViewModel"
             Title="Activities"
             BackgroundColor="#050b18">

    <ContentPage.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
    </ContentPage.Resources>

    <Shell.TitleColor>White</Shell.TitleColor>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+" Command="{Binding GoToCreateCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*,Auto" Padding="16">

        <!-- Filters -->
        <VerticalStackLayout Grid.Row="0" Spacing="8" Margin="0,0,0,12">
            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                <Label Text="Completed Only" TextColor="#aaaaaa" VerticalOptions="Center" />
                <Switch IsToggled="{Binding IsCompleted}" OnColor="#00c8ff"
                        ThumbColor="White" />
            </HorizontalStackLayout>
            <Button Text="Apply Filter" Command="{Binding FilterCommand}"
                    BackgroundColor="#00c8ff" TextColor="#050b18" FontAttributes="Bold"
                    CornerRadius="8" HeightRequest="40" />
        </VerticalStackLayout>

        <!-- Activity List -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Activities}">
            <CollectionView.EmptyView>
                <Label Text="No activities found." TextColor="#666666"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="#0f1e35" BorderColor="#1a3a5c"
                           CornerRadius="8" Padding="14" Margin="0,0,0,8"
                           HasShadow="False">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.GoToDetailCommand}"
                                CommandParameter="{Binding}" />
                        </Frame.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Subject}" TextColor="White"
                                   FontAttributes="Bold" FontSize="16"
                                   LineBreakMode="TailTruncation" />
                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Type}" TextColor="#00c8ff"
                                   FontSize="12" VerticalOptions="Center" />
                            <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                   Text="{Binding DueDate, StringFormat='{0:MMM dd, yyyy h:mm tt}'}"
                                   TextColor="#aaaaaa" FontSize="13" />
                            <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="6">
                                <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5"
                                         Color="{Binding IsCompleted, Converter={StaticResource BoolToColorConverter}}" />
                                <Label TextColor="#aaaaaa" FontSize="12">
                                    <Label.Text>
                                        <Binding Path="IsCompleted" StringFormat="{}{0}" />
                                    </Label.Text>
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsCompleted}" Value="True">
                                            <Setter Property="Text" Value="Completed" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsCompleted}" Value="False">
                                            <Setter Property="Text" Value="Pending" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </HorizontalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Pagination -->
        <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center" Spacing="16" Margin="0,12,0,0">
            <Button Text="◀ Previous" Command="{Binding PreviousPageCommand}"
                    BackgroundColor="#1a3a5c" TextColor="White" CornerRadius="8"
                    IsVisible="{Binding HasPreviousPage}" />
            <Label TextColor="White" VerticalOptions="Center" FontSize="14">
                <Label.Text>
                    <MultiBinding StringFormat="Page {0} of {1}">
                        <Binding Path="CurrentPage" />
                        <Binding Path="TotalPages" />
                    </MultiBinding>
                </Label.Text>
            </Label>
            <Button Text="Next ▶" Command="{Binding NextPageCommand}"
                    BackgroundColor="#1a3a5c" TextColor="White" CornerRadius="8"
                    IsVisible="{Binding HasNextPage}" />
        </HorizontalStackLayout>

        <!-- Loading Overlay -->
        <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           Color="#00c8ff" HorizontalOptions="Center" VerticalOptions="Center" />
    </Grid>
</ContentPage>
