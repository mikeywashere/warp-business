@page "/employees/new"
@page "/employees/{EmployeeId:guid}"
@using Microsoft.AspNetCore.Authorization
@using WarpBusiness.Shared.Plugins
@attribute [Authorize]
@inject WarpBusiness.Web.Services.WarpApiClient ApiClient
@inject NavigationManager Nav

<PageTitle>@(_isNew ? "New Employee" : (_employee?.FullName ?? "Employee"))</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>@(_isNew ? "Add Employee" : "Edit Employee")</h1>
    <a class="btn btn-outline-secondary" href="employees">← Back to Employees</a>
</div>

@if (_loading)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body">
                    <EditForm Model="_form" OnValidSubmit="SaveAsync">
                        <DataAnnotationsValidator />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">First Name *</label>
                                <InputText class="form-control" @bind-Value="_form.FirstName" />
                                <ValidationMessage For="() => _form.FirstName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Last Name *</label>
                                <InputText class="form-control" @bind-Value="_form.LastName" />
                                <ValidationMessage For="() => _form.LastName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Email *</label>
                                <InputText class="form-control" type="email" @bind-Value="_form.Email" />
                                <ValidationMessage For="() => _form.Email" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Phone</label>
                                <InputText class="form-control" @bind-Value="_form.Phone" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Department</label>
                                <InputText class="form-control" @bind-Value="_form.Department" list="dept-list" />
                                <datalist id="dept-list">
                                    @foreach (var d in _departments)
                                    {
                                        <option value="@d" />
                                    }
                                </datalist>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Job Title</label>
                                <InputText class="form-control" @bind-Value="_form.JobTitle" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Hire Date *</label>
                                <InputDate class="form-control" @bind-Value="_form.HireDate" />
                                <ValidationMessage For="() => _form.HireDate" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Termination Date</label>
                                <InputDate class="form-control" TValue="DateOnly?" @bind-Value="_form.TerminationDate" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Manager</label>
                                <InputSelect class="form-select" @bind-Value="_form.ManagerId">
                                    <option value="">— None —</option>
                                    @foreach (var m in _managers)
                                    {
                                        <option value="@m.Id">@m.FullName (@(m.JobTitle ?? m.Department ?? "Employee"))</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check mt-4">
                                    <InputCheckbox class="form-check-input" @bind-Value="_form.IsActive" id="isActive" />
                                    <label class="form-check-label" for="isActive">Active</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Notes</label>
                                <InputTextArea class="form-control" @bind-Value="_form.Notes" rows="4" />
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(_error))
                        {
                            <div class="alert alert-danger mt-3">@_error</div>
                        }

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary" disabled="@_saving">
                                @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                @(_isNew ? "Create Employee" : "Save Changes")
                            </button>
                            @if (!_isNew)
                            {
                                <button type="button" class="btn btn-warning" @onclick="DeactivateAsync" disabled="@_saving">
                                    Deactivate
                                </button>
                                <button type="button" class="btn btn-outline-danger ms-auto" @onclick="DeleteAsync" disabled="@_saving">
                                    Delete
                                </button>
                            }
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>

        @if (!_isNew && _employee is not null)
        {
            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header">Employee Info</div>
                    <div class="card-body small">
                        <dl class="row mb-0">
                            <dt class="col-sm-5">Status</dt>
                            <dd class="col-sm-7">
                                <span class="badge @(_employee.IsActive ? "bg-success" : "bg-secondary")">
                                    @(_employee.IsActive ? "Active" : "Inactive")
                                </span>
                            </dd>
                            @if (_employee.ManagerName is not null)
                            {
                                <dt class="col-sm-5">Manager</dt>
                                <dd class="col-sm-7">@_employee.ManagerName</dd>
                            }
                            <dt class="col-sm-5">Hired</dt>
                            <dd class="col-sm-7">@_employee.HireDate.ToString("MMM d, yyyy")</dd>
                            @if (_employee.TerminationDate is not null)
                            {
                                <dt class="col-sm-5">Left</dt>
                                <dd class="col-sm-7">@_employee.TerminationDate.Value.ToString("MMM d, yyyy")</dd>
                            }
                            <dt class="col-sm-5">Added</dt>
                            <dd class="col-sm-7">@_employee.CreatedAt.ToString("MMM d, yyyy")</dd>
                        </dl>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public Guid? EmployeeId { get; set; }

    private bool _isNew => EmployeeId is null;
    private EmployeeDto? _employee;
    private EmployeeFormModel _form = new();
    private List<string> _departments = [];
    private List<EmployeeDto> _managers = [];
    private bool _loading = true;
    private bool _saving;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _departments = await ApiClient.GetEmployeeDepartmentsAsync();
        _managers = await ApiClient.GetEmployeeManagersAsync();

        if (!_isNew)
        {
            _employee = await ApiClient.GetEmployeeAsync(EmployeeId!.Value);
            if (_employee is null)
            {
                Nav.NavigateTo("employees");
                return;
            }
            _form = new EmployeeFormModel
            {
                FirstName = _employee.FirstName,
                LastName = _employee.LastName,
                Email = _employee.Email,
                Phone = _employee.Phone ?? string.Empty,
                Department = _employee.Department ?? string.Empty,
                JobTitle = _employee.JobTitle ?? string.Empty,
                HireDate = _employee.HireDate,
                TerminationDate = _employee.TerminationDate,
                IsActive = _employee.IsActive,
                ManagerId = _employee.ManagerId?.ToString() ?? string.Empty,
                Notes = _employee.Notes ?? string.Empty
            };
        }
        _loading = false;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _error = null;
        try
        {
            var req = new EmployeeRequest(
                _form.FirstName, _form.LastName, _form.Email,
                string.IsNullOrEmpty(_form.Phone) ? null : _form.Phone,
                string.IsNullOrEmpty(_form.Department) ? null : _form.Department,
                string.IsNullOrEmpty(_form.JobTitle) ? null : _form.JobTitle,
                _form.HireDate, _form.TerminationDate, _form.IsActive,
                string.IsNullOrEmpty(_form.ManagerId) ? null : Guid.Parse(_form.ManagerId),
                string.IsNullOrEmpty(_form.Notes) ? null : _form.Notes
            );

            if (_isNew)
            {
                var created = await ApiClient.CreateEmployeeAsync(req);
                Nav.NavigateTo($"employees/{created.Id}");
            }
            else
            {
                await ApiClient.UpdateEmployeeAsync(EmployeeId!.Value, req);
                _employee = await ApiClient.GetEmployeeAsync(EmployeeId!.Value);
            }
        }
        catch (Exception ex)
        {
            _error = $"Save failed: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeactivateAsync()
    {
        if (EmployeeId is null) return;
        _saving = true;
        try
        {
            await ApiClient.DeactivateEmployeeAsync(EmployeeId.Value);
            Nav.NavigateTo("employees");
        }
        catch (Exception ex)
        {
            _error = $"Deactivate failed: {ex.Message}";
            _saving = false;
        }
    }

    private async Task DeleteAsync()
    {
        if (EmployeeId is null) return;
        _saving = true;
        try
        {
            await ApiClient.DeleteEmployeeAsync(EmployeeId.Value);
            Nav.NavigateTo("employees");
        }
        catch (Exception ex)
        {
            _error = $"Delete failed: {ex.Message}";
            _saving = false;
        }
    }

    private class EmployeeFormModel
    {
        [System.ComponentModel.DataAnnotations.Required] public string FirstName { get; set; } = string.Empty;
        [System.ComponentModel.DataAnnotations.Required] public string LastName { get; set; } = string.Empty;
        [System.ComponentModel.DataAnnotations.Required] public string Email { get; set; } = string.Empty;
        public string Phone { get; set; } = string.Empty;
        public string Department { get; set; } = string.Empty;
        public string JobTitle { get; set; } = string.Empty;
        public DateOnly HireDate { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public DateOnly? TerminationDate { get; set; }
        public bool IsActive { get; set; } = true;
        public string ManagerId { get; set; } = string.Empty;
        public string Notes { get; set; } = string.Empty;
    }
}
