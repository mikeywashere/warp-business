@page "/employees"
@using Microsoft.AspNetCore.Authorization
@using WarpBusiness.Shared.Plugins
@attribute [Authorize]
@inject WarpBusiness.Web.Services.WarpApiClient ApiClient
@inject NavigationManager Nav

<PageTitle>Employees</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Employees</h1>
    <a class="btn btn-primary" href="employees/new">
        <span class="bi bi-person-plus me-1"></span> Add Employee
    </a>
</div>

<div class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" class="form-control" placeholder="Search by name or email..."
               @bind="_search" @bind:event="oninput" @onkeyup="OnSearchChanged" />
    </div>
    <div class="col-md-3">
        <select class="form-select" @bind="_department" @bind:after="LoadAsync">
            <option value="">All Departments</option>
            @foreach (var dept in _departments)
            {
                <option value="@dept">@dept</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <div class="form-check mt-2">
            <input class="form-check-input" type="checkbox" id="includeInactive"
                   @bind="_includeInactive" @bind:after="LoadAsync" />
            <label class="form-check-label" for="includeInactive">Include inactive</label>
        </div>
    </div>
</div>

@if (_loading)
{
    <p><em>Loading...</em></p>
}
else if (_employees.Count == 0)
{
    <div class="alert alert-info">No employees found.</div>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Job Title</th>
                <th>Department</th>
                <th>Email</th>
                <th>Hire Date</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var emp in _employees)
            {
                <tr @onclick="() => GoToEmployee(emp.Id)" style="cursor:pointer">
                    <td>@emp.FullName</td>
                    <td>@(emp.JobTitle ?? "—")</td>
                    <td>@(emp.Department ?? "—")</td>
                    <td>@emp.Email</td>
                    <td>@emp.HireDate.ToString("MMM d, yyyy")</td>
                    <td>
                        <span class="badge @(emp.IsActive ? "bg-success" : "bg-secondary")">
                            @(emp.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td>
                        <a class="btn btn-sm btn-outline-secondary" href="employees/@emp.Id"
                           @onclick:stopPropagation="true">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (_totalPages > 1)
    {
        <nav>
            <ul class="pagination">
                <li class="page-item @(_page == 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="PrevPage">Previous</button>
                </li>
                @for (var i = 1; i <= _totalPages; i++)
                {
                    var pageNum = i;
                    <li class="page-item @(_page == pageNum ? "active" : "")">
                        <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                    </li>
                }
                <li class="page-item @(_page == _totalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="NextPage">Next</button>
                </li>
            </ul>
        </nav>
    }
    <p class="text-muted small">@_total employees total</p>
}

@code {
    private List<EmployeeDto> _employees = [];
    private List<string> _departments = [];
    private bool _loading = true;
    private int _page = 1;
    private int _pageSize = 20;
    private int _total;
    private int _totalPages => (int)Math.Ceiling(_total / (double)_pageSize);
    private string _search = string.Empty;
    private string _department = string.Empty;
    private bool _includeInactive;
    private System.Timers.Timer? _searchTimer;

    protected override async Task OnInitializedAsync()
    {
        _departments = await ApiClient.GetEmployeeDepartmentsAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();
        var result = await ApiClient.GetEmployeesAsync(_page, _pageSize, _includeInactive,
            string.IsNullOrEmpty(_department) ? null : _department,
            string.IsNullOrEmpty(_search) ? null : _search);
        _employees = result.Items;
        _total = result.Total;
        _loading = false;
    }

    private void OnSearchChanged()
    {
        _searchTimer?.Dispose();
        _searchTimer = new System.Timers.Timer(400);
        _searchTimer.Elapsed += async (_, _) =>
        {
            _searchTimer?.Dispose();
            _page = 1;
            await InvokeAsync(LoadAsync);
        };
        _searchTimer.AutoReset = false;
        _searchTimer.Start();
    }

    private async Task PrevPage() { if (_page > 1) { _page--; await LoadAsync(); } }
    private async Task NextPage() { if (_page < _totalPages) { _page++; await LoadAsync(); } }
    private async Task GoToPage(int p) { _page = p; await LoadAsync(); }
    private void GoToEmployee(Guid id) => Nav.NavigateTo($"employees/{id}");
}
