@page "/register"
@using WarpBusiness.Shared.Auth
@using WarpBusiness.Web.Services
@inject WarpApiClient Api
@inject AuthStateService AuthState
@inject NavigationManager Nav

<PageTitle>Create Account — Warp Business</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h2 class="h4 mb-4 text-center">Create Account</h2>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="alert alert-danger py-2 small">@_errorMessage</div>
                }

                <EditForm Model="_model" OnValidSubmit="HandleRegister">
                    <DataAnnotationsValidator />
                    <div class="row g-2 mb-3">
                        <div class="col">
                            <label class="form-label">First Name</label>
                            <InputText @bind-Value="_model.FirstName" class="form-control" autocomplete="given-name" />
                            <ValidationMessage For="() => _model.FirstName" />
                        </div>
                        <div class="col">
                            <label class="form-label">Last Name</label>
                            <InputText @bind-Value="_model.LastName" class="form-control" autocomplete="family-name" />
                            <ValidationMessage For="() => _model.LastName" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <InputText @bind-Value="_model.Email" class="form-control" type="email"
                                   placeholder="you@example.com" autocomplete="email" />
                        <ValidationMessage For="() => _model.Email" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <InputText @bind-Value="_model.Password" class="form-control" type="password"
                                   autocomplete="new-password" />
                        <ValidationMessage For="() => _model.Password" />
                        <div class="form-text">Min 8 characters, must include a number and uppercase letter.</div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100" disabled="@_submitting">
                        @if (_submitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        }
                        Create Account
                    </button>
                </EditForm>

                <div class="text-center mt-3">
                    <a href="/login" class="text-muted small">Already have an account? Sign in</a>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private readonly RegisterFormModel _model = new();
    private string? _errorMessage;
    private bool _submitting;

    private async Task HandleRegister()
    {
        _submitting = true;
        _errorMessage = null;

        var result = await Api.RegisterAsync(
            new RegisterRequest(_model.Email, _model.Password, _model.FirstName, _model.LastName));

        if (result is not null)
        {
            AuthState.SetAuth(result);
            Nav.NavigateTo("/contacts");
        }
        else
        {
            _errorMessage = "Registration failed. The email may already be in use, or the password doesn't meet requirements.";
        }

        _submitting = false;
    }

    private class RegisterFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string FirstName { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        public string LastName { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MinLength(8)]
        public string Password { get; set; } = string.Empty;
    }
}
