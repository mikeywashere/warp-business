@page "/"
@using WarpBusiness.Web.Services
@inject AuthStateService AuthState
@inject NavigationManager Nav

<PageTitle>Home — Warp Business</PageTitle>

<div class="container py-4">
    @if (AuthState.IsAuthenticated)
    {
        <div class="row g-3">
            <div class="col-12">
                <h1 class="h3">Welcome back, @AuthState.UserFullName 👋</h1>
                <p class="text-muted">Your CRM is ready. Here's what's happening today.</p>
            </div>
            <div class="col-md-4">
                <a href="/contacts" class="card text-decoration-none h-100">
                    <div class="card-body text-center py-4">
                        <span class="display-4">👤</span>
                        <h5 class="mt-2">Contacts</h5>
                        <p class="text-muted small mb-0">Manage your people</p>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="/companies" class="card text-decoration-none h-100">
                    <div class="card-body text-center py-4">
                        <span class="display-4">🏢</span>
                        <h5 class="mt-2">Companies</h5>
                        <p class="text-muted small mb-0">Manage your accounts</p>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="/deals" class="card text-decoration-none h-100">
                    <div class="card-body text-center py-4">
                        <span class="display-4">💰</span>
                        <h5 class="mt-2">Deals</h5>
                        <p class="text-muted small mb-0">Track your pipeline</p>
                    </div>
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row justify-content-center">
            <div class="col-md-6 text-center py-5">
                <h1 class="display-5 fw-bold">Warp Business</h1>
                <p class="lead text-muted">CRM and business management for teams that move fast.</p>
                <a href="/login" class="btn btn-primary btn-lg px-5">Sign In</a>
            </div>
        </div>
    }
</div>

