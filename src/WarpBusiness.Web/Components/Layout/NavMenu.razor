@implements IDisposable
@using WarpBusiness.Web.Services
@using WarpBusiness.Shared.Plugins
@inject AuthStateService AuthState
@inject NavigationManager Nav
@inject WarpApiClient Api

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Warp Business</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        @if (IsAdmin)
        {
            <div class="nav-item px-3 mt-3 border-top pt-2">
                <div class="text-white-50 small fw-semibold mb-2 ms-2">ADMIN</div>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin/users">
                    <span class="bi bi-person-gear" aria-hidden="true"></span> Users
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin/custom-fields">
                    <span class="bi bi-sliders" aria-hidden="true"></span> Custom Fields
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="admin/modules">
                    <span class="bi bi-puzzle" aria-hidden="true"></span> Modules
                </NavLink>
            </div>
        }

        @if (IsTenantAdmin)
        {
            <div class="nav-item px-3 mt-3 border-top pt-2">
                <div class="text-white-50 small fw-semibold mb-2 ms-2">SETTINGS</div>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="settings/workspace">
                    <span class="bi bi-building" aria-hidden="true"></span> Workspace Settings
                </NavLink>
            </div>
        }

        @if (_pluginNavItems.Count > 0)
        {
            <div class="nav-item px-3 mt-3 border-top pt-2">
                <div class="text-white-50 small fw-semibold mb-2 ms-2">EXTENSIONS</div>
            </div>
            @foreach (var item in _pluginNavItems.OrderBy(x => x.DisplayOrder))
            {
                @if (item.RequiredRole == null || AuthState.Roles?.Contains(item.RequiredRole) == true)
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="@item.Href">
                            @if (!string.IsNullOrEmpty(item.Icon))
                            {
                                <span class="@item.Icon me-2" aria-hidden="true"></span>
                            }
                            @item.Label
                        </NavLink>
                    </div>
                }
            }
        }

        <div class="nav-item px-3 mt-3 border-top pt-2">
            @if (AuthState.IsAuthenticated)
            {
                @if (!string.IsNullOrEmpty(AuthState.TenantName))
                {
                    <div class="text-white-50 small mb-1 ms-2">
                        <span class="bi bi-building me-1"></span>@AuthState.TenantName
                    </div>
                }
                <div class="nav-link text-white-50 small">
                    <span class="bi bi-person-circle me-1"></span>
                    @AuthState.UserFullName
                </div>
                <button class="btn btn-sm btn-outline-light w-100 mt-1" @onclick="Logout">
                    Sign out
                </button>
            }
            else
            {
                <NavLink class="nav-link" href="login">
                    <span class="bi bi-box-arrow-in-right" aria-hidden="true"></span> Sign In
                </NavLink>
            }
        </div>
    </nav>
</div>

@code {
    private bool IsAdmin => AuthState.IsAuthenticated 
        && AuthState.Roles?.Contains("Admin") == true;

    private bool IsTenantAdmin => AuthState.IsAuthenticated
        && AuthState.Roles?.Contains("TenantAdmin") == true;

    private List<ModuleNavItemDto> _pluginNavItems = [];

    protected override void OnInitialized()
    {
        AuthState.OnChange += OnAuthChanged;
    }

    private async void OnAuthChanged()
    {
        await LoadPluginNavItemsAsync();
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadPluginNavItemsAsync();
    }

    private async Task LoadPluginNavItemsAsync()
    {
        try
        {
            if (AuthState.IsAuthenticated)
                _pluginNavItems = await Api.GetModuleNavItemsAsync();
            else
                _pluginNavItems = [];
        }
        catch
        {
            _pluginNavItems = [];
        }
    }

    private async Task Logout()
    {
        await Api.LogoutAsync();
        Nav.NavigateTo("/login");
    }

    public void Dispose() => AuthState.OnChange -= OnAuthChanged;
}
