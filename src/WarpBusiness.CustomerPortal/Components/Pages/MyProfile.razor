@page "/my-profile"
@rendermode InteractiveServer
@using WarpBusiness.CustomerPortal.Services
@using WarpBusiness.Shared.Crm
@inject CustomerApiClient Api
@inject CustomerAuthState AuthState
@inject NavigationManager Nav

<PageTitle>My Profile — Warp Customer Portal</PageTitle>

@if (!AuthState.IsAuthenticated)
{
    Nav.NavigateTo("/login");
    return;
}

<div class="container mt-4" style="max-width: 540px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 mb-0">My Profile</h1>
        @if (_contact is not null && !_isEditing)
        {
            <button class="btn btn-primary btn-sm" @onclick="EnterEditMode">
                <span class="bi bi-pencil"></span> Edit
            </button>
        }
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger alert-dismissible" role="alert">
            @_errorMessage
            <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="alert alert-success alert-dismissible" role="alert">
            @_successMessage
            <button type="button" class="btn-close" @onclick="() => _successMessage = null"></button>
        </div>
    }

    @if (_loading)
    {
        <div class="spinner-border spinner-border-sm text-primary mt-3"></div>
    }
    else if (_contact is null)
    {
        <div class="alert alert-info mt-3">
            Your profile information isn't linked yet. Please contact your account manager.
        </div>
    }
    else if (_isEditing)
    {
        <div class="card">
            <div class="card-body">
                <EditForm Model="_editModel" OnValidSubmit="SaveChanges">
                    <DataAnnotationsValidator />

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label">First Name</label>
                            <InputText @bind-Value="_editModel.FirstName" class="form-control" />
                            <ValidationMessage For="() => _editModel.FirstName" />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label">Last Name</label>
                            <InputText @bind-Value="_editModel.LastName" class="form-control" />
                            <ValidationMessage For="() => _editModel.LastName" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input class="form-control" value="@_contact.Email" disabled />
                        <div class="form-text">Email is managed by your account.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Phone</label>
                        <InputText @bind-Value="_editModel.Phone" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Job Title</label>
                        <InputText @bind-Value="_editModel.JobTitle" class="form-control" />
                    </div>

                    @foreach (var def in _fieldDefinitions.Where(d => d.IsActive).OrderBy(d => d.DisplayOrder))
                    {
                        var defId = def.Id;
                        <div class="mb-3">
                            <label class="form-label">
                                @def.Name
                                @if (def.IsRequired) { <span class="text-danger ms-1">*</span> }
                            </label>
                            @if (def.FieldType == "Text")
                            {
                                <input type="text" class="form-control" value="@_fieldValues.GetValueOrDefault(defId)"
                                       @onchange="e => _fieldValues[defId] = e.Value?.ToString()" />
                            }
                            else if (def.FieldType == "Number")
                            {
                                <input type="number" class="form-control" value="@_fieldValues.GetValueOrDefault(defId)"
                                       @onchange="e => _fieldValues[defId] = e.Value?.ToString()" />
                            }
                            else if (def.FieldType == "Date")
                            {
                                <input type="date" class="form-control" value="@_fieldValues.GetValueOrDefault(defId)"
                                       @onchange="e => _fieldValues[defId] = e.Value?.ToString()" />
                            }
                            else if (def.FieldType == "Boolean")
                            {
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="pf-@def.Id"
                                           checked="@(_fieldValues.GetValueOrDefault(defId) == "true")"
                                           @onchange="e => HandlePortalBoolChange(defId, e)" />
                                    <label class="form-check-label" for="pf-@def.Id">Yes</label>
                                </div>
                            }
                            else if (def.FieldType == "Select" && def.SelectOptions is not null)
                            {
                                <select class="form-select" value="@_fieldValues.GetValueOrDefault(defId)"
                                        @onchange="e => _fieldValues[defId] = e.Value?.ToString()">
                                    <option value="">-- Select --</option>
                                    @foreach (var opt in def.SelectOptions)
                                    {
                                        <option value="@opt">@opt</option>
                                    }
                                </select>
                            }
                        </div>
                    }

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" disabled="@_saving">
                            @if (_saving)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            Save
                        </button>
                        <button type="button" class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <div class="row mb-2">
                    <div class="col-sm-4 text-muted small">First Name</div>
                    <div class="col-sm-8 fw-semibold">@_contact.FirstName</div>
                </div>
                <div class="row mb-2">
                    <div class="col-sm-4 text-muted small">Last Name</div>
                    <div class="col-sm-8 fw-semibold">@_contact.LastName</div>
                </div>
                <div class="row mb-2">
                    <div class="col-sm-4 text-muted small">Email</div>
                    <div class="col-sm-8">
                        @if (!string.IsNullOrEmpty(_contact.Email))
                        {
                            <a href="mailto:@_contact.Email">@_contact.Email</a>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </div>
                </div>
                <div class="row mb-2">
                    <div class="col-sm-4 text-muted small">Phone</div>
                    <div class="col-sm-8">@(_contact.Phone ?? "—")</div>
                </div>
                <div class="row">
                    <div class="col-sm-4 text-muted small">Job Title</div>
                    <div class="col-sm-8">@(_contact.JobTitle ?? "—")</div>
                </div>

                @{
                    var visibleCustomFields = _contact.CustomFields?
                        .Where(cf => !string.IsNullOrEmpty(cf.Value) || cf.IsRequired)
                        .ToList();
                }
                @if (visibleCustomFields?.Count > 0)
                {
                    <hr />
                    <h6 class="text-muted mb-2">Additional Information</h6>
                    @foreach (var cf in visibleCustomFields)
                    {
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted small">@cf.FieldName</div>
                            <div class="col-sm-8">
                                @if (string.IsNullOrEmpty(cf.Value))
                                {
                                    <span class="text-muted">—</span>
                                }
                                else if (cf.FieldType == "Boolean")
                                {
                                    @(cf.Value == "true" ? "Yes" : "No")
                                }
                                else
                                {
                                    @cf.Value
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    private ContactDto? _contact;
    private List<CustomFieldDefinitionDto> _fieldDefinitions = [];
    private Dictionary<Guid, string?> _fieldValues = [];
    private bool _loading = true;
    private bool _isEditing = false;
    private bool _saving = false;
    private string? _errorMessage;
    private string? _successMessage;

    private EditProfileModel _editModel = new();

    protected override async Task OnInitializedAsync()
    {
        var contactTask = Api.GetMyContactAsync();
        var fieldDefsTask = Api.GetCustomFieldDefinitionsAsync("Contact");
        _contact = await contactTask;
        _fieldDefinitions = await fieldDefsTask;
        _loading = false;
    }

    private void EnterEditMode()
    {
        _errorMessage = null;
        _successMessage = null;
        _editModel = new EditProfileModel
        {
            FirstName = _contact!.FirstName,
            LastName = _contact.LastName,
            Phone = _contact.Phone,
            JobTitle = _contact.JobTitle
        };

        _fieldValues = [];
        foreach (var def in _fieldDefinitions.Where(d => d.IsActive))
        {
            var existing = _contact.CustomFields?.FirstOrDefault(cf => cf.FieldDefinitionId == def.Id);
            _fieldValues[def.Id] = existing?.Value;
        }

        _isEditing = true;
    }

    private void CancelEdit()
    {
        _isEditing = false;
        _errorMessage = null;
    }

    private async Task SaveChanges()
    {
        _saving = true;
        _errorMessage = null;
        _successMessage = null;

        var request = new UpdateContactRequest(
            _editModel.FirstName ?? _contact!.FirstName,
            _editModel.LastName ?? _contact!.LastName,
            _contact!.Email,
            _editModel.Phone,
            _editModel.JobTitle,
            _contact.CompanyId,
            _contact.Status,
            _fieldValues.Select(kv => new UpsertCustomFieldValueRequest(kv.Key, kv.Value)).ToList()
        );

        var result = await Api.UpdateMyContactAsync(_contact!.Id, request);

        if (result is not null)
        {
            _contact = result;
            _isEditing = false;
            _successMessage = "Profile updated successfully.";
        }
        else
        {
            _errorMessage = "Failed to save changes. Please try again.";
        }

        _saving = false;
    }

    private void HandlePortalBoolChange(Guid defId, ChangeEventArgs e)
        => _fieldValues[defId] = e.Value is bool b && b ? "true" : "false";

    private class EditProfileModel
    {
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
        public string? Phone { get; set; }
        public string? JobTitle { get; set; }
    }
}
