{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AuthProvider": {
    "ActiveProvider": "Local",
    "Keycloak": {
      "Authority": "",
      "ClientId": "",
      "Audience": "",
      "EmailClaim": "email",
      "NameClaim": "name"
    },
    "Microsoft": {
      "TenantId": "",
      "ClientId": "",
      "Audience": ""
    }
  },
  "Jwt": {
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  }
}
