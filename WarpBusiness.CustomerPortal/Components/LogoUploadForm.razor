@using WarpBusiness.CustomerPortal.Services
@using Microsoft.AspNetCore.Components.Forms
@inject LogoService LogoService
@inject CustomerPortalApiClient ApiClient

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Upload Logo</h5>
    </div>
    <div class="card-body">
        <div class="mb-3">
            <label for="logoFile" class="form-label">Select Logo File</label>
            <div class="upload-zone">
                <InputFile id="logoFile" onchange="@HandleFileSelected" accept="image/png,image/jpeg,image/webp,image/svg+xml" />
                <p class="text-center mb-0" style="color: var(--clr-text-muted);">
                    Select your logo (PNG, JPG, WEBP, or SVG - max 2MB)
                </p>
                @if (!string.IsNullOrEmpty(selectedFileName))
                {
                    <p class="text-center mt-2" style="color: var(--clr-accent);">
                        Selected: <strong>@selectedFileName</strong>
                    </p>
                }
            </div>
            @if (!string.IsNullOrEmpty(validationError))
            {
                <div class="alert alert-danger mt-2">@validationError</div>
            }
        </div>

        @if (uploadProgress > 0 && uploadProgress < 100)
        {
            <div class="progress mb-3">
                <div class="progress-bar" role="progressbar" style="width: @uploadProgress%" 
                     aria-valuenow="@uploadProgress" aria-valuemin="0" aria-valuemax="100">
                    @uploadProgress%
                </div>
            </div>
        }

        <div class="d-flex gap-2">
            <button type="button" class="btn btn-primary" @onclick="@HandleUpload" disabled="@(isLoading || selectedFile == null)">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                }
                Upload
            </button>
            <button type="button" class="btn btn-outline-light" @onclick="@HandleClear" disabled="@isLoading">
                Clear
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Guid CustomerId { get; set; }

    [Parameter]
    public EventCallback OnUploadSuccessAsync { get; set; }

    [Parameter]
    public EventCallback OnDeleteAsync { get; set; }

    private IBrowserFile? selectedFile;
    private string? selectedFileName;
    private string? validationError;
    private bool isLoading;
    private int uploadProgress;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        selectedFileName = selectedFile?.Name ?? "";
        validationError = null;

        if (selectedFile == null)
            return;

        if (!LogoService.IsValidFileSize(selectedFile.Size))
        {
            validationError = "File too large (max 2MB)";
            selectedFile = null;
            selectedFileName = null;
            return;
        }

        var mimeType = selectedFile.ContentType ?? "";
        if (!LogoService.IsValidMimeType(mimeType))
        {
            validationError = "Unsupported file type (PNG, JPG, WEBP, SVG only)";
            selectedFile = null;
            selectedFileName = null;
            return;
        }
    }

    private async Task HandleUpload()
    {
        if (selectedFile == null)
            return;

        isLoading = true;
        uploadProgress = 0;
        validationError = null;

        try
        {
            using var ms = new MemoryStream();
            await selectedFile.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024).CopyToAsync(ms);
            var bytes = ms.ToArray();
            var mimeType = selectedFile.ContentType ?? "application/octet-stream";

            uploadProgress = 50;
            
            await ApiClient.UploadLogoAsync(CustomerId, bytes, mimeType);
            uploadProgress = 100;

            selectedFile = null;
            selectedFileName = null;
            await OnUploadSuccessAsync.InvokeAsync();
        }
        catch (Exception ex)
        {
            validationError = $"Upload failed: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            uploadProgress = 0;
        }
    }

    private void HandleClear()
    {
        selectedFile = null;
        selectedFileName = null;
        validationError = null;
    }
}

<style>
    .upload-zone {
        border: 2px dashed var(--clr-border);
        border-radius: 8px;
        padding: 2rem;
        text-align: center;
        transition: all 0.3s ease;
        background-color: rgba(0, 200, 255, 0.02);
        cursor: pointer;
    }

    .upload-zone:hover {
        border-color: var(--clr-accent);
        background-color: rgba(0, 200, 255, 0.05);
    }

    ::deep .upload-zone input[type="file"] {
        opacity: 0;
        position: absolute;
        width: 100%;
        height: 100%;
        cursor: pointer;
    }
</style>
